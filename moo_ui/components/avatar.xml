<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="avatar" name="Moo UI Avatar">
        <span t-attf-class="o_moo_ui_avatar o_moo_ui_avatar_#{avatar_size or 'md'} #{avatar_class or ''}"
              t-att-aria-label="avatar_label or avatar_initials or None"
              role="img">
            <img t-if="avatar_src"
                 class="o_moo_ui_avatar_image"
                 t-att-src="avatar_src"
                 t-att-alt="avatar_label or ''"/>
            <span t-else="" class="o_moo_ui_avatar_fallback" t-out="avatar_initials or '•'"/>
        </span>
    </template>
</odoo>
