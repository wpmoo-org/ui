<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="popover" name="Moo UI Popover">
        <button type="button"
                t-attf-class="o_moo_ui_popover btn btn-outline-secondary #{popover_class or ''}"
                data-moo-ui-popover="1"
                data-bs-toggle="popover"
                t-att-title="popover_title"
                t-att-data-bs-content="popover_body">
            <t t-out="0"/>
        </button>
    </template>
</odoo>
