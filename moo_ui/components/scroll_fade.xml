<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="scroll_fade" name="Moo UI Scroll Fade">
        <div t-attf-class="o_moo_ui_scroll_fade o_moo_ui_scroll_fade_#{scroll_fade_orientation or 'y'} #{scroll_fade_class or ''}"
             t-att-data-orientation="scroll_fade_orientation or 'y'"
             t-att-style="scroll_fade_style or None">
            <t t-out="0"/>
        </div>
    </template>
</odoo>
