<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="tabs" name="Moo UI Tabs">
        <nav t-attf-class="o_moo_ui_tabs #{tabs_class or ''}" role="tablist">
            <t t-foreach="tabs_items or ()" t-as="item">
                <a t-att-href="item.get('url') or item.get('target') or '#'"
                   t-attf-class="o_moo_ui_tabs_trigger #{'active' if item.get('active') else ''}"
                   role="tab"
                   t-att-aria-selected="'true' if item.get('active') else 'false'">
                    <t t-out="item.get('label')"/>
                </a>
            </t>
        </nav>
    </template>
</odoo>
