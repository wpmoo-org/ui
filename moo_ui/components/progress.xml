<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="progress" name="Moo UI Progress">
        <div t-attf-class="o_moo_ui_progress progress #{progress_class or ''}"
             role="progressbar"
             t-att-aria-valuenow="progress_value or 0"
             aria-valuemin="0"
             t-att-aria-valuemax="progress_max or 100"
             t-att-aria-label="progress_label or 'Progress'">
            <div class="progress-bar" t-attf-style="width: #{((progress_value or 0) / (progress_max or 100)) * 100}%"/>
        </div>
    </template>
</odoo>
