<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="drawer" name="Moo UI Drawer">
        <aside t-att-id="drawer_id"
               t-attf-class="offcanvas offcanvas-#{drawer_side or 'end'} o_moo_ui_drawer #{drawer_class or ''}"
               tabindex="-1"
               t-att-aria-labelledby="drawer_id and (drawer_id + '_title') or None">
            <div class="offcanvas-header o_moo_ui_drawer_header">
                <div>
                    <h2 t-att-id="drawer_id and (drawer_id + '_title') or None"
                        class="offcanvas-title o_moo_ui_drawer_title"
                        t-out="drawer_title"/>
                    <p t-if="drawer_description" class="o_moo_ui_drawer_description" t-out="drawer_description"/>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"/>
            </div>
            <div class="offcanvas-body o_moo_ui_drawer_body">
                <t t-out="0"/>
            </div>
        </aside>
    </template>
</odoo>
