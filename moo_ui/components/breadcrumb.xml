<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="breadcrumb" name="Moo UI Breadcrumb">
        <nav t-attf-class="o_moo_ui_breadcrumb #{breadcrumb_class or ''}" aria-label="Breadcrumb">
            <ol class="breadcrumb mb-0">
                <t t-foreach="breadcrumb_items or ()" t-as="item">
                    <li t-attf-class="breadcrumb-item #{'active' if item.get('active') else ''}"
                        t-att-aria-current="'page' if item.get('active') else None">
                        <a t-if="item.get('url') and not item.get('active')" t-att-href="item.get('url')" t-out="item.get('label')"/>
                        <span t-else="" t-out="item.get('label')"/>
                    </li>
                </t>
            </ol>
        </nav>
    </template>
</odoo>
