<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="separator" name="Moo UI Separator">
        <hr t-if="(separator_orientation or 'horizontal') == 'horizontal'"
            t-attf-class="o_moo_ui_separator o_moo_ui_separator_horizontal #{separator_class or ''}"
            t-att-aria-hidden="'true' if separator_decorative else None"/>
        <span t-else=""
              t-attf-class="o_moo_ui_separator o_moo_ui_separator_vertical #{separator_class or ''}"
              role="separator"
              aria-orientation="vertical"
              t-att-aria-hidden="'true' if separator_decorative else None"/>
    </template>
</odoo>
