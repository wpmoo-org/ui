<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="textarea" name="Moo UI Textarea">
        <textarea t-att-id="textarea_id"
                  t-att-name="textarea_name"
                  t-att-placeholder="textarea_placeholder"
                  t-att-required="'required' if textarea_required else None"
                  t-att-disabled="'disabled' if textarea_disabled else None"
                  t-att-rows="textarea_rows or 4"
                  t-attf-class="o_moo_ui_textarea form-control #{textarea_class or ''}"><t t-out="0"/></textarea>
    </template>
</odoo>
