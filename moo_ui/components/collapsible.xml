<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="collapsible" name="Moo UI Collapsible">
        <section t-attf-class="o_moo_ui_collapsible #{collapsible_class or ''}">
            <button class="o_moo_ui_collapsible_trigger btn btn-outline-secondary"
                    type="button"
                    data-bs-toggle="collapse"
                    t-att-data-bs-target="'#' + collapsible_id"
                    t-att-aria-controls="collapsible_id"
                    aria-expanded="false">
                <t t-out="collapsible_label or 'Toggle'"/>
            </button>
            <div t-att-id="collapsible_id" class="o_moo_ui_collapsible_content collapse">
                <t t-out="0"/>
            </div>
        </section>
    </template>
</odoo>
