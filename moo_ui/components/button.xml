<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="button" name="Moo UI Button">
        <t t-set="button_variant" t-value="button_variant or 'default'"/>
        <t t-set="button_size" t-value="button_size or 'md'"/>
        <a t-if="button_href"
           t-att-href="button_href"
           t-attf-class="o_moo_ui_button o_moo_ui_button_#{button_variant} o_moo_ui_button_#{button_size} #{button_class or ''}"
           t-att="button_attrs or {}"
           t-att-aria-disabled="'true' if button_disabled else None">
            <t t-out="0"/>
        </a>
        <button t-else=""
                t-att-type="button_type or 'button'"
                t-attf-class="o_moo_ui_button o_moo_ui_button_#{button_variant} o_moo_ui_button_#{button_size} #{button_class or ''}"
                t-att="button_attrs or {}"
                t-att-disabled="'disabled' if button_disabled else None">
            <t t-out="0"/>
        </button>
    </template>
</odoo>
