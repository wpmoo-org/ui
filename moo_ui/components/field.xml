<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="field" name="Moo UI Field">
        <div t-attf-class="o_moo_ui_field #{'o_moo_ui_field_invalid' if field_error else ''} #{field_class or ''}">
            <label t-if="field_label" t-att-for="field_for" class="o_moo_ui_field_label">
                <t t-out="field_label"/>
                <span t-if="field_required" aria-hidden="true">*</span>
            </label>
            <div class="o_moo_ui_field_control">
                <t t-out="0"/>
            </div>
            <p t-if="field_description" class="o_moo_ui_field_description" t-out="field_description"/>
            <p t-if="field_error" class="o_moo_ui_field_error" t-out="field_error"/>
        </div>
    </template>
</odoo>
