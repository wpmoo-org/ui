<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="pagination" name="Moo UI Pagination">
        <nav t-attf-class="o_moo_ui_pagination #{pagination_class or ''}" aria-label="Pagination">
            <ul class="pagination mb-0">
                <t t-foreach="pagination_items or ()" t-as="item">
                    <li t-attf-class="page-item #{'active' if item.get('active') else ''} #{'disabled' if item.get('disabled') else ''}">
                        <a class="page-link" t-att-href="item.get('url') or '#'" t-out="item.get('label')"/>
                    </li>
                </t>
            </ul>
        </nav>
    </template>
</odoo>
