<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="select" name="Moo UI Select">
        <select t-att-id="select_id"
                t-att-name="select_name"
                t-att-required="'required' if select_required else None"
                t-att-disabled="'disabled' if select_disabled else None"
                t-attf-class="o_moo_ui_select form-select #{select_class or ''}">
            <t t-foreach="select_options or ()" t-as="option">
                <option t-att-value="option.get('value')"
                        t-att-selected="'selected' if option.get('value') == select_value else None"
                        t-out="option.get('label')"/>
            </t>
        </select>
    </template>
</odoo>
