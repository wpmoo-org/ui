<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="checkbox" name="Moo UI Checkbox">
        <div t-attf-class="o_moo_ui_checkbox form-check #{checkbox_class or ''}">
            <input class="form-check-input"
                   type="checkbox"
                   t-att-id="checkbox_id"
                   t-att-name="checkbox_name"
                   t-att-value="checkbox_value or '1'"
                   t-att-checked="'checked' if checkbox_checked else None"
                   t-att-disabled="'disabled' if checkbox_disabled else None"/>
            <label class="form-check-label" t-att-for="checkbox_id">
                <t t-out="0"/>
            </label>
        </div>
    </template>
</odoo>
