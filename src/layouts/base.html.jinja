<!doctype html>
<html lang="en" dir="ltr" data-bs-theme="light">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Moo UI Bootstrap component catalog">
    <title>{% block title %}Moo UI{% endblock %}</title>
    <script>
      (() => {
        try {
          const theme = window.localStorage.getItem("moo:theme");
          if (theme === "dark" || theme === "light") {
            document.documentElement.dataset.bsTheme = theme;
          }
        } catch (_) {
          /* localStorage can be unavailable in restricted browsing contexts. */
        }
      })();
    </script>
    <link rel="preload" href="{{ root_path }}assets/fonts/geist/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="stylesheet" href="{{ root_path }}assets/css/moo-ui.css?v={{ asset_version }}">
    <link rel="stylesheet" href="{{ root_path }}assets/css/catalog.css?v={{ asset_version }}">
  </head>
  <body>
    <a class="visually-hidden-focusable" href="#main-content">
      Skip to component content
    </a>
    {% block body %}{% endblock %}
    <script defer src="{{ root_path }}assets/js/bootstrap.bundle.min.js?v={{ asset_version }}"></script>
    <script defer src="{{ root_path }}assets/js/preview.js?v={{ asset_version }}"></script>
  </body>
</html>
