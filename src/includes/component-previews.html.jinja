{# Component and block preview art comes from designer-authored
   transparent-background PNG/WebP files, one per catalog slug, dropped into
   static/images/components/<slug>.webp or static/images/blocks/<slug>.webp
   (copied to dist/assets/images/<category>/ by build.py's existing
   copy_assets() — same static-asset pattern as sidebar-structure.png). The
   originals are generated outside this repo and converted with
   scripts/convert-previews-to-webp.sh; only the WebP output ships here.
   component_preview_src() / block_preview_src() (build.py) resolve to that
   file when it exists on disk at build time (webp preferred over png),
   falling back to static/images/placeholder.webp otherwise — a slug with
   no art yet still renders a real card instead of a broken image. #}

{% macro component_preview(slug, root_path) -%}
  <img
    class="moo-catalog__showcase-image"
    src="{{ component_preview_src(slug, root_path) }}"
    alt=""
    loading="lazy"
  >
{%- endmacro %}

{% macro block_preview(slug, root_path) -%}
  <img
    class="moo-catalog__showcase-image"
    src="{{ block_preview_src(slug, root_path) }}"
    alt=""
    loading="lazy"
  >
{%- endmacro %}
