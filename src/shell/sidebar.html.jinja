<aside
  class="offcanvas-lg offcanvas-start moo-catalog__sidebar"
  tabindex="-1"
  id="catalog-navigation"
  aria-labelledby="catalog-navigation-title"
>
  <div class="offcanvas-header">
    <h2 class="offcanvas-title fs-6" id="catalog-navigation-title">Components</h2>
    <button
      class="btn-close"
      type="button"
      data-bs-dismiss="offcanvas"
      data-bs-target="#catalog-navigation"
      aria-label="Close navigation"
    ></button>
  </div>
  <div class="offcanvas-body d-block">
    <nav aria-label="Components">
      <ul class="nav nav-pills flex-column gap-1">
        {% for component in catalog %}
          <li class="nav-item">
            <a
              class="nav-link{% if current_slug == component.slug %} active{% endif %}"
              href="{{ root_path }}components/{{ component.slug }}.html"
              {% if current_slug == component.slug %}aria-current="page"{% endif %}
            >
              {{ component.label }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</aside>
