{% from "components/sidebar.html.jinja" import sidebar, sidebar_brand_mark, sidebar_content, sidebar_group, sidebar_group_label, sidebar_header, sidebar_menu, sidebar_menu_button, sidebar_menu_item %}
{% from "includes/component-icons.html.jinja" import component_icons %}

{% set utility_icons = {
  "scroll-fade": "scroll"
} %}

{% call sidebar(id="catalog-sidebar", aria_label="Catalog navigation") %}
  {% call sidebar_header() %}
    {% call sidebar_menu() %}
      {% call sidebar_menu_item() %}
        {{ sidebar_menu_button(
          "Moo UI",
          subtitle="Component system",
          size="lg",
          href=site_href("index.html", root_path),
          lead=sidebar_brand_mark("blocks")
        ) }}
      {% endcall %}
    {% endcall %}
  {% endcall %}

  {% call sidebar_content() %}
    {% call sidebar_group() %}
      {{ sidebar_group_label("Sections") }}
      {% call sidebar_menu() %}
        {% for section in sections %}
          {% call sidebar_menu_item() %}
            {{ sidebar_menu_button(
              section.label,
              href=site_href(section.href, root_path),
              active=(current_section == "sections" and current_slug == section.slug) or (current_section == section.slug),
              icon=section.icon
            ) }}
          {% endcall %}
        {% endfor %}
      {% endcall %}
    {% endcall %}

    {% call sidebar_group() %}
      {{ sidebar_group_label("Components") }}
      {% call sidebar_menu() %}
        {% for component in catalog | sort(attribute="label") %}
          {% call sidebar_menu_item() %}
            {{ sidebar_menu_button(
              component.label,
              href=site_href("components/" ~ component.slug ~ ".html", root_path),
              active=current_section == "components" and current_slug == component.slug,
              icon=component_icons.get(component.slug, "component")
            ) }}
          {% endcall %}
        {% endfor %}
      {% endcall %}
    {% endcall %}

    {% call sidebar_group() %}
      {{ sidebar_group_label("Utilities") }}
      {% call sidebar_menu() %}
        {% for utility in utilities %}
          {% call sidebar_menu_item() %}
            {{ sidebar_menu_button(
              utility.label,
              href=site_href("utils/" ~ utility.slug ~ ".html", root_path),
              active=current_section == "utils" and current_slug == utility.slug,
              icon=utility_icons.get(utility.slug, "sparkles")
            ) }}
          {% endcall %}
        {% endfor %}
      {% endcall %}
    {% endcall %}
  {% endcall %}
{% endcall %}
