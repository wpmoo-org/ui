{% from "components/avatar.html.jinja" import avatar %}
{% from "components/dropdown_menu.html.jinja" import dropdown_divider, dropdown_header, dropdown_item, dropdown_menu %}
{% from "components/sidebar.html.jinja" import sidebar, sidebar_brand_mark, sidebar_content, sidebar_footer, sidebar_group, sidebar_group_label, sidebar_header, sidebar_menu, sidebar_menu_button, sidebar_menu_item %}
{% from "includes/component-icons.html.jinja" import component_icons %}

{% set utility_icons = {
  "scroll-fade": "scroll"
} %}

{% call sidebar(id="catalog-sidebar", aria_label="Catalog navigation") %}
  {% call sidebar_header() %}
    {% call sidebar_menu() %}
      {% call sidebar_menu_item(dropdown=true) %}
        {{ sidebar_menu_button(
          "Moo UI",
          subtitle="Component system",
          size="lg",
          dropdown=true,
          lead=sidebar_brand_mark("blocks"),
          end_icon="chevrons-up-down"
        ) }}
        {% call dropdown_menu() %}
          {{ dropdown_header("Workspaces") }}
          {{ dropdown_item("Moo UI", icon="blocks", active=true) }}
          {{ dropdown_item("Moo Odoo", icon="box") }}
          {{ dropdown_divider() }}
          {{ dropdown_item("Add workspace", icon="plus") }}
        {% endcall %}
      {% endcall %}
    {% endcall %}
  {% endcall %}

  {% call sidebar_content() %}
    {% call sidebar_group() %}
      {{ sidebar_group_label("Components") }}
      {% call sidebar_menu() %}
        {% for component in catalog %}
          {% call sidebar_menu_item() %}
            {{ sidebar_menu_button(
              component.label,
              href=root_path ~ "components/" ~ component.slug ~ ".html",
              active=current_section == "components" and current_slug == component.slug,
              icon=component_icons.get(component.slug, "component")
            ) }}
          {% endcall %}
        {% endfor %}
      {% endcall %}
    {% endcall %}

    {% call sidebar_group() %}
      {{ sidebar_group_label("Blocks") }}
      {% call sidebar_menu() %}
        {% call sidebar_menu_item() %}
          {{ sidebar_menu_button(
            "Blocks",
            href=root_path ~ "blocks/index.html",
            active=current_section == "blocks",
            icon="panel-left-dashed"
          ) }}
        {% endcall %}
      {% endcall %}
    {% endcall %}

    {% call sidebar_group() %}
      {{ sidebar_group_label("Utilities") }}
      {% call sidebar_menu() %}
        {% for utility in utilities %}
          {% call sidebar_menu_item() %}
            {{ sidebar_menu_button(
              utility.label,
              href=root_path ~ "utils/" ~ utility.slug ~ ".html",
              active=current_section == "utils" and current_slug == utility.slug,
              icon=utility_icons.get(utility.slug, "sparkles")
            ) }}
          {% endcall %}
        {% endfor %}
      {% endcall %}
    {% endcall %}
  {% endcall %}

  {% call sidebar_footer() %}
    {% call sidebar_menu() %}
      {% call sidebar_menu_item(dropdown=true) %}
        {{ sidebar_menu_button(
          "Moo UI",
          subtitle="Bootstrap-first shell",
          size="lg",
          dropdown=true,
          lead=avatar(name="Moo UI", initials="MO", size="sm", extra_class="sidebar-avatar"),
          end_icon="chevron-right"
        ) }}
        {% call dropdown_menu(align="end") %}
          {{ dropdown_header("hello@wpmoo.org") }}
          {{ dropdown_item("Account", icon="badge-check") }}
          {{ dropdown_item("Settings", icon="settings-2") }}
          {{ dropdown_divider() }}
          {{ dropdown_item("Log out", icon="log-out") }}
        {% endcall %}
      {% endcall %}
    {% endcall %}
  {% endcall %}
{% endcall %}
