{% from "components/button.html.jinja" import button %}
{% from "components/input.html.jinja" import input %}
{% from "components/input_group.html.jinja" import input_group, input_group_text %}
{% from "components/kbd.html.jinja" import kbd %}
{% from "components/navigation.html.jinja" import nav_item, nav_menu %}
{% from "components/sidebar.html.jinja" import sidebar_trigger %}
{% from "components/separator.html.jinja" import separator %}

{% macro _command_item(href, label) -%}
  <a
    class="list-group-item list-group-item-action moo-catalog__command-item"
    href="{{ href }}"
    data-moo-command-item
    role="option"
  >
    <span class="moo-catalog__command-arrow" aria-hidden="true">{{ render_icon("arrow-right", "inline-start") }}</span>
    <span class="moo-catalog__command-title">{{ label }}</span>
  </a>
{%- endmacro %}

<header class="moo-catalog__header">
  <nav class="navbar moo-catalog__navbar" aria-label="Catalog controls">
    <div class="container-fluid moo-catalog__navbar-inner">
      <div class="moo-catalog__header-start">
        {{ sidebar_trigger(sidebar_id="catalog-sidebar", extra_class="moo-catalog__sidebar-toggle") }}
        {{ separator(orientation="vertical", extra_class="moo-catalog__header-divider") }}
        {% call nav_menu("Catalog navigation", style="base", extra_class="moo-catalog__header-nav") %}
          {{ nav_item("Home", href=root_path ~ "index.html") }}
        {% endcall %}
      </div>

      <div class="moo-catalog__header-actions">
        {{ button(
          "Search documentation...",
          variant="ghost",
          size="default",
          element="button",
          aria_label="Search documentation",
          icon_start="search",
          extra_class="moo-catalog__search-trigger d-none d-md-inline-flex"
        ) }}
        {{ separator(orientation="vertical", extra_class="moo-catalog__header-divider moo-catalog__header-divider--leading") }}
        {{ button(
          "wpmoo-org/ui",
          variant="ghost",
          size="default",
          element="a",
          href="https://github.com/wpmoo-org/ui",
          aria_label="Open Moo UI on GitHub",
          icon_start="github",
          extra_class="moo-catalog__github-link"
        ) }}
        {{ separator(orientation="vertical", extra_class="moo-catalog__header-divider") }}
        <button
          class="btn btn-ghost btn-icon moo-catalog__theme-toggle"
          type="button"
          data-moo-theme
          aria-label="Switch to dark mode"
        >
          <span data-moo-theme-icon="light">{{ render_icon("sun", "inline-start") }}</span>
          <span data-moo-theme-icon="dark" class="d-none">{{ render_icon("moon-star", "inline-start") }}</span>
        </button>
      </div>
    </div>
  </nav>
</header>

<div
  class="modal fade moo-catalog__command"
  id="catalog-command"
  tabindex="-1"
  aria-labelledby="catalog-command-title"
  data-moo-command
>
  <div class="modal-dialog moo-catalog__command-dialog">
    <div class="modal-content moo-catalog__command-content">
      <div class="modal-header moo-catalog__command-header">
        <h2 class="visually-hidden" id="catalog-command-title">Search documentation</h2>
        {% call input_group(extra_class="moo-catalog__command-search") %}
          {{ input_group_text(render_icon("search", "inline-start")) }}
          {{ input(aria_label="Search documentation", type="search", placeholder="Search documentation...") }}
          {{ input_group_text(kbd("Esc")) }}
        {% endcall %}
      </div>
      <div class="modal-body moo-catalog__command-body">
        <div class="moo-catalog__command-section" id="catalog-command-pages">Pages</div>
        <div class="list-group list-group-flush" role="listbox" aria-labelledby="catalog-command-pages">
          {{ _command_item(root_path ~ "index.html", "Home") }}
          {% for component in catalog %}
            {{ _command_item(root_path ~ "components/" ~ component.slug ~ ".html", component.label) }}
          {% endfor %}
          {% for utility in utilities %}
            {{ _command_item(root_path ~ "utils/" ~ utility.slug ~ ".html", utility.label) }}
          {% endfor %}
        </div>
        <p class="moo-catalog__command-empty" hidden>No matching pages.</p>
      </div>
      <div class="moo-catalog__command-footer">
        {{ kbd("↵") }}
        <span>Go to Page</span>
      </div>
    </div>
  </div>
</div>
