          </svg>
          <span class="moo-catalog__github-label d-none d-lg-inline">wpmoo-org/ui</span>
        </a>
      </div>
    </div>
  </nav>
</header>

<div
  class="modal fade moo-catalog__command"
  id="catalog-command"
  tabindex="-1"
  aria-labelledby="catalog-command-title"
  data-moo-command
>
  <div class="modal-dialog moo-catalog__command-dialog">
    <div class="modal-content moo-catalog__command-content">
      <div class="modal-header moo-catalog__command-header">
        <h2 class="visually-hidden" id="catalog-command-title">Search documentation</h2>
        {% call input_group(extra_class="moo-catalog__command-search") %}
          {{ input_group_text(render_icon("search", "inline-start")) }}
          {{ input(aria_label="Search documentation", type="search", placeholder="Search documentation...") }}
        {% endcall %}
      </div>
      <div class="modal-body moo-catalog__command-body scroll-fade-y no-scrollbar">
        {% set command_groups = [
          ("Pages", "doc"),
          ("Components", "component"),
          ("Utilities", "utility"),
          ("Blocks", "block"),
        ] %}
        <div class="moo-catalog__command-list" role="listbox">
          {% for group_label, group_kind in command_groups %}
            {% set group_pages = site_pages | selectattr("kind", "equalto", group_kind) | list %}
            {% if group_pages %}
              <div class="moo-catalog__command-group" data-moo-command-group>
                <div class="moo-catalog__command-section" id="catalog-command-{{ group_kind }}">{{ group_label }}</div>
                <div class="list-group list-group-flush" aria-labelledby="catalog-command-{{ group_kind }}">
                  {% for page in group_pages %}
                    {{ _command_item(site_href(page.href, root_path), page.label) }}
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
        <p class="moo-catalog__command-empty" hidden>No matching pages.</p>
      </div>
      <div class="moo-catalog__command-footer">
        {{ kbd("↵") }}
        <span>Go to Page</span>
      </div>
    </div>
  </div>
</div>
