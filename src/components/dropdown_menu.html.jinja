{% from "components/button.html.jinja" import button %}

{% set dropdown_alignments = ["", "start", "end"] %}

{% macro dropdown(label, variant="outline", align="", extra_class="", caret=false, auto_close="", offset="") -%}
  {% if align not in dropdown_alignments %}{{ fail("Unknown dropdown alignment: " ~ align) }}{% endif %}
  {% set items %}{{ caller() | trim | safe }}{% endset %}
  <div class="dropdown{% if extra_class %} {{ extra_class }}{% endif %}">
    {{ button(label, variant=variant, dropdown=true, dropdown_caret=caret, dropdown_auto_close=auto_close, dropdown_offset=offset) }}
    {% call dropdown_menu(align=align) %}{{ items | safe }}{% endcall %}
  </div>
{%- endmacro %}

{% macro dropdown_menu(align="", extra_class="") -%}
  {% if align not in dropdown_alignments %}{{ fail("Unknown dropdown alignment: " ~ align) }}{% endif %}
  <ul class="dropdown-menu{% if align %} dropdown-menu-{{ align }}{% endif %}{% if extra_class %} {{ extra_class }}{% endif %}">
    {{ caller() | trim | safe }}
  </ul>
{%- endmacro %}

{% macro dropdown_item(label, href="", icon="", active=false, disabled=false, destructive=false, shortcut="", icon_box=false, extra_class="", target="", rel="", attrs="") -%}
  {% if not label | trim %}{{ fail("Dropdown item label is required") }}{% endif %}
  {% if icon_box and not icon %}{{ fail("Dropdown item icon_box requires an icon") }}{% endif %}
  {% if target and not rel %}{{ fail("Dropdown item target requires rel") }}{% endif %}
  {% set classes = "dropdown-item" %}
  {% if active %}{% set classes = classes ~ " active" %}{% endif %}
  {% if destructive %}{% set classes = classes ~ " text-danger" %}{% endif %}
  {% if extra_class %}{% set classes = classes ~ " " ~ extra_class %}{% endif %}
  {% set icon_markup %}
    {%- if icon and icon_box -%}
      <span class="dropdown-item__icon-box">{{ render_icon(icon, "inline-start") }}</span>
    {%- elif icon -%}
      {{ render_icon(icon, "inline-start") }}
    {%- endif -%}
  {% endset %}
  {% if href %}
    <li>
      <a class="{{ classes }}{% if disabled %} disabled{% endif %}" href="{{ href }}"{% if target %} target="{{ target }}"{% endif %}{% if rel %} rel="{{ rel }}"{% endif %}{% if attrs %} {{ attrs | safe }}{% endif %}{% if disabled %} aria-disabled="true" tabindex="-1"{% endif %}{% if active %} aria-current="true"{% endif %}>
        {{ icon_markup | trim | safe }}
        <span>{{ label }}</span>
        {% if shortcut %}<span class="ms-auto small text-body-secondary">{{ shortcut }}</span>{% endif %}
      </a>
    </li>
  {% else %}
    <li>
      <button class="{{ classes }}" type="button"{% if attrs %} {{ attrs | safe }}{% endif %}{% if disabled %} disabled{% endif %}>
        {{ icon_markup | trim | safe }}
        <span>{{ label }}</span>
        {% if shortcut %}<span class="ms-auto small text-body-secondary">{{ shortcut }}</span>{% endif %}
      </button>
    </li>
  {% endif %}
{%- endmacro %}

{% macro dropdown_header(label) -%}
  {% if not label | trim %}{{ fail("Dropdown header label is required") }}{% endif %}
  <li><h6 class="dropdown-header">{{ label }}</h6></li>
{%- endmacro %}

{% macro dropdown_divider(extra_class="") -%}
  <li><hr class="dropdown-divider{% if extra_class %} {{ extra_class }}{% endif %}"></li>
{%- endmacro %}
