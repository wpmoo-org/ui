{% from "components/button.html.jinja" import button %}

{% set dropdown_alignments = ["", "start", "end"] %}

{% macro dropdown(label, variant="outline", align="", extra_class="") -%}
  {% if align not in dropdown_alignments %}{{ fail("Unknown dropdown alignment: " ~ align) }}{% endif %}
  {% set items %}{{ caller() | trim | safe }}{% endset %}
  <div class="dropdown{% if extra_class %} {{ extra_class }}{% endif %}">
    {{ button(label, variant=variant, dropdown=true) }}
    {% call dropdown_menu(align=align) %}{{ items | safe }}{% endcall %}
  </div>
{%- endmacro %}

{% macro dropdown_menu(align="") -%}
  {% if align not in dropdown_alignments %}{{ fail("Unknown dropdown alignment: " ~ align) }}{% endif %}
  <ul class="dropdown-menu{% if align %} dropdown-menu-{{ align }}{% endif %}">
    {{ caller() | trim | safe }}
  </ul>
{%- endmacro %}

{% macro dropdown_item(label, href="", icon="", active=false, disabled=false, destructive=false) -%}
  {% if not label | trim %}{{ fail("Dropdown item label is required") }}{% endif %}
  {% set classes = "dropdown-item" %}
  {% if active %}{% set classes = classes ~ " active" %}{% endif %}
  {% if destructive %}{% set classes = classes ~ " text-danger" %}{% endif %}
  {% if href %}
    <li>
      <a class="{{ classes }}{% if disabled %} disabled{% endif %}" href="{{ href }}"{% if disabled %} aria-disabled="true" tabindex="-1"{% endif %}{% if active %} aria-current="true"{% endif %}>
        {% if icon %}{{ lucide_icon(icon, "inline-start") }}{% endif %}
        {{ label }}
      </a>
    </li>
  {% else %}
    <li>
      <button class="{{ classes }}" type="button"{% if disabled %} disabled{% endif %}>
        {% if icon %}{{ lucide_icon(icon, "inline-start") }}{% endif %}
        {{ label }}
      </button>
    </li>
  {% endif %}
{%- endmacro %}

{% macro dropdown_header(label) -%}
  {% if not label | trim %}{{ fail("Dropdown header label is required") }}{% endif %}
  <li><h6 class="dropdown-header">{{ label }}</h6></li>
{%- endmacro %}

{% macro dropdown_divider() -%}
  <li><hr class="dropdown-divider"></li>
{%- endmacro %}
