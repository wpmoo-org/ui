{% macro render_api_reference(id, description, rows) %}
  <section class="moo-component-reference" aria-labelledby="{{ id }}-reference-title">
    <h2 class="h3" id="{{ id }}-reference-title">API Reference</h2>
    <p class="text-body-secondary">{{ description }}</p>
    <div class="table-responsive">
      <table class="table align-middle">
        <thead>
          <tr>
            <th scope="col">Public contract</th>
            <th scope="col">Use</th>
            <th scope="col">Behavior</th>
          </tr>
        </thead>
        <tbody>
          {% for row in rows %}
            <tr>
              <th scope="row"><code>{{ row.contract }}</code></th>
              <td>{{ row.use }}</td>
              <td>{{ row.behavior }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
{% endmacro %}
