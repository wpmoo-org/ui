{% set input_group_dirs = ["", "ltr", "rtl"] %}

{% macro input_group(extra_class="", dir="") -%}
  {% if dir not in input_group_dirs %}{{ fail("Unknown input group direction: " ~ dir) }}{% endif %}
  <div class="input-group{% if extra_class %} {{ extra_class }}{% endif %}"{% if dir %} dir="{{ dir }}"{% endif %}>
    {{ caller() | trim | safe }}
  </div>
{%- endmacro %}

{% macro input_group_text(content, id="", extra_class="", for_id="") -%}
  {% if not content | trim %}{{ fail("Input group text content is required") }}{% endif %}
  {% set tag = "label" if for_id | trim else "span" %}
  <{{ tag }} class="input-group-text{% if extra_class %} {{ extra_class }}{% endif %}"{% if id %} id="{{ id }}"{% endif %}{% if for_id | trim %} for="{{ for_id | trim }}"{% endif %}>{{ content | trim | safe }}</{{ tag }}>
{%- endmacro %}

{% macro input_group_block_addon(align, extra_class="") -%}
  {% if align not in ["start", "end"] %}{{ fail("Unknown input group block addon alignment: " ~ align) }}{% endif %}
  <div{% if extra_class %} class="{{ extra_class }}"{% endif %} data-align="block-{{ align }}">
    {{ caller() | trim | safe }}
  </div>
{%- endmacro %}
