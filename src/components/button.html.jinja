{% set button_variants = {
  "default": "btn-primary",
  "secondary": "btn-secondary",
  "outline": "btn-outline-secondary",
  "ghost": "btn-ghost",
  "destructive": "btn-danger",
  "link": "btn-link",
  "success": "btn-success",
  "warning": "btn-warning",
  "info": "btn-info",
  "light": "btn-light",
  "dark": "btn-dark",
  "outline-primary": "btn-outline-primary",
  "outline-success": "btn-outline-success",
  "outline-danger": "btn-outline-danger"
} %}

{% set button_sizes = {
  "default": {"class": "", "dimensions": "32px"},
  "xs": {"class": "btn-xs", "dimensions": "24px"},
  "sm": {"class": "btn-sm", "dimensions": "28px"},
  "lg": {"class": "btn-lg", "dimensions": "36px"},
  "icon": {"class": "btn-icon", "dimensions": "32×32px"},
  "icon-xs": {"class": "btn-icon-xs", "dimensions": "24×24px"},
  "icon-sm": {"class": "btn-icon-sm", "dimensions": "28×28px"},
  "icon-lg": {"class": "btn-icon-lg", "dimensions": "36×36px"}
} %}

{% macro icon(name, position) -%}
  <svg
    data-icon="{{ position }}"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    {% if name == "plus" %}
      <path d="M12 5v14M5 12h14"/>
    {% elif name == "arrow-right" %}
      <path d="M5 12h14M14 7l5 5-5 5"/>
    {% elif name == "pin" %}
      <path d="M8 3h8l-1 6 3 3v2H6v-2l3-3-1-6M12 14v7"/>
    {% endif %}
  </svg>
{%- endmacro %}

{% macro button(
  label,
  variant="default",
  size="default",
  element="button",
  type="button",
  href="",
  disabled=false,
  aria_label="",
  icon_start="",
  icon_end="",
  extra_class="",
  toggle=false
) -%}
  {% set variant_class = button_variants.get(variant, button_variants["default"]) %}
  {% set size_config = button_sizes.get(size, button_sizes["default"]) %}
  {% set size_class = size_config["class"] %}
  {% set classes = "btn " ~ variant_class %}
  {% if size_class %}{% set classes = classes ~ " " ~ size_class %}{% endif %}
  {% if extra_class %}{% set classes = classes ~ " " ~ extra_class %}{% endif %}

  {% if element == "a" %}
    <a class="{{ classes }}"{% if not disabled %} href="{{ href }}"{% else %} aria-disabled="true" tabindex="-1"{% endif %}{% if aria_label %} aria-label="{{ aria_label }}"{% endif %}>
      {% if icon_start %}{{ icon(icon_start, "inline-start") }}{% endif %}
      {{ label }}
      {% if icon_end %}{{ icon(icon_end, "inline-end") }}{% endif %}
    </a>
  {% elif element == "input" %}
    <input class="{{ classes }}" type="{{ type }}" value="{{ label }}"{% if disabled %} disabled{% endif %}{% if aria_label %} aria-label="{{ aria_label }}"{% endif %}>
  {% else %}
    <button class="{{ classes }}" type="{{ type }}"{% if disabled %} disabled{% endif %}{% if aria_label %} aria-label="{{ aria_label }}"{% endif %}{% if toggle %} data-bs-toggle="button" aria-pressed="false"{% endif %}>
      {% if icon_start %}{{ icon(icon_start, "inline-start") }}{% endif %}
      {{ label }}
      {% if icon_end %}{{ icon(icon_end, "inline-end") }}{% endif %}
    </button>
  {% endif %}
{%- endmacro %}
