{% set button_variants = {
  "default": "btn-primary",
  "secondary": "btn-secondary",
  "outline": "btn-outline-secondary",
  "ghost": "btn-ghost",
  "destructive": "btn-danger",
  "link": "btn-link",
  "success": "btn-success",
  "warning": "btn-warning",
  "info": "btn-info",
  "light": "btn-light",
  "dark": "btn-dark",
  "outline-primary": "btn-outline-primary",
  "outline-success": "btn-outline-success",
  "outline-danger": "btn-outline-danger"
} %}

{% set button_sizes = {
  "default": {"class": "", "dimensions": "32px"},
  "xs": {"class": "btn-xs", "dimensions": "24px"},
  "sm": {"class": "btn-sm", "dimensions": "28px"},
  "lg": {"class": "btn-lg", "dimensions": "36px"},
  "icon": {"class": "btn-icon", "dimensions": "32×32px"},
  "icon-xs": {"class": "btn-icon-xs", "dimensions": "24×24px"},
  "icon-sm": {"class": "btn-icon-sm", "dimensions": "28×28px"},
  "icon-lg": {"class": "btn-icon-lg", "dimensions": "36×36px"}
} %}

{% set button_elements = ["button", "input", "a"] %}

{% set button_types = ["button", "submit", "reset"] %}

{% set button_tooltip_placements = ["top", "right", "bottom", "left"] %}

{% set button_popover_placements = ["top", "right", "bottom", "left"] %}

{% set button_dismiss_targets = ["modal", "offcanvas", "toast"] %}

{% macro icon(name, position) -%}
  {{ render_icon(name, position) }}
{%- endmacro %}

{% macro button(
  label,
  variant="default",
  size="default",
  element="button",
  type="button",
  href="",
  disabled=false,
  aria_label="",
  icon_start="",
  icon_end="",
  extra_class="",
  toggle=false,
  dropdown=false,
  dropdown_offset="",
  dropdown_caret=false,
  loading=false,
  collapse_target="",
  collapse_open=false,
  tooltip="",
  tooltip_placement="top",
  tooltip_html=false,
  popover_content="",
  popover_title="",
  popover_placement="top",
  popover_html=false,
  dialog_target="",
  dismiss="",
  toast_target="",
  sheet_target=""
) -%}
  {% if variant not in button_variants %}{{ fail("Unknown button variant: " ~ variant) }}{% endif %}
  {% if size not in button_sizes %}{{ fail("Unknown button size: " ~ size) }}{% endif %}
  {% if element not in button_elements %}{{ fail("Unknown button element: " ~ element) }}{% endif %}
  {% if type not in button_types %}{{ fail("Unknown button type: " ~ type) }}{% endif %}
  {% if element != "button" and (toggle or dropdown or dropdown_offset or dropdown_caret or loading or collapse_target) %}{{ fail("Button dropdown, toggle, loading, and collapse_target options require element=button") }}{% endif %}
  {% if toggle and dropdown %}{{ fail("Button cannot be both toggle and dropdown") }}{% endif %}
  {% if dropdown_caret and not dropdown %}{{ fail("Button dropdown_caret requires dropdown=true") }}{% endif %}
  {% if dropdown_offset and not dropdown %}{{ fail("Button dropdown_offset requires dropdown=true") }}{% endif %}
  {% if loading and icon_start %}{{ fail("Button loading replaces icon_start; do not set both") }}{% endif %}
  {% if collapse_target and (toggle or dropdown) %}{{ fail("Button collapse_target cannot combine with toggle or dropdown") }}{% endif %}
  {% if collapse_open and not collapse_target %}{{ fail("Button collapse_open requires collapse_target") }}{% endif %}
  {% if not label | trim and not aria_label | trim %}{{ fail("Buttons without a visible label require aria_label") }}{% endif %}
  {% if tooltip_placement not in button_tooltip_placements %}{{ fail("Unknown button tooltip placement: " ~ tooltip_placement) }}{% endif %}
  {% if tooltip and element not in ("button", "a") %}{{ fail("Button tooltip requires element=button or element=a") }}{% endif %}
  {% if tooltip and (toggle or dropdown or collapse_target) %}{{ fail("Button tooltip cannot combine with toggle, dropdown, or collapse_target; a Bootstrap element holds only one plugin instance") }}{% endif %}
  {% if tooltip_html and not tooltip %}{{ fail("Button tooltip_html requires tooltip") }}{% endif %}
  {% if popover_placement not in button_popover_placements %}{{ fail("Unknown button popover placement: " ~ popover_placement) }}{% endif %}
  {% if popover_content and element not in ("button", "a") %}{{ fail("Button popover_content requires element=button or element=a") }}{% endif %}
  {% if popover_content and (toggle or dropdown or collapse_target or tooltip) %}{{ fail("Button popover_content cannot combine with toggle, dropdown, collapse_target, or tooltip; a Bootstrap element holds only one plugin instance") }}{% endif %}
  {% if popover_html and not popover_content %}{{ fail("Button popover_html requires popover_content") }}{% endif %}
  {% if popover_title and not popover_content %}{{ fail("Button popover_title requires popover_content") }}{% endif %}
  {% if dialog_target and element not in ("button", "a") %}{{ fail("Button dialog_target requires element=button or element=a") }}{% endif %}
  {% if dialog_target and (toggle or dropdown or collapse_target or tooltip or popover_content) %}{{ fail("Button dialog_target cannot combine with toggle, dropdown, collapse_target, tooltip, or popover_content; an element carries only one data-bs-toggle value") }}{% endif %}
  {% if dismiss and dismiss not in button_dismiss_targets %}{{ fail("Unknown button dismiss target: " ~ dismiss) }}{% endif %}
  {% if toast_target and element not in ("button", "a") %}{{ fail("Button toast_target requires element=button or element=a") }}{% endif %}
  {% if sheet_target and element not in ("button", "a") %}{{ fail("Button sheet_target requires element=button or element=a") }}{% endif %}
  {% if sheet_target and (toggle or dropdown or collapse_target or tooltip or popover_content or dialog_target) %}{{ fail("Button sheet_target cannot combine with toggle, dropdown, collapse_target, tooltip, popover_content, or dialog_target; an element carries only one data-bs-toggle value") }}{% endif %}
  {% set variant_class = button_variants[variant] %}
  {% set size_config = button_sizes[size] %}
  {% set size_class = size_config["class"] %}
  {% set classes = "btn " ~ variant_class %}
  {% if size_class %}{% set classes = classes ~ " " ~ size_class %}{% endif %}
  {% if dropdown_caret %}{% set classes = classes ~ " dropdown-toggle" %}{% endif %}
  {% if element == "a" and disabled %}{% set classes = classes ~ " disabled" %}{% endif %}
  {% if extra_class %}{% set classes = classes ~ " " ~ extra_class %}{% endif %}

  {% if element == "a" %}
    <a class="{{ classes }}" role="button"{% if not disabled %} href="{{ href }}"{% else %} aria-disabled="true" tabindex="-1"{% endif %}{% if aria_label %} aria-label="{{ aria_label }}"{% endif %}{% if tooltip %} data-bs-toggle="tooltip" data-bs-title="{{ tooltip | safe if tooltip_html else tooltip }}" data-bs-placement="{{ tooltip_placement }}"{% if tooltip_html %} data-bs-html="true"{% endif %}{% endif %}{% if popover_content %} data-bs-toggle="popover"{% if popover_title %} data-bs-title="{{ popover_title | safe if popover_html else popover_title }}"{% endif %} data-bs-content="{{ popover_content | safe if popover_html else popover_content }}" data-bs-placement="{{ popover_placement }}"{% if popover_html %} data-bs-html="true"{% endif %}{% endif %}{% if dialog_target %} data-bs-toggle="modal" data-bs-target="#{{ dialog_target }}"{% endif %}{% if sheet_target %} data-bs-toggle="offcanvas" data-bs-target="#{{ sheet_target }}"{% endif %}{% if dismiss %} data-bs-dismiss="{{ dismiss }}"{% endif %}{% if toast_target %} data-moo-toast-target="#{{ toast_target }}"{% endif %}>
      {% if icon_start %}{{ icon(icon_start, "inline-start") }}{% endif %}
      {{ label }}
      {% if icon_end %}{{ icon(icon_end, "inline-end") }}{% endif %}
    </a>
  {% elif element == "input" %}
    <input class="{{ classes }}" type="{{ type }}" value="{{ label }}"{% if disabled %} disabled{% endif %}{% if aria_label %} aria-label="{{ aria_label }}"{% endif %}>
  {% else %}
    <button class="{{ classes }}" type="{{ type }}"{% if disabled %} disabled{% endif %}{% if aria_label %} aria-label="{{ aria_label }}"{% endif %}{% if toggle %} data-bs-toggle="button" aria-pressed="false"{% endif %}{% if dropdown %} data-bs-toggle="dropdown" aria-expanded="false"{% if dropdown_offset %} data-bs-offset="{{ dropdown_offset }}"{% endif %}{% endif %}{% if collapse_target %} data-bs-toggle="collapse" data-bs-target="#{{ collapse_target }}" aria-expanded="{{ "true" if collapse_open else "false" }}" aria-controls="{{ collapse_target }}"{% endif %}{% if tooltip %} data-bs-toggle="tooltip" data-bs-title="{{ tooltip | safe if tooltip_html else tooltip }}" data-bs-placement="{{ tooltip_placement }}"{% if tooltip_html %} data-bs-html="true"{% endif %}{% endif %}{% if popover_content %} data-bs-toggle="popover"{% if popover_title %} data-bs-title="{{ popover_title | safe if popover_html else popover_title }}"{% endif %} data-bs-content="{{ popover_content | safe if popover_html else popover_content }}" data-bs-placement="{{ popover_placement }}"{% if popover_html %} data-bs-html="true"{% endif %}{% endif %}{% if dialog_target %} data-bs-toggle="modal" data-bs-target="#{{ dialog_target }}"{% endif %}{% if sheet_target %} data-bs-toggle="offcanvas" data-bs-target="#{{ sheet_target }}"{% endif %}{% if dismiss %} data-bs-dismiss="{{ dismiss }}"{% endif %}{% if toast_target %} data-moo-toast-target="#{{ toast_target }}"{% endif %}{% if loading %} aria-busy="true"{% endif %}>
      {% if loading %}{{ icon("loader-circle", "inline-start") }}{% elif icon_start %}{{ icon(icon_start, "inline-start") }}{% endif %}
      {{ label }}
      {% if icon_end %}{{ icon(icon_end, "inline-end") }}{% endif %}
    </button>
  {% endif %}
{%- endmacro %}
