{% set popover_placements = ["top", "right", "bottom", "left"] %}

{# Bootstrap requires an <a>, not a <button>, for the focus-triggered
   "dismiss on next click" pattern to behave consistently across browsers,
   so this is a dedicated trigger rather than another button() option.
   The default href is "#!", not "#": an empty fragment is the one browsers
   special-case to scroll to the very top of the document on click, which
   Bootstrap's popover JS never prevents; "#!" matches nothing, so nothing
   scrolls, while the element stays a real, always-focusable anchor. #}
{% macro popover_dismiss_trigger(
  label,
  content,
  title="",
  placement="top",
  html=false,
  href="#!",
  extra_class=""
) -%}
  {% if not label | trim %}{{ fail("Popover trigger label is required") }}{% endif %}
  {% if not content | trim %}{{ fail("Popover content is required") }}{% endif %}
  {% if placement not in popover_placements %}{{ fail("Unknown popover placement: " ~ placement) }}{% endif %}
  <a
    href="{{ href }}"
    role="button"
    tabindex="0"
    class="btn btn-outline-secondary{% if extra_class %} {{ extra_class }}{% endif %}"
    data-bs-toggle="popover"
    data-bs-trigger="focus"
    data-bs-placement="{{ placement }}"
    {% if title %}data-bs-title="{{ title }}"{% endif %}
    data-bs-content="{{ content }}"
    {% if html %}data-bs-html="true"{% endif %}
  >{{ label }}</a>
{%- endmacro %}
