{# Field is composition scaffolding around the already-ready Input, Textarea,
   Select, Checkbox, Radio Group, and Switch macros -- it owns no input
   control of its own. It mirrors shadcn's own Field/FieldGroup/FieldSet
   component (a distinct page from shadcn's "Forms" guide, which is just
   React Hook Form/Zod wiring and has no portable static markup of its own),
   built on Bootstrap's native fieldset/legend markup and its existing
   client-side validation pseudo-classes (:invalid/:valid,
   .is-invalid/.is-valid, .was-validated), never a Moo-owned validation
   engine. form() is the one exception to the "field" naming: it renders a
   literal <form> element, a real HTML concept rather than a Field synonym. #}

{% macro form(extra_class="", novalidate=false) -%}
  <form{% if extra_class %} class="{{ extra_class }}"{% endif %}{% if novalidate %} novalidate{% endif %}>
    {{ caller() | trim | safe }}
  </form>
{%- endmacro %}

{% macro field(extra_class="") -%}
  <div class="field{% if extra_class %} {{ extra_class }}{% endif %}">
    {{ caller() | trim | safe }}
  </div>
{%- endmacro %}

{% macro field_description(id, text) -%}
  {% if not id | trim %}{{ fail("Field description id is required") }}{% endif %}
  {% if not text | trim %}{{ fail("Field description text is required") }}{% endif %}
  <div class="form-text" id="{{ id }}">{{ text }}</div>
{%- endmacro %}

{% macro field_error(id, text) -%}
  {% if not id | trim %}{{ fail("Field error id is required") }}{% endif %}
  {% if not text | trim %}{{ fail("Field error text is required") }}{% endif %}
  <div class="invalid-feedback" id="{{ id }}">{{ text }}</div>
{%- endmacro %}

{% macro field_group(extra_class="") -%}
  <div class="field-group{% if extra_class %} {{ extra_class }}{% endif %}">
    {{ caller() | trim | safe }}
  </div>
{%- endmacro %}

{% macro fieldset(legend, description="", extra_class="") -%}
  {% if not legend | trim %}{{ fail("Fieldset legend is required") }}{% endif %}
  <fieldset class="field-fieldset{% if extra_class %} {{ extra_class }}{% endif %}">
    <legend class="form-label">{{ legend }}</legend>
    {% if description %}<div class="form-text mb-2">{{ description }}</div>{% endif %}
    {{ caller() | trim | safe }}
  </fieldset>
{%- endmacro %}
