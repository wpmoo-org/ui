{% from "components/badge.html.jinja" import badge %}

{% set nav_styles = {
  "base": "nav",
  "pills": "nav nav-pills",
  "underline": "nav nav-underline"
} %}

{% set nav_directions = ["", "ltr", "rtl"] %}

{% macro nav_menu(aria_label, style="pills", vertical=false, extra_class="", dir="") -%}
  {% if not aria_label | trim %}{{ fail("Navigation aria_label is required") }}{% endif %}
  {% if style not in nav_styles %}{{ fail("Unknown navigation style: " ~ style) }}{% endif %}
  {% if dir not in nav_directions %}{{ fail("Unknown navigation direction: " ~ dir) }}{% endif %}
  {% set classes = nav_styles[style] %}
  {% if vertical %}{% set classes = classes ~ " flex-column gap-1" %}{% endif %}
  {% if extra_class %}{% set classes = classes ~ " " ~ extra_class %}{% endif %}
  <nav aria-label="{{ aria_label }}"{% if dir %} dir="{{ dir }}"{% endif %}>
    <ul class="{{ classes }}">
      {{ caller() | trim | safe }}
    </ul>
  </nav>
{%- endmacro %}

{% macro nav_item(label, href="#", active=false, disabled=false, icon="", end_icon="", badge_label="", badge_variant="secondary") -%}
  {% if not label | trim %}{{ fail("Navigation item label is required") }}{% endif %}
  {% set classes = "nav-link" %}
  {% if active %}{% set classes = classes ~ " active" %}{% endif %}
  {% if disabled %}{% set classes = classes ~ " disabled" %}{% endif %}
  <li class="nav-item">
    <a class="{{ classes }}"{% if not disabled %} href="{{ href }}"{% else %} aria-disabled="true" tabindex="-1"{% endif %}{% if active %} aria-current="page"{% endif %}>
      {% if icon %}{{ render_icon(icon, "inline-start") }}{% endif %}
      <span>{{ label }}</span>
      {% if badge_label %}{{ badge(badge_label, variant=badge_variant, pill=true, extra_class="ms-auto") }}{% endif %}
      {% if end_icon %}<span class="ms-auto">{{ render_icon(end_icon, "inline-end") }}</span>{% endif %}
    </a>
  </li>
{%- endmacro %}
