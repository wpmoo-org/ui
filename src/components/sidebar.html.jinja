{# Moo UI Sidebar: a composable app-shell primitive.

   Bootstrap has no native sidebar component, so this family owns the public
   `.sidebar*` selector namespace (same precedent as `.avatar`). The macros
   mirror shadcn's composable sidebar API so an app shell is rearranged by
   editing markup rather than rewriting CSS. Behavior (collapse-to-icon rail,
   mobile offcanvas, sub-menu disclosure) layers on in later phases using
   native Bootstrap plugins. #}

{% set sidebar_sides = ["left", "right"] %}
{% set sidebar_variants = ["sidebar", "floating", "inset"] %}
{% set sidebar_collapsible = ["icon", "offcanvas", "none"] %}
{% set sidebar_button_sizes = ["default", "lg"] %}

{% from "components/dropdown_menu.html.jinja" import dropdown_menu %}
{% from "components/badge.html.jinja" import badge %}
{% from "components/button.html.jinja" import button %}
{% from "components/input.html.jinja" import input %}
{% from "components/separator.html.jinja" import separator %}
{% from "components/skeleton.html.jinja" import skeleton %}

{% macro sidebar_provider(default_open=true, contained=false, key="", extra_class="") -%}
  {% set classes = "sidebar-wrapper" %}
  {% if contained %}{% set classes = classes ~ " sidebar-wrapper--contained" %}{% endif %}
  {% if extra_class %}{% set classes = classes ~ " " ~ extra_class %}{% endif %}
  <div
    class="{{ classes }}"
    data-slot="sidebar-wrapper"
    data-moo-sidebar-state="{{ 'expanded' if default_open else 'collapsed' }}"
    {% if key %}data-moo-sidebar-key="{{ key }}"{% endif %}
  >
    {{ caller() | trim | safe }}
  </div>
{%- endmacro %}

{% macro sidebar(
  side="left",
  variant="sidebar",
  collapsible="icon",
  rail=true,
  id="catalog-sidebar",
  aria_label="Sidebar",
  aria_labelled_by="",
  extra_class=""
) -%}
  {% if side not in sidebar_sides %}{{ fail("Unknown sidebar side: " ~ side) }}{% endif %}
  {% if variant not in sidebar_variants %}{{ fail("Unknown sidebar variant: " ~ variant) }}{% endif %}
  {% if collapsible not in sidebar_collapsible %}{{ fail("Unknown sidebar collapsible mode: " ~ collapsible) }}{% endif %}
  {% if not id | trim %}{{ fail("Sidebar id is required") }}{% endif %}
  {% set classes = "sidebar" %}
  {% set side_class = "offcanvas-end" if side == "right" else "offcanvas-start" %}
  {% if extra_class %}{% set classes = classes ~ " " ~ extra_class %}{% endif %}
  {% set classes = classes ~ " offcanvas-lg " ~ side_class %}
  <aside
    id="{{ id }}"
    class="{{ classes }}"
    tabindex="-1"
    data-slot="sidebar"
    aria-label="{{ aria_label }}"
    {% if aria_labelled_by %}aria-labelledby="{{ aria_labelled_by }}"{% endif %}
    data-side="{{ side }}"
    data-variant="{{ variant }}"
    data-collapsible="{{ collapsible }}"
  >
    <div class="sidebar-inner" data-slot="sidebar-inner">
      {{ caller() | trim | safe }}
    </div>
    {% if rail and collapsible != "none" %}{{ sidebar_rail() }}{% endif %}
  </aside>
{%- endmacro %}

{% macro sidebar_trigger(
  aria_label="Toggle sidebar",
  extra_class="",
  sidebar_id="catalog-sidebar",
  expanded=true
) -%}
  {% if not sidebar_id | trim %}{{ fail("Sidebar trigger target id is required") }}{% endif %}
  <button
    class="btn btn-ghost btn-icon-sm sidebar-trigger{% if extra_class %} {{ extra_class }}{% endif %}"
    type="button"
    data-moo-sidebar-trigger
    data-bs-target="#{{ sidebar_id }}"
    aria-label="{{ aria_label }}"
    aria-controls="{{ sidebar_id }}"
    aria-expanded="{{ "true" if expanded else "false" }}"
  >
    {{ render_icon("panel-left", "inline-start") }}
  </button>
{%- endmacro %}

{% macro sidebar_rail(aria_label="Toggle sidebar") -%}
  <button
    class="sidebar-rail"
    type="button"
    data-moo-sidebar-rail
    aria-label="{{ aria_label }}"
    tabindex="-1"
  ></button>
{%- endmacro %}

{% macro sidebar_header(extra_class="") -%}
  <div class="sidebar-header{% if extra_class %} {{ extra_class }}{% endif %}" data-slot="sidebar-header">
    {{ caller() | trim | safe }}
  </div>
{%- endmacro %}

{% macro sidebar_content(extra_class="") -%}
  <div class="sidebar-content scroll-fade-y no-scrollbar{% if extra_class %} {{ extra_class }}{% endif %}" data-slot="sidebar-content">
    {{ caller() | trim | safe }}
  </div>
{%- endmacro %}

{% macro sidebar_input(id="", placeholder="", aria_label="Search", extra_class="") -%}
  {% set classes = "sidebar-input" %}
  {% if extra_class %}{% set classes = classes ~ " " ~ extra_class %}{% endif %}
  <div class="{{ classes }}" data-slot="sidebar-input">
    {{ input(id=id, aria_label=aria_label, placeholder=placeholder) }}
  </div>
{%- endmacro %}

{% macro sidebar_separator(extra_class="") -%}
  <div class="sidebar-separator{% if extra_class %} {{ extra_class }}{% endif %}" data-slot="sidebar-separator">
    {{ separator() }}
  </div>
{%- endmacro %}

{% macro sidebar_footer(extra_class="") -%}
  <div class="sidebar-footer{% if extra_class %} {{ extra_class }}{% endif %}" data-slot="sidebar-footer">
    {{ caller() | trim | safe }}
  </div>
{%- endmacro %}

{% macro sidebar_group(extra_class="") -%}
  <div class="sidebar-group{% if extra_class %} {{ extra_class }}{% endif %}" data-slot="sidebar-group">
    {{ caller() | trim | safe }}
  </div>
{%- endmacro %}

{% macro sidebar_group_label(label) -%}
  {% if not label | trim %}{{ fail("Sidebar group label is required") }}{% endif %}
  <div class="sidebar-group-label" data-slot="sidebar-group-label">{{ label }}</div>
{%- endmacro %}

{% macro sidebar_group_content(extra_class="") -%}
  <div class="sidebar-group-content{% if extra_class %} {{ extra_class }}{% endif %}" data-slot="sidebar-group-content">
    {{ caller() | trim | safe }}
  </div>
{%- endmacro %}

{% macro sidebar_menu(extra_class="") -%}
  <ul class="sidebar-menu{% if extra_class %} {{ extra_class }}{% endif %}" data-slot="sidebar-menu">
    {{ caller() | trim | safe }}
  </ul>
{%- endmacro %}

{% macro sidebar_group_action(icon="plus", aria_label="", extra_class="") -%}
  {% if not aria_label | trim %}{{ fail("Sidebar group action aria-label is required") }}{% endif %}
  {% if not icon | trim %}{{ fail("Sidebar group action icon is required") }}{% endif %}
  <span class="sidebar-group-action{% if extra_class %} {{ extra_class }}{% endif %}" data-slot="sidebar-group-action">
    {{ button(
      "",
      variant="ghost",
      size="icon-xs",
      aria_label=aria_label,
      icon_start=icon,
      extra_class=""
    ) }}
  </span>
{%- endmacro %}

{% macro sidebar_menu_item(dropdown=false, extra_class="") -%}
  {% set classes = "sidebar-menu-item" %}
  {% if dropdown %}{% set classes = classes ~ " dropdown" %}{% endif %}
  {% if extra_class %}{% set classes = classes ~ " " ~ extra_class %}{% endif %}
  <li class="{{ classes }}" data-slot="sidebar-menu-item">
    {{ caller() | trim | safe }}
  </li>
{%- endmacro %}

{% macro _sidebar_button_body(title, subtitle, icon, lead, end_icon) -%}
  {% if lead %}
    <span class="sidebar-menu-button__lead" aria-hidden="true">{{ lead | safe }}</span>
  {% elif icon %}
    <span class="sidebar-menu-button__lead" aria-hidden="true">{{ render_icon(icon, "inline-start") }}</span>
  {% endif %}
  <span class="sidebar-menu-button__text">
    <span class="sidebar-menu-button__title">{{ title }}</span>
    {% if subtitle %}<span class="sidebar-menu-button__subtitle">{{ subtitle }}</span>{% endif %}
  </span>
  {% if end_icon %}<span class="sidebar-menu-button__end" aria-hidden="true">{{ render_icon(end_icon, "inline-end") }}</span>{% endif %}
{%- endmacro %}

{% macro sidebar_menu_button(
  title,
  subtitle="",
  href="#",
  icon="",
  lead="",
  end_icon="",
  active=false,
  size="default",
  tooltip="",
  element="a",
  dropdown=false,
  collapse_target="",
  collapse_open=false,
  aria_label="",
  extra_class="",
  static=false
) -%}
  {% if not title | trim %}{{ fail("Sidebar menu button title is required") }}{% endif %}
  {% if size not in sidebar_button_sizes %}{{ fail("Unknown sidebar menu button size: " ~ size) }}{% endif %}
  {% set classes = "sidebar-menu-button" %}
  {% if size != "default" %}{% set classes = classes ~ " sidebar-menu-button--" ~ size %}{% endif %}
  {% if active %}{% set classes = classes ~ " active" %}{% endif %}
  {% if collapse_target %}{% set classes = classes ~ " sidebar-menu-button--disclosure" %}{% endif %}
  {% if static %}{% set classes = classes ~ " sidebar-menu-button--static" %}{% endif %}
  {% if extra_class %}{% set classes = classes ~ " " ~ extra_class %}{% endif %}
  {% set body = _sidebar_button_body(title, subtitle, icon, lead, end_icon) %}
  {# The collapsed icon rail reveals this label as a tooltip; default it to the
     visible title so every menu button stays legible when text is hidden. #}
  {% set tip = tooltip if tooltip else title %}
  {% if static %}
    <div class="{{ classes }}" data-slot="sidebar-menu-button" data-moo-sidebar-tooltip="{{ tip }}">
      {{ body }}
    </div>
  {% elif dropdown or collapse_target or element == "button" %}
    <button
      class="{{ classes }}"
      type="button"
      data-slot="sidebar-menu-button"
      {% if dropdown %}data-bs-toggle="dropdown" aria-expanded="false"{% endif %}
      {% if collapse_target %}data-bs-toggle="collapse" data-bs-target="#{{ collapse_target }}" aria-expanded="{{ "true" if collapse_open else "false" }}" aria-controls="{{ collapse_target }}"{% endif %}
      data-moo-sidebar-tooltip="{{ tip }}"
      {% if aria_label %} aria-label="{{ aria_label }}"{% endif %}
    >
      {{ body }}
    </button>
  {% else %}
    <a
      class="{{ classes }}"
      href="{{ href }}"
      data-slot="sidebar-menu-button"
      {% if active %} aria-current="page"{% endif %}
      data-moo-sidebar-tooltip="{{ tip }}"
      {% if aria_label %} aria-label="{{ aria_label }}"{% endif %}
    >
      {{ body }}
    </a>
  {% endif %}
{%- endmacro %}

{% macro sidebar_menu_sub(id, open=false, extra_class="") -%}
  {% if not id | trim %}{{ fail("Sidebar submenu id is required") }}{% endif %}
  <ul
    id="{{ id }}"
    class="sidebar-menu-sub collapse{% if open %} show{% endif %}{% if extra_class %} {{ extra_class }}{% endif %}"
    data-slot="sidebar-menu-sub"
  >
    {{ caller() | trim | safe }}
  </ul>
{%- endmacro %}

{% macro sidebar_menu_sub_item(extra_class="") -%}
  <li class="sidebar-menu-sub-item{% if extra_class %} {{ extra_class }}{% endif %}" data-slot="sidebar-menu-sub-item">
    {{ caller() | trim | safe }}
  </li>
{%- endmacro %}

{% macro sidebar_menu_sub_button(
  title,
  submenu_id,
  href="#",
  icon="",
  active=false,
  open=false,
  tooltip="",
  extra_class=""
) -%}
  {% if not submenu_id | trim %}{{ fail("Sidebar submenu target id is required") }}{% endif %}
  {{ sidebar_menu_button(
    title,
    href=href,
    icon=icon,
    active=active,
    element="button",
    collapse_target=submenu_id,
    collapse_open=open,
    end_icon="chevron-right",
    tooltip=tooltip,
    extra_class="sidebar-menu-sub-trigger" ~ (" " ~ extra_class if extra_class else "")
  ) }}
{%- endmacro %}

{% macro sidebar_menu_action(icon="ellipsis", aria_label="More actions", align="end", extra_class="") -%}
  {% if not aria_label | trim %}{{ fail("Sidebar menu action aria-label is required") }}{% endif %}
  {% set items %}{{ caller() | trim | safe }}{% endset %}
  <div class="sidebar-menu-action dropdown{% if extra_class %} {{ extra_class }}{% endif %}" data-slot="sidebar-menu-action">
    <button
      class="btn btn-ghost btn-icon-xs"
      type="button"
      data-bs-toggle="dropdown"
      aria-expanded="false"
      aria-label="{{ aria_label }}"
    >
      {{ render_icon(icon, "inline-start") }}
    </button>
    {% call dropdown_menu(align=align) %}{{ items | safe }}{% endcall %}
  </div>
{%- endmacro %}

{% macro sidebar_menu_badge(value, variant="outline", extra_class="") -%}
  {% if not value | trim %}{{ fail("Sidebar menu badge value is required") }}{% endif %}
  <span class="sidebar-menu-badge{% if extra_class %} {{ extra_class }}{% endif %}" data-slot="sidebar-menu-badge">
    {{ badge(value, variant=variant, extra_class="") }}
  </span>
{%- endmacro %}

{% macro sidebar_menu_skeleton(show_icon=false, extra_class="") -%}
  <div class="sidebar-menu-skeleton{% if extra_class %} {{ extra_class }}{% endif %}" data-slot="sidebar-menu-skeleton">
    {% if show_icon %}
      {{ skeleton(width="1rem", height="1rem", extra_class="sidebar-menu-skeleton__icon") }}
    {% endif %}
    {{ skeleton(width="8rem", height="0.875rem", extra_class="sidebar-menu-skeleton__line") }}
  </div>
{%- endmacro %}

{% macro sidebar_brand_mark(icon, variant="primary") -%}
  <span class="sidebar-brand-mark sidebar-brand-mark--{{ variant }}">{{ render_icon(icon, "inline-start") }}</span>
{%- endmacro %}

{% macro sidebar_inset(extra_class="") -%}
  <div class="sidebar-inset{% if extra_class %} {{ extra_class }}{% endif %}" data-slot="sidebar-inset">
    {{ caller() | trim | safe }}
  </div>
{%- endmacro %}
