{% extends "layouts/catalog.html.jinja" %}
{% from "includes/page-header.html.jinja" import render_page_header %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "components/badge.html.jinja" import badge %}
{% from "components/button.html.jinja" import button %}
{% from "components/field.html.jinja" import form, field, field_description, field_group, fieldset %}
{% from "components/input.html.jinja" import input %}
{% from "components/input_group.html.jinja" import input_group, input_group_text %}
{% from "components/select.html.jinja" import select %}

{% block title %}Input — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Input",
    "A native input primitive with Bootstrap form semantics for labeled, helper-aware, and validated fields."
  ) }}

  <div class="moo-component-examples">
    {% set api_key %}
      {% call field() %}
      {{ input(
        label="API Key",
        id="input-api-key",
        placeholder="sk-...",
        describedby="input-api-key-help"
      ) }}
      {{ field_description("input-api-key-help", "Your API key is encrypted and stored securely.") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "api-key",
      "API Key",
      "Use a labeled single input with helper text.",
      api_key,
      "moo-example__preview--narrow"
    ) }}

    {% set basic %}
      {{ input(
        aria_label="Input",
        placeholder="Enter your text"
      ) }}
    {% endset %}
    {{ render_example(
      "basic",
      "Basic",
      "Use standalone bare inputs when surrounding context already provides the label.",
      basic,
      "moo-example__preview--narrow"
    ) }}

    {% set field_single %}
      {% call field() %}
      {{ input(
        label="Email",
        id="input-field-email",
        placeholder="you@example.com",
        describedby="input-field-email-help"
      ) }}
      {{ field_description("input-field-email-help", "We'll only use this to send you updates.") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "field",
      "Field",
      "Wrap a label and input together in a <code>.field</code> container to keep spacing consistent under Bootstrap form semantics.",
      field_single,
      "moo-example__preview--narrow"
    ) }}

    {% set field_grouped %}
      {% call fieldset("Developer profile", description="Shown on the shared team roster.") %}
      {% call field_group() %}
      {% call field() %}
      {{ input(
        label="First name",
        id="input-first-name",
        describedby="input-first-name-help",
        placeholder="Ada"
      ) }}
      {{ field_description("input-first-name-help", "Displayed in activity headers.") }}
      {% endcall %}
      {% call field() %}
      {{ input(
        label="Last name",
        id="input-last-name",
        describedby="input-last-name-help",
        placeholder="Lovelace"
      ) }}
      {{ field_description("input-last-name-help", "Used for routing and search matching.") }}
      {% endcall %}
      {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "group",
      "Field group",
      "Group related fields inside a <code>.field-group</code> to keep rhythm and spacing token-driven.",
      field_grouped,
      "moo-example__preview--narrow"
    ) }}

    {% set readonly %}
      {% call field() %}
      {{ input(
        label="Default region",
        id="input-default-region",
        value="us-east-1",
        readonly=true
      ) }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "readonly",
      "Read-only",
      "Use <code>readonly</code> on a single field to preserve visible context without editing.",
      readonly,
      "moo-example__preview--narrow"
    ) }}

    {% set disabled %}
      {% call field() %}
      {{ input(
        label="Workspace slug",
        id="input-disabled-slug",
        placeholder="acme-corp",
        disabled=true,
        describedby="input-disabled-slug-help"
      ) }}
      {{ field_description("input-disabled-slug-help", "Contact an owner to change the workspace slug.") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "disabled",
      "Disabled",
      "Use <code>disabled</code> on a control-level input to block interaction while keeping it readable.",
      disabled,
      "moo-example__preview--narrow"
    ) }}

    {% set invalid %}
      {% call field() %}
      {{ input(
        label="Coupon Code",
        id="input-invalid",
        placeholder="Enter code",
        aria_invalid=true,
        describedby="input-invalid-help"
      ) }}
      {{ field_description("input-invalid-help", "That coupon code has expired.") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "invalid",
      "Invalid",
      "Use <code>aria-invalid=\"true\"</code> to mark a field as invalid alongside descriptive helper text.",
      invalid,
      "moo-example__preview--narrow"
    ) }}

    {% set file_input %}
      {% call field() %}
      {{ input(
        label="Picture",
        id="input-picture",
        type="file",
        describedby="input-picture-help"
      ) }}
      {{ field_description("input-picture-help", "PNG or JPG up to 5MB.") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "file",
      "File",
      "Use <code>type=\"file\"</code> with helper text.",
      file_input,
      "moo-example__preview--narrow"
    ) }}

    {% set inline %}
      <div class="d-flex gap-2">
        {{ input(
          aria_label="Search",
          type="search",
          placeholder="Search..."
        ) }}
        {{ button("Search") }}
      </div>
    {% endset %}
    {{ render_example(
      "inline",
      "Inline",
      "Place a bare input next to a button in a flex row to create a search input with a button.",
      inline,
      "moo-example__preview--narrow"
    ) }}

    {% set grid %}
      <div class="d-flex flex-wrap gap-3">
        {% call field(extra_class="flex-fill") %}
        {{ input(
          label="City",
          id="input-grid-city",
          placeholder="Amsterdam"
        ) }}
        {% endcall %}
        {% call field(extra_class="flex-fill") %}
        {{ input(
          label="Postal code",
          id="input-grid-postal-code",
          placeholder="1011 AB"
        ) }}
        {% endcall %}
      </div>
    {% endset %}
    {{ render_example(
      "grid",
      "Grid",
      "Use a flex row of <code>.field.flex-fill</code> containers to place multiple inputs side by side.",
      grid,
      "moo-example__preview--narrow"
    ) }}

    {% set input_required %}
      {% call field() %}
      {{ input(
        label="Project name",
        id="input-required",
        placeholder="marketing-site",
        required=true,
        describedby="input-required-help"
      ) }}
      {{ field_description("input-required-help", "Used to generate the deployment URL.") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "required",
      "Required",
      "Use the <code>required</code> attribute to indicate required inputs.",
      input_required,
      "moo-example__preview--narrow"
    ) }}

    {% set input_badge %}
      {% call field() %}
      {{ input(
        label="API endpoint",
        id="input-badge",
        placeholder="https://api.acme.dev/v1/webhook",
        label_extra=badge("Preview", variant="secondary")
      ) }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "badge",
      "Badge",
      "Add a <code>.badge</code> inside the label to highlight a recommended field.",
      input_badge,
      "moo-example__preview--narrow"
    ) }}

    {% set input_group_example %}
      {% call field() %}
      {% call input_group() %}
        {{ input_group_text("https://") }}
        {{ input(aria_label="Website URL", id="input-group-url", placeholder="example.com") }}
      {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "input-group",
      "Input Group",
      "To add icons or text inside an input, wrap it in a Bootstrap <code>.input-group</code>. See the <a href=\"../components/input-group.html\">Input Group</a> component for more examples.",
      input_group_example,
      "moo-example__preview--narrow"
    ) }}

    {% set button_group_example %}
      {% call field() %}
      <label class="form-label" for="input-button-group-search">Search</label>
      {% call input_group() %}
        {{ input(aria_label="Search", id="input-button-group-search", type="search", placeholder="Type to search...") }}
        {{ button("Search", variant="outline") }}
      {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "button-group",
      "Button Group",
      "Use Bootstrap's native <code>.input-group</code> pattern to attach a button to a search input with a shared border. See the <a href=\"../components/button-group.html\">Button Group</a> component for button-only groups.",
      button_group_example,
      "moo-example__preview--narrow"
    ) }}

    {% set full_form %}
      {% call form(extra_class="mx-auto", novalidate=true) %}
      {% call fieldset("Shipping details", description="Used to calculate delivery time and customs fees.") %}
      {% call field_group() %}
      {% call field() %}
      {{ input(
        label="Full name",
        id="input-form-name",
        placeholder="Ada Lovelace",
        required=true
      ) }}
      {% endcall %}
      {% call field() %}
      {{ input(
        label="Email",
        id="input-form-email",
        placeholder="you@example.com",
        describedby="input-form-email-help"
      ) }}
      {{ field_description("input-form-email-help", "Order updates are sent to this address.") }}
      {% endcall %}
      <div class="d-flex flex-wrap gap-3">
        {% call field(extra_class="flex-fill") %}
        {{ input(
          label="Phone",
          id="input-form-phone",
          placeholder="+31 20 123 4567"
        ) }}
        {% endcall %}
        {% call field(extra_class="flex-fill") %}
        {{ select(
          label="Country",
          id="input-form-country",
          options=[
            {"label": "Netherlands", "value": "nl"},
            {"label": "Germany", "value": "de"},
            {"label": "United States", "value": "us"}
          ],
          selected="nl"
        ) }}
        {% endcall %}
      </div>
      {% call field() %}
      {{ input(
        label="Address",
        id="input-form-address",
        placeholder="Damrak 1, 1012 LG"
      ) }}
      {% endcall %}
      {% endcall %}
      {% endcall %}
      <div class="d-flex gap-2 justify-content-end mt-3">
        {{ button("Cancel", variant="outline", type="reset") }}
        {{ button("Submit", type="submit") }}
      </div>
      {% endcall %}
    {% endset %}
    {{ render_example(
      "form",
      "Form",
      "A full form example composed from a <code>&lt;fieldset&gt;</code>, a <code>.field-group</code>, and labeled fields. See the <a href=\"../components/field.html\">Fieldset</a> section for the legend/description contract.",
      full_form,
      "moo-example__preview--narrow"
    ) }}

    {% set rtl_arabic %}
      <div dir="rtl">
        {% call field() %}
        {{ input(
          label="مفتاح API",
          id="input-rtl-arabic",
          placeholder="sk-...",
          describedby="input-rtl-arabic-help"
        ) }}
        {{ field_description("input-rtl-arabic-help", "مفتاح API الخاص بك آمن ومشفر.") }}
        {% endcall %}
      </div>
    {% endset %}
    {% set rtl_hebrew %}
      <div dir="rtl">
        {% call field() %}
        {{ input(
          label="מפתח API",
          id="input-rtl-hebrew",
          placeholder="sk-...",
          describedby="input-rtl-hebrew-help"
        ) }}
        {{ field_description("input-rtl-hebrew-help", "המפתח שלך מאובטח ומוצפן.") }}
        {% endcall %}
      </div>
    {% endset %}
    {% set rtl_english %}
      <div dir="rtl">
        {% call field() %}
        {{ input(
          label="API Key",
          id="input-rtl-english",
          placeholder="sk-...",
          describedby="input-rtl-english-help"
        ) }}
        {{ field_description("input-rtl-english-help", "Your key is encrypted and stored securely.") }}
        {% endcall %}
      </div>
    {% endset %}

    {{ render_rtl_example(
      "input",
      "Use the same labeled helper-text pattern across languages with RTL direction.",
      rtl_arabic,
      rtl_hebrew,
      rtl_english,
      "moo-example__preview--narrow"
    ) }}
  </div>

  {{ render_reference(
    "For more form control options, see the",
    "https://getbootstrap.com/docs/5.3/forms/form-control/",
    "Bootstrap Form controls documentation"
  ) }}
{% endblock %}
