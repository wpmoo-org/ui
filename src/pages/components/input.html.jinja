{% extends "layouts/catalog.html.jinja" %}
{% from "includes/page-header.html.jinja" import render_page_header %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example %}
{% from "components/input.html.jinja" import input %}

{% block title %}Input — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Input",
    "A text input component for forms and user data entry with built-in styling and accessibility features."
  ) }}

  <div class="moo-component-examples">
    {% set api_key %}
      <div class="moo-field w-100">
        {{ input(
          label="API Key",
          id="api-key",
          placeholder="sk-..."
        ) }}
        <div class="form-text">Your API key is encrypted and stored securely.</div>
      </div>
    {% endset %}
    {{ render_example(
      "api-key",
      "API Key",
      "Keep the visible label, input, and helper text together when the field needs context.",
      api_key,
      "moo-example__preview--narrow"
    ) }}

    {% set basic %}
      {{ input(
        aria_label="Enter text",
        placeholder="Enter text"
      ) }}
    {% endset %}
    {{ render_example(
      "basic",
      "Basic",
      "Use a plain text input when the surrounding layout already explains the field.",
      basic,
      "moo-example__preview--narrow"
    ) }}

    {% set disabled %}
      <div class="moo-field w-100">
        {{ input(
          label="Email",
          id="disabled-email",
          type="text",
          value="team@example.com",
          disabled=true
        ) }}
        <div class="form-text">This field is currently disabled.</div>
      </div>
    {% endset %}
    {{ render_example(
      "disabled",
      "Disabled",
      "Use the <code>disabled</code> attribute when the value is visible but cannot be edited.",
      disabled,
      "moo-example__preview--narrow"
    ) }}

    {% set file_input %}
      <div class="moo-field w-100">
        {{ input(
          label="Picture",
          id="picture",
          type="file"
        ) }}
        <div class="form-text">Select a picture to upload.</div>
      </div>
    {% endset %}
    {{ render_example(
      "file",
      "File",
      "Use the <code>type=\"file\"</code> input for a native file picker.",
      file_input,
      "moo-example__preview--narrow"
    ) }}
  </div>

  {{ render_reference(
    "For more form control options, see the",
    "https://getbootstrap.com/docs/5.3/forms/form-control/",
    "Bootstrap Form controls documentation"
  ) }}
{% endblock %}
