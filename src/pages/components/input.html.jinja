{% extends "layouts/catalog.html.jinja" %}
{% from "components/api_reference.html.jinja" import render_api_reference %}
{% from "components/example.html.jinja" import render_example %}
{% from "components/input.html.jinja" import input %}
{% from "components/typography.html.jinja" import typography %}

{% block title %}Input — Moo UI{% endblock %}

{% block content %}
  <header class="moo-component-header">
    {{ typography("Input", variant="page-title") }}
    {{ typography(
      "Collect short text and search queries with native form controls.",
      variant="page-description"
    ) }}
  </header>

  <div class="moo-component-examples">
    {% set visible_label %}
      {{ input(
        label="Component name",
        id="component-name",
        placeholder="Enter a component name"
      ) }}
    {% endset %}
    {{ render_example(
      "visible-label",
      "Visible label",
      "Connect the label and control when the field name should remain visible.",
      visible_label
    ) }}

    {% set search_input %}
      {{ input(
        aria_label="Search components",
        type="search",
        placeholder="Filter components"
      ) }}
    {% endset %}
    {{ render_example(
      "search-input",
      "Search input",
      "Use an accessible name when surrounding context already identifies the field.",
      search_input
    ) }}

    {% set native_states %}
      <div class="d-grid gap-3">
        {{ input(
          aria_label="Disabled project name",
          value="Unavailable project",
          disabled=true
        ) }}
        {{ input(
          aria_label="Read-only project name",
          value="Published project",
          readonly=true
        ) }}
      </div>
    {% endset %}
    {{ render_example(
      "native-states",
      "Native states",
      "Choose disabled for unavailable controls and readonly for values that remain selectable.",
      native_states
    ) }}
  </div>

  {% set api_rows = [
    {"contract": "form-control", "use": "Text and search fields", "behavior": "Uses Bootstrap's native control sizing, border, focus, placeholder, and state styles."},
    {"contract": "form-label + for / id", "use": "Visible accessible name", "behavior": "Links a visible label to its input through native HTML attributes."},
    {"contract": "aria-label", "use": "Standalone accessible name", "behavior": "Names a control when its purpose is already visible in surrounding content."},
    {"contract": "disabled", "use": "Unavailable input", "behavior": "Uses native disabled interaction and Bootstrap's disabled appearance."},
    {"contract": "readonly", "use": "Non-editable value", "behavior": "Keeps the native control readable and selectable without accepting edits."},
    {"contract": "type=text / type=search", "use": "Supported scope", "behavior": "Input Group, textarea, validation, and floating labels remain deferred until an approved consumer needs them."}
  ] %}
  {{ render_api_reference(
    "input",
    "Use Bootstrap form-control markup directly for the current text and search field scope.",
    api_rows
  ) }}
{% endblock %}
