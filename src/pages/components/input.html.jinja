{% extends "layouts/catalog.html.jinja" %}
{% from "includes/page-header.html.jinja" import render_page_header %}
{% from "includes/example.html.jinja" import render_example %}
{% from "components/input.html.jinja" import input %}

{% block title %}Input — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Input",
    "A text input component for forms and user data entry with built-in styling and accessibility features."
  ) }}

  <div class="moo-component-examples">
    {% set api_key %}
      <div class="d-grid gap-2">
        {{ input(
          label="API Key",
          id="api-key",
          placeholder="sk-..."
        ) }}
        <div class="form-text">Your API key is encrypted and stored securely.</div>
      </div>
    {% endset %}
    {{ render_example(
      "api-key",
      "API Key",
      "Keep a visible label and a short supporting message together when a field needs context.",
      api_key,
      "moo-example__preview--narrow"
    ) }}

    {% set basic %}
      {{ input(
        aria_label="Enter text",
        placeholder="Enter text"
      ) }}
    {% endset %}
    {{ render_example(
      "basic",
      "Basic",
      "Use the native text input when the surrounding layout already explains the field.",
      basic,
      "moo-example__preview--narrow"
    ) }}

    {% set disabled %}
      <div class="d-grid gap-2">
        {{ input(
          label="Email",
          id="disabled-email",
          type="text",
          value="team@example.com",
          disabled=true
        ) }}
        <div class="form-text">This field is currently disabled.</div>
      </div>
    {% endset %}
    {{ render_example(
      "disabled",
      "Disabled",
      "Use the <code>disabled</code> attribute to prevent editing and focus while Bootstrap applies its disabled appearance.",
      disabled,
      "moo-example__preview--narrow"
    ) }}

    {% set invalid %}
      <div class="d-grid gap-2">
        {{ input(
          label="Invalid Input",
          id="invalid-input",
          placeholder="Error",
          aria_invalid=true
        ) }}
        <div class="form-text">This field contains validation errors.</div>
      </div>
    {% endset %}
    {{ render_example(
      "invalid",
      "Invalid",
      "Use <code>aria-invalid</code> for the accessibility state; the macro adds Bootstrap's matching <code>is-invalid</code> class.",
      invalid,
      "moo-example__preview--narrow"
    ) }}

    {% set file_input %}
      <div class="d-grid gap-2">
        {{ input(
          label="Picture",
          id="picture",
          type="file"
        ) }}
        <div class="form-text">Select a picture to upload.</div>
      </div>
    {% endset %}
    {{ render_example(
      "file",
      "File",
      "Use the <code>type=\"file\"</code> input for a native file picker.",
      file_input,
      "moo-example__preview--narrow"
    ) }}

    {% set required_field %}
      <div class="d-grid gap-2">
        {{ input(
          label="Required Field *",
          id="required-field",
          placeholder="This field is required",
          required=true
        ) }}
        <div class="form-text">This field must be filled out.</div>
      </div>
    {% endset %}
    {{ render_example(
      "required",
      "Required",
      "Use the native <code>required</code> attribute to indicate that an input must be filled out.",
      required_field,
      "moo-example__preview--narrow"
    ) }}
  </div>
{% endblock %}
