{% extends "layouts/catalog.html.jinja" %}
{% from "components/badge.html.jinja" import badge %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Badge — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Badge",
    "Add compact labels, counts, and statuses with Bootstrap's native badge component."
  ) }}

  <div class="moo-component-examples">
    {% set variants %}
      <div class="d-flex flex-wrap gap-2">
        {{ badge("Default") }}
        {{ badge("Secondary", variant="secondary") }}
        {{ badge("Destructive", variant="destructive") }}
        {{ badge("Outline", variant="outline") }}
      </div>
    {% endset %}
    {{ render_example(
      "variants",
      "Variants",
      "Use a compact set: default, secondary, destructive, and outline.",
      variants
    ) }}

    {% set status %}
      <div class="d-flex flex-wrap gap-2">
        {{ badge("Connected", variant="outline") }}
        {{ badge("Beta", variant="secondary") }}
        {{ badge("Draft", variant="warning") }}
        {{ badge("Blocked", variant="destructive") }}
      </div>
    {% endset %}
    {{ render_example(
      "status",
      "Status labels",
      "Reserve extra Bootstrap statuses for product states that need a recognizable semantic cue.",
      status
    ) }}

    {% set counts %}
      <div class="d-flex flex-wrap align-items-center gap-3">
        <span class="d-inline-flex align-items-center gap-2">
          Inbox
          {{ badge("12", variant="secondary", visually_hidden="unread messages") }}
        </span>
        <span class="d-inline-flex align-items-center gap-2">
          Chats
          {{ badge("3", pill=true, visually_hidden="new chats") }}
        </span>
      </div>
    {% endset %}
    {{ render_example(
      "counts",
      "Counts",
      "When a badge is only a number, add visually hidden context so screen readers hear what the count means.",
      counts
    ) }}

    {% set arabic_badge %}
      <div dir="rtl">
        <span class="d-inline-flex align-items-center gap-2">
          طلب الوصول
          {{ badge("قيد المراجعة", variant="warning") }}
        </span>
      </div>
    {% endset %}

    {% set hebrew_badge %}
      <div dir="rtl">
        <span class="d-inline-flex align-items-center gap-2">
          בקשת גישה
          {{ badge("ממתינה לאישור", variant="warning") }}
        </span>
      </div>
    {% endset %}

    {% set english_badge %}
      <div dir="rtl">
        <span class="d-inline-flex align-items-center gap-2">
          Access request
          {{ badge("Pending approval", variant="warning") }}
        </span>
      </div>
    {% endset %}

    {{ render_rtl_example(
      "badge",
      "RTL",
      arabic_badge,
      hebrew_badge,
      english_badge,
      preview_class="moo-example__preview--fit"
    ) }}
  </div>

  {{ render_reference(
    "For positioned badges and accessibility notes, see the",
    "https://getbootstrap.com/docs/5.3/components/badge/",
    "Bootstrap Badge documentation"
  ) }}

{% endblock %}
