{% extends "layouts/catalog.html.jinja" %}
{% from "components/button.html.jinja" import button %}
{% from "components/tooltip.html.jinja" import tooltip_trigger %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Tooltip — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Tooltip",
    "Show compact context hints for controls and actions on hover or keyboard focus with Bootstrap's native tooltip plugin."
  ) }}

  <div class="moo-component-examples">
    {% set basic %}
      {{ tooltip_trigger("Check sync status", "Workspace status is visible from the project settings panel.") }}
    {% endset %}
    {{ render_example(
      "basic",
      "Basic",
      "Use a focusable trigger for one-line operational context without opening modals.",
      basic,
      "moo-example__preview--narrow"
    ) }}

    {% set placements %}
      <div class="d-flex flex-wrap gap-2">
        {{ button("Top", variant="outline", tooltip="Preview opens above", tooltip_placement="top") }}
        {{ button("Right", variant="outline", tooltip="Preview opens to the right", tooltip_placement="right") }}
        {{ button("Bottom", variant="outline", tooltip="Preview opens below", tooltip_placement="bottom") }}
        {{ button("Left", variant="outline", tooltip="Preview opens to the left", tooltip_placement="left") }}
      </div>
    {% endset %}
    {{ render_example(
      "placements",
      "Side",
      "Choose <code>tooltip_placement</code> for compact command bars and density-sensitive tooltips.",
      placements,
      "moo-example__preview--narrow"
    ) }}

    {% set with_shortcut %}
      {{ button(
        "Save draft",
        variant="outline",
        icon_start="save",
        tooltip="Save draft <code class='tooltip-kbd'>⌘S</code>",
        tooltip_html=true
      ) }}
    {% endset %}
    {{ render_example(
      "keyboard-shortcut",
      "With keyboard shortcut",
      "Use compact shortcut badges in tooltip content and let Bootstrap sanitize the markup.",
      with_shortcut,
      "moo-example__preview--narrow"
    ) }}

    {% set disabled %}
      <span
        class="d-inline-block"
        role="button"
        tabindex="0"
        data-bs-toggle="tooltip"
        data-bs-title="This action is currently unavailable"
      >
        {{ button("Archive", variant="outline", disabled=true) }}
      </span>
    {% endset %}
    {{ render_example(
      "disabled-button",
      "Disabled button",
      "A <code>disabled</code> element never fires hover or focus events, so wrap it in a focusable <code>&lt;span&gt;</code> and attach the tooltip there, per Bootstrap's own guidance.",
      disabled,
      "moo-example__preview--narrow"
    ) }}

    {% set tooltip_rtl_arabic %}
      <div dir="rtl">
        {{ button("حالة المشروع", variant="outline", tooltip="تتبع حالة المشروع من هذه البطاقة.") }}
      </div>
    {% endset %}
    {% set tooltip_rtl_hebrew %}
      <div dir="rtl">
        {{ button("מצב הפרויקט", variant="outline", tooltip="בדוק את סטטוס הפרויקט מאותה כרטיסייה.") }}
      </div>
    {% endset %}
    {% set tooltip_rtl_english %}
      <div dir="rtl">
        {{ button("Project status", variant="outline", tooltip="Check project status from this card.") }}
      </div>
    {% endset %}
    {{ render_rtl_example(
      "tooltip",
      "Keep the same action context while previewing in RTL locales.",
      tooltip_rtl_arabic,
      tooltip_rtl_hebrew,
      tooltip_rtl_english,
      "moo-example__preview--narrow"
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's Tooltip plugin options, positioning, and accessibility notes, see the",
    "https://getbootstrap.com/docs/5.3/components/tooltips/",
    "Bootstrap Tooltips documentation"
  ) }}

{% endblock %}
