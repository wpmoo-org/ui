{% extends "layouts/catalog.html.jinja" %}
{% from "components/button.html.jinja" import button %}
{% from "components/sheet.html.jinja" import sheet, sheet_body, sheet_header %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Sheet — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Sheet",
    "A side panel that slides from the viewport edge using Bootstrap's Offcanvas behavior."
  ) }}

  <div class="moo-component-examples">
    {% set basic %}
      <div class="d-inline-flex">
        {{ button("Open sheet", variant="outline", sheet_target="sheet-basic") }}
      </div>
    {% endset %}
    {% set basic_sheet %}
      {% call sheet("sheet-basic") %}
        {{ sheet_header("sheet-basic", "Filter results") }}
        {% call sheet_body() %}
          <p class="mb-0">Narrow the list below by status, owner, and date range before a bulk action.</p>
        {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "basic",
      "Basic",
      "Use <code>sheet_target</code> on a button to open an off-canvas panel while staying in your current context.",
      basic,
      portal_content=basic_sheet
    ) }}

    {% set placements %}
      <div class="d-inline-flex flex-wrap gap-2">
        {{ button("Start", variant="outline", sheet_target="sheet-start") }}
        {{ button("End", variant="outline", sheet_target="sheet-end") }}
        {{ button("Top", variant="outline", sheet_target="sheet-top") }}
        {{ button("Bottom", variant="outline", sheet_target="sheet-bottom") }}
      </div>
    {% endset %}
    {% set placement_sheets %}
      {% call sheet("sheet-start", placement="start") %}
        {{ sheet_header("sheet-start", "From the start edge") }}
        {% call sheet_body() %}<p class="mb-0">Set <code>placement="start"</code>.</p>{% endcall %}
      {% endcall %}
      {% call sheet("sheet-end", placement="end") %}
        {{ sheet_header("sheet-end", "From the end edge") }}
        {% call sheet_body() %}<p class="mb-0">Set <code>placement="end"</code>, the default.</p>{% endcall %}
      {% endcall %}
      {% call sheet("sheet-top", placement="top") %}
        {{ sheet_header("sheet-top", "From the top edge") }}
        {% call sheet_body() %}<p class="mb-0">Set <code>placement="top"</code>.</p>{% endcall %}
      {% endcall %}
      {% call sheet("sheet-bottom", placement="bottom") %}
        {{ sheet_header("sheet-bottom", "From the bottom edge") }}
        {% call sheet_body() %}<p class="mb-0">Set <code>placement="bottom"</code>.</p>{% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "placements",
      "Placement",
      "Control which screen edge anchors the panel by setting <code>placement</code> to <code>start</code>, <code>end</code>, <code>top</code>, or <code>bottom</code>.",
      placements,
      portal_content=placement_sheets
    ) }}

    {% set scroll %}
      <div class="d-inline-flex">
        {{ button("Open with body scrolling", variant="outline", sheet_target="sheet-scroll") }}
      </div>
    {% endset %}
    {% set scroll_sheet %}
      {% call sheet("sheet-scroll", backdrop=false, scroll=true) %}
        {{ sheet_header("sheet-scroll", "Body scrolling") }}
        {% call sheet_body() %}
          <p class="mb-0">Use <code>backdrop=false</code> + <code>scroll=true</code> when users need to keep the page context visible.</p>
        {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "scroll",
      "Body scrolling",
      "Prefer <code>backdrop=false</code> + <code>scroll=true</code> only when users need to keep the page context visible.",
      scroll,
      portal_content=scroll_sheet
    ) }}

    {% set no_close %}
      <div class="d-inline-flex">
        {{ button("Open without a close button", variant="outline", sheet_target="sheet-no-close") }}
      </div>
    {% endset %}
    {% set no_close_sheet %}
      {% call sheet("sheet-no-close") %}
        {{ sheet_header("sheet-no-close", "Confirm export", dismiss=false) }}
        {% call sheet_body() %}
          <p class="text-body-secondary mb-3">Close from in-panel actions when a quick decision is required.</p>
          <div class="d-inline-flex gap-2">
            {{ button("Cancel", variant="outline", dismiss="offcanvas") }}
            {{ button("Export", dismiss="offcanvas") }}
          </div>
        {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "no-close-button",
      "No close button",
      "Hide the header close affordance with <code>dismiss=false</code> and provide an explicit in-panel action instead.",
      no_close,
      portal_content=no_close_sheet
    ) }}

    {% set workflow %}
      <div class="d-inline-flex">
        {{ button("Open task panel", variant="outline", sheet_target="sheet-workflow") }}
      </div>
    {% endset %}
    {% set workflow_sheet %}
      {% call sheet("sheet-workflow", placement="end") %}
        {{ sheet_header("sheet-workflow", "Task workflow") }}
        {% call sheet_body() %}
          <div class="vstack gap-3">
            <p class="text-body-secondary mb-0">Review assignment, due date, and reviewer notes before publishing.</p>
            {{ button("Assign reviewer", variant="outline") }}
            {{ button("Move to queue") }}
          </div>
        {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "workflow",
      "Task workflow panel",
      "Use a panel as a compact context surface for related operations that should stay connected to the main page.",
      workflow,
      preview_class="moo-example__preview--narrow",
      portal_content=workflow_sheet
    ) }}

    {% set rtl_arabic %}
      <div dir="rtl">
        {{ button("فتح لوحة التصفية", variant="outline", sheet_target="sheet-rtl") }}
      </div>
    {% endset %}
    {% set rtl_arabic_sheet %}
      {% call sheet("sheet-rtl") %}
        {{ sheet_header("sheet-rtl", "تصفية العناصر") }}
        {% call sheet_body() %}
          <p class="mb-0">قم بتصفية القائمة حسب الحالة والمالك ونطاق التاريخ.</p>
        {% endcall %}
      {% endcall %}
    {% endset %}

    {% set rtl_hebrew %}
      <div dir="rtl">
        {{ button("פתח חלון סינון", variant="outline", sheet_target="sheet-rtl-hebrew") }}
      </div>
    {% endset %}
    {% set rtl_hebrew_sheet %}
      {% call sheet("sheet-rtl-hebrew") %}
        {{ sheet_header("sheet-rtl-hebrew", "סינון פריטים") }}
        {% call sheet_body() %}
          <p class="mb-0">סנן את הרשימה לפי סטטוס, בעלים ורצף תאריכים.</p>
        {% endcall %}
      {% endcall %}
    {% endset %}

    {% set rtl_english %}
      <div dir="rtl">
        {{ button("Open filter panel", variant="outline", sheet_target="sheet-rtl-english") }}
      </div>
    {% endset %}
    {% set rtl_english_sheet %}
      {% call sheet("sheet-rtl-english") %}
        {{ sheet_header("sheet-rtl-english", "Filter items") }}
        {% call sheet_body() %}
          <p class="mb-0">Filter the list below by status, owner, and date range.</p>
        {% endcall %}
      {% endcall %}
    {% endset %}

    {{ render_rtl_example(
      "sheet-rtl",
      "Switch the sheet content direction for Arabic, Hebrew, and English workflows with the same placement and content shape.",
      rtl_arabic,
      rtl_hebrew,
      rtl_english,
      arabic_portal=rtl_arabic_sheet,
      hebrew_portal=rtl_hebrew_sheet,
      english_portal=rtl_english_sheet
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's Offcanvas plugin options, focus management, and accessibility notes, see the",
    "https://getbootstrap.com/docs/5.3/components/offcanvas/",
    "Bootstrap Offcanvas documentation"
  ) }}

{% endblock %}
