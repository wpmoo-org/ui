{% extends "layouts/catalog.html.jinja" %}
{% from "includes/page-header.html.jinja" import render_page_header %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example %}
{% from "components/kbd.html.jinja" import kbd %}

{% block title %}Kbd — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Kbd",
    "Show keyboard input in clear, accessible surrounding instructions."
  ) }}

  <div class="moo-component-examples">
    {% set single_key %}
      <p class="mb-0">Press {{ kbd("Esc") }} to close the current surface.</p>
    {% endset %}
    {{ render_example(
      "single-key",
      "Single key",
      "Use <code>&lt;kbd&gt;</code> inside a sentence so the key and the action it triggers are understandable together.",
      single_key
    ) }}

    {% set key_combination %}
      <p class="mb-0">Press {{ kbd("Ctrl") }} + {{ kbd("K") }} to open search.</p>
    {% endset %}
    {{ render_example(
      "key-combination",
      "Key combination",
      "Render each key separately and explain the result in text; do not make a <code>+</code> symbol carry the instruction by itself.",
      key_combination
    ) }}
  </div>

  {{ render_reference(
    "For keyboard input guidance, see the",
    "https://getbootstrap.com/docs/5.3/content/reboot/#user-input",
    "Bootstrap Reboot documentation"
  ) }}
{% endblock %}
