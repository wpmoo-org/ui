{% extends "layouts/catalog.html.jinja" %}
{% from "components/alert.html.jinja" import alert %}
{% from "components/button.html.jinja" import button %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Alert — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Alert",
    "Surface a contextual message with Bootstrap's native alert region."
  ) }}

  <div class="moo-component-examples">
    {% set basic %}
      {{ alert(
        "Scheduled maintenance",
        description="The catalog will be briefly unavailable this weekend while we upgrade the build pipeline.",
        icon="info"
      ) }}
    {% endset %}
    {{ render_example(
      "basic",
      "Basic",
      "Pair an icon with a title and description inside a quiet bordered region.",
      basic
    ) }}

    {% set destructive %}
      {{ alert(
        "Build failed",
        description="The last commit broke two tests. Check the CI log for details.",
        variant="destructive",
        icon="circle-alert"
      ) }}
    {% endset %}
    {{ render_example(
      "destructive",
      "Destructive",
      "Use <code>variant=\"destructive\"</code> for errors that need immediate attention.",
      destructive
    ) }}

    {% set action %}
      {{ alert(
        "Storage limit approaching",
        description="This workspace has used 92% of its plan. Upgrade to avoid interrupted uploads.",
        icon="triangle-alert",
        action=button("Upgrade plan", variant="outline", size="sm")
      ) }}
    {% endset %}
    {{ render_example(
      "action",
      "Action",
      "Compose the ready Button macro into <code>action</code> for a single inline response.",
      action
    ) }}

    {% set custom_colors %}
      {{ alert(
        "Subscription renews in 3 days",
        description="Confirm your payment method so the workspace doesn't lose access when the trial ends.",
        icon="triangle-alert",
        extra_class="border-warning-subtle bg-warning-subtle text-warning-emphasis"
      ) }}
    {% endset %}
    {{ render_example(
      "custom-colors",
      "Custom colors",
      "Layer Bootstrap's own subtle contextual utilities on <code>extra_class</code> instead of a filled, saturated alert color.",
      custom_colors
    ) }}

    {% set dismissible %}
      {{ alert(
        "Preview images refreshed",
        description="Component preview thumbnails were regenerated for the latest release.",
        icon="info",
        dismissible=true
      ) }}
    {% endset %}
    {{ render_example(
      "dismissible",
      "Dismissible",
      "Add a Close Button; wire <code>data-bs-dismiss=\"alert\"</code> when the alert should remove itself.",
      dismissible
    ) }}

    {% set arabic_alert %}
      <div dir="rtl">
        {{ alert(
          "تمت الموافقة على الطلب",
          description="تمت مراجعة طلب الوصول وسيصل صاحبه إلى مساحة العمل خلال دقائق.",
          icon="info"
        ) }}
      </div>
    {% endset %}

    {% set hebrew_alert %}
      <div dir="rtl">
        {{ alert(
          "הבקשה אושרה",
          description="בקשת הגישה נבדקה והמשתמש יקבל גישה לסביבת העבודה בתוך דקות.",
          icon="info"
        ) }}
      </div>
    {% endset %}

    {% set english_rtl_alert %}
      <div dir="rtl">
        {{ alert(
          "Access request approved",
          description="The request was reviewed and the requester will reach the workspace within minutes.",
          icon="info"
        ) }}
      </div>
    {% endset %}

    {{ render_rtl_example(
      "alert",
      "Use tabs to compare Arabic, Hebrew, and English alerts inside the same RTL layout.",
      arabic_alert,
      hebrew_alert,
      english_rtl_alert,
      preview_class="moo-example__preview--fit"
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's source behavior and contextual variants, see the",
    "https://getbootstrap.com/docs/5.3/components/alerts/",
    "Bootstrap Alerts documentation"
  ) }}

{% endblock %}
