{% extends "layouts/catalog.html.jinja" %}
{% from "components/tabs.html.jinja" import tabs %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Tabs — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Tabs",
    "Switch between related views in the same space using Bootstrap's Tab plugin."
  ) }}

  <div class="moo-component-examples">
    {% set basic %}
      {{ tabs(
        "tabs-basic",
        [
          {
            "id": "profile",
            "title": "Profile",
            "content": "Update your name, avatar, and public bio."
          },
          {
            "id": "security",
            "title": "Security",
            "content": "Manage your password and two-factor authentication."
          },
          {
            "id": "preferences",
            "title": "Preferences",
            "content": "Choose your language, timezone, and default notification settings."
          }
        ]
      ) }}
    {% endset %}
    {{ render_example(
      "basic",
      "Basic",
      "The first item is active by default; set <code>active</code> on an item to override it.",
      basic
    ) }}

    {% set disabled %}
      {{ tabs(
        "tabs-disabled",
        [
          {"id": "team", "title": "Team", "content": "See who has access to this project."},
          {"id": "archive", "title": "Archive", "content": "Archived projects are read-only.", "disabled": true}
        ]
      ) }}
    {% endset %}
    {{ render_example(
      "disabled",
      "Disabled",
      "Set <code>disabled</code> on an item to remove it from keyboard and pointer interaction.",
      disabled
    ) }}

    {% set rtl %}
      <div dir="rtl">
        {{ tabs(
          "tabs-rtl",
          [
            {"id": "profile", "title": "الملف الشخصي", "content": "تحديث اسمك وصورتك الشخصية ونبذتك العامة."},
            {"id": "security", "title": "الأمان", "content": "إدارة كلمة المرور والمصادقة الثنائية."}
          ]
        ) }}
      </div>
    {% endset %}
    {{ render_example(
      "rtl",
      "Right-to-left layout",
      "The active tab's track and text swap sides without mirrored custom CSS.",
      rtl
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's Tab plugin behavior and keyboard interaction, see the",
    "https://getbootstrap.com/docs/5.3/components/navs-tab/",
    "Bootstrap Navs and tabs documentation"
  ) }}

{% endblock %}
