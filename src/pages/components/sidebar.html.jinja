{% extends "layouts/catalog.html.jinja" %}
{% from "blocks/sidebar_shell.html.jinja" import render_sidebar_shell %}
{% from "components/table.html.jinja" import table %}
{% from "includes/block-example.html.jinja" import render_block_example %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/page-header.html.jinja" import render_page_header with context %}

{% block title %}Sidebar — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Sidebar",
    "Compose an application shell with Bootstrap-native sidebar primitives: provider, regions, menus, and inset content."
  ) }}

  <div class="moo-component-examples">
    <h2 id="usage" class="h4 mb-3">Usage</h2>
    <p class="mb-4">
      Start with <code>sidebar_provider()</code>, render one <code>sidebar()</code>,
      and place page content in <code>sidebar_inset()</code>. Put team switching and
      global actions in <code>sidebar_header()</code> and <code>sidebar_footer()</code>.
    </p>

    {% set app_shell %}
      {{ render_sidebar_shell(
        key="components-sidebar-floating",
        sidebar_id="components-sidebar-floating-demo",
        variant="floating",
        demo_copy="portal"
      ) }}
    {% endset %}
    {{ render_block_example(
      "app-shell",
      "Application shell",
      "Compose the shell from <code>sidebar_provider</code>, <code>sidebar</code>, and <code>sidebar_inset</code>. The preview uses the same floating sidebar block frame so the application shell is exercised as a standalone viewport.",
      app_shell,
      preview_class="moo-example__preview--shell",
      frame_src=site_href("blocks/previews/sidebar-floating.html", root_path)
    ) }}

    <h2 id="composition" class="h4 mt-5 mb-3">Composition</h2>
    <p class="mb-4">
      Sidebar parts compose existing ready macros. Actions use Button and
      Dropdown Menu, metadata uses Badge, form fields use Input, separators use
      Separator, and loading rows use Skeleton.
    </p>

    <figure class="mb-5">
      <img
        class="img-fluid rounded border bg-white"
        src="{{ root_path }}assets/images/sidebar-structure.webp"
        alt="Diagram showing sidebar_provider wrapping sidebar_header, sidebar_content, sidebar_footer, and sidebar_inset regions."
      >
    </figure>

    <h2 id="sidebar-api-reference" class="h4 mt-5 mb-3">Sidebar API Reference</h2>
    <p class="mb-4">
      Public names follow Bootstrap-native shell primitives and the shared sidebar contract.
      Use this list to wire page-level compositions quickly.
    </p>

    {% set sidebar_parts = [
      {"id": "sidebar-provider", "name": "sidebar_provider()", "summary": "Owns expanded/collapsed state and wraps the shell."},
      {"id": "sidebar", "name": "sidebar()", "summary": "Renders the app navigation container."},
      {"id": "sidebar-input", "name": "sidebar_input()", "summary": "Composes Input for sidebar-local filtering fields."},
      {"id": "sidebar-header", "name": "sidebar_header()", "summary": "Hosts brand, team switcher, or primary header controls."},
      {"id": "sidebar-footer", "name": "sidebar_footer()", "summary": "Hosts account menus and persistent footer actions."},
      {"id": "sidebar-separator", "name": "sidebar_separator()", "summary": "Composes Separator for sidebar section breaks."},
      {"id": "sidebar-content", "name": "sidebar_content()", "summary": "Provides the scrollable main navigation area."},
      {"id": "sidebar-group", "name": "sidebar_group()", "summary": "Groups related navigation or action rows."},
      {"id": "sidebar-group-label", "name": "sidebar_group_label()", "summary": "Labels a sidebar group with visible text."},
      {"id": "sidebar-group-action", "name": "sidebar_group_action()", "summary": "Composes Button for icon-only group actions."},
      {"id": "sidebar-group-content", "name": "sidebar_group_content()", "summary": "Wraps group children without adding layout policy by default."},
      {"id": "sidebar-menu", "name": "sidebar_menu()", "summary": "Renders the menu list container."},
      {"id": "sidebar-menu-item", "name": "sidebar_menu_item()", "summary": "Hosts one menu row, action row, or submenu trigger."},
      {"id": "sidebar-menu-button", "name": "sidebar_menu_button()", "summary": "Renders a link-like or button-like menu row."},
      {"id": "sidebar-menu-action", "name": "sidebar_menu_action()", "summary": "Composes Dropdown Menu for row-level overflow actions."},
      {"id": "sidebar-menu-badge", "name": "sidebar_menu_badge()", "summary": "Composes Badge for trailing row metadata."},
      {"id": "sidebar-menu-skeleton", "name": "sidebar_menu_skeleton()", "summary": "Composes Skeleton for deterministic loading rows."},
      {"id": "sidebar-menu-sub", "name": "sidebar_menu_sub()", "summary": "Renders a Bootstrap Collapse-backed submenu container."},
      {"id": "sidebar-menu-sub-item", "name": "sidebar_menu_sub_item()", "summary": "Hosts one nested submenu row."},
      {"id": "sidebar-menu-sub-button", "name": "sidebar_menu_sub_button()", "summary": "Renders the disclosure control for a submenu."},
      {"id": "sidebar-trigger", "name": "sidebar_trigger()", "summary": "Toggles the target sidebar."},
      {"id": "sidebar-rail", "name": "sidebar_rail()", "summary": "Provides the collapsed rail hit target."},
      {"id": "sidebar-inset", "name": "sidebar_inset()", "summary": "Hosts the page surface next to the sidebar."}
    ] %}

    {% set sidebar_parts_rows = [] %}
    {% for part in sidebar_parts %}
      {% set _ = sidebar_parts_rows.append(["<code>" ~ part["name"] ~ "</code>", part["summary"]]) %}
    {% endfor %}
    {{ table(
      ["Macro", "Purpose"],
      sidebar_parts_rows,
      row_ids=sidebar_parts | map(attribute="id") | list,
      row_header=true,
      extra_class="align-middle mb-5"
    ) }}

    <h2 id="usesidebar" class="h4 mt-5 mb-3">useSidebar</h2>
    <p class="mb-0">
      <strong>useSidebar</strong> is a runtime mapping only:
      <code>sidebar_provider()</code> writes <code>data-moo-sidebar-state</code>,
      and the integration logic reads it from <code>static/js/preview.js</code>.
    </p>
  </div>

  {{ render_reference(
    "The mobile drawer and collapse behavior build on Bootstrap's own Offcanvas and Collapse plugins; see the",
    "https://getbootstrap.com/docs/5.3/components/offcanvas/",
    "Bootstrap Offcanvas documentation"
  ) }}
  {{ render_reference(
    "For the nested collapse behavior, see the",
    "https://getbootstrap.com/docs/5.3/components/collapse/",
    "Bootstrap Collapse documentation"
  ) }}
{% endblock %}
