                          {% call sidebar_menu_sub_item() %}
                            {{ sidebar_menu_button("Runbooks", href="#", icon="book-open") }}
                          {% endcall %}
                          {% call sidebar_menu_sub_item() %}
                            {{ sidebar_menu_button("API guides", href="#", icon="code") }}
                          {% endcall %}
                        {% endcall %}
                      {% endcall %}
                      {% call sidebar_menu_item() %}
                        {{ sidebar_menu_button("Settings", href="#", icon="settings-2") }}
                      {% endcall %}
                    {% endcall %}
                  {% endcall %}
                {% endcall %}

                {% call sidebar_group() %}
                  {% call sidebar_group_content() %}
                    {{ sidebar_group_label("Project views") }}
                    {{ sidebar_group_action(icon="plus", aria_label="Create project view") }}
                    {% call sidebar_menu() %}
                      {% call sidebar_menu_item() %}
                        {{ sidebar_menu_button("Campaigns", href="#", icon="frame") }}
                        {% call sidebar_menu_action(aria_label="Campaign actions") %}
                          {{ dropdown_item("Rename", icon="pencil") }}
