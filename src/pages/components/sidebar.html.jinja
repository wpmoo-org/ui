{% extends "layouts/catalog.html.jinja" %}
{% from "components/avatar.html.jinja" import avatar %}
{% from "components/dropdown_menu.html.jinja" import dropdown_divider, dropdown_header, dropdown_item, dropdown_menu %}
{% from "components/separator.html.jinja" import separator %}
{% from "components/sidebar.html.jinja" import sidebar, sidebar_brand_mark, sidebar_content, sidebar_footer, sidebar_group, sidebar_group_label, sidebar_header, sidebar_inset, sidebar_menu, sidebar_menu_action, sidebar_menu_button, sidebar_menu_item, sidebar_menu_sub, sidebar_menu_sub_button, sidebar_menu_sub_item, sidebar_provider, sidebar_trigger %}
{% from "components/dropdown_menu.html.jinja" import dropdown_divider, dropdown_item %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Sidebar — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Sidebar",
    "Compose a collapsible application shell from a small family of Bootstrap-native primitives — header, groups, menus, footer, and inset."
  ) }}

  <div class="moo-component-examples">
    {% set sidebar_open = true %}
    {% set app_shell %}
      {% call sidebar_provider(contained=true, key="components-sidebar", default_open=sidebar_open) %}
        {% call sidebar(id="catalog-sidebar", aria_label="Catalog navigation") %}
          {% call sidebar_header() %}
            {% call sidebar_menu() %}
              {% call sidebar_menu_item(dropdown=true) %}
                {{ sidebar_menu_button(
                  "Acme Inc",
                  subtitle="Enterprise",
                  size="lg",
                  dropdown=true,
                  lead=sidebar_brand_mark("gallery-vertical-end"),
                  end_icon="chevrons-up-down"
                ) }}
                {% call dropdown_menu() %}
                  {{ dropdown_header("Teams") }}
                  {{ dropdown_item("Acme Inc", icon="gallery-vertical-end") }}
                  {{ dropdown_item("Acme Corp.", icon="audio-waveform") }}
                  {{ dropdown_item("Evil Corp.", icon="command") }}
                  {{ dropdown_divider() }}
                  {{ dropdown_item("Add team", icon="plus") }}
                {% endcall %}
              {% endcall %}
            {% endcall %}
          {% endcall %}

          {% call sidebar_content() %}
            {% call sidebar_group() %}
              {{ sidebar_group_label("Platform") }}
              {% call sidebar_menu() %}
                {% call sidebar_menu_item() %}
                  {{ sidebar_menu_button("Playground", href="#", icon="square-terminal", active=true) }}
                {% endcall %}
                {% call sidebar_menu_item() %}
                  {{ sidebar_menu_sub_button("Models", "platform-models", icon="bot", open=true) }}
                  {% call sidebar_menu_sub("platform-models", open=true) %}
                    {% call sidebar_menu_sub_item() %}
                      {{ sidebar_menu_button("GPT-4o", href="#", icon="sparkles", active=true) }}
                    {% endcall %}
                    {% call sidebar_menu_sub_item() %}
                      {{ sidebar_menu_button("Claude 3.5", href="#", icon="brain") }}
                    {% endcall %}
                  {% endcall %}
                {% endcall %}
                {% call sidebar_menu_item() %}
                  {{ sidebar_menu_sub_button("Documentation", "platform-documentation", icon="book-open") }}
                  {% call sidebar_menu_sub("platform-documentation") %}
                    {% call sidebar_menu_sub_item() %}
                      {{ sidebar_menu_button("Guides", href="#", icon="book-open") }}
                    {% endcall %}
                    {% call sidebar_menu_sub_item() %}
                      {{ sidebar_menu_button("API reference", href="#", icon="code") }}
                    {% endcall %}
                  {% endcall %}
                {% endcall %}
                {% call sidebar_menu_item() %}
                  {{ sidebar_menu_button("Settings", href="#", icon="settings-2") }}
                {% endcall %}
              {% endcall %}
            {% endcall %}

            {% call sidebar_group() %}
              {{ sidebar_group_label("Projects") }}
              {% call sidebar_menu() %}
                {% call sidebar_menu_item(extra_class="sidebar-menu-item--has-action") %}
                  {{ sidebar_menu_button("Design Engineering", href="#", icon="frame") }}
                  {% call sidebar_menu_action(aria_label="Design Engineering actions") %}
                    {{ dropdown_item("Rename", icon="pencil") }}
                    {{ dropdown_item("Archive", icon="archive") }}
                  {% endcall %}
                {% endcall %}
                {% call sidebar_menu_item(extra_class="sidebar-menu-item--has-action") %}
                  {{ sidebar_menu_button("Sales & Marketing", href="#", icon="pie-chart") }}
                  {% call sidebar_menu_action(aria_label="Sales and Marketing actions") %}
                    {{ dropdown_item("Rename", icon="pencil") }}
                    {{ dropdown_item("Archive", icon="archive") }}
                  {% endcall %}
                {% endcall %}
                {% call sidebar_menu_item(extra_class="sidebar-menu-item--has-action") %}
                  {{ sidebar_menu_button("Travel", href="#", icon="map") }}
                  {% call sidebar_menu_action(aria_label="Travel actions") %}
                    {{ dropdown_item("Rename", icon="pencil") }}
                    {{ dropdown_item("Archive", icon="archive") }}
                  {% endcall %}
                {% endcall %}
                {% call sidebar_menu_item() %}
                  {{ sidebar_menu_button("More", href="#", icon="ellipsis") }}
                {% endcall %}
              {% endcall %}
            {% endcall %}
          {% endcall %}

          {% call sidebar_footer() %}
            {% call sidebar_menu() %}
              {% call sidebar_menu_item(dropdown=true) %}
                {{ sidebar_menu_button(
                  "wpmoo",
                  subtitle="hello@wpmoo.org",
                  size="lg",
                  dropdown=true,
                  lead=avatar(name="wpmoo", initials="SC", extra_class="sidebar-avatar"),
                  end_icon="chevrons-up-down"
                ) }}
                {% call dropdown_menu(align="end") %}
                  {{ dropdown_header("hello@wpmoo.org") }}
                  {{ dropdown_item("Upgrade to Pro", icon="sparkles") }}
                  {{ dropdown_divider() }}
                  {{ dropdown_item("Account", icon="badge-check") }}
                  {{ dropdown_item("Billing", icon="credit-card") }}
                  {{ dropdown_item("Notifications", icon="bell") }}
                  {{ dropdown_divider() }}
                  {{ dropdown_item("Log out", icon="log-out") }}
                {% endcall %}
              {% endcall %}
            {% endcall %}
          {% endcall %}
        {% endcall %}

        {% call sidebar_inset() %}
          <header class="sidebar-inset__header">
            {{ sidebar_trigger(sidebar_id="catalog-sidebar", expanded=sidebar_open) }}
            {{ separator(orientation="vertical") }}
            <nav aria-label="breadcrumb">
              <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="#">Building Your Application</a></li>
                <li class="breadcrumb-item active" aria-current="page">Data Fetching</li>
              </ol>
            </nav>
          </header>
          <div class="sidebar-inset__content d-grid gap-3 p-3">
            <div class="d-grid gap-3" style="grid-template-columns: repeat(3, 1fr);">
              <div class="rounded-3 bg-body-secondary" style="aspect-ratio: 16 / 9;"></div>
              <div class="rounded-3 bg-body-secondary" style="aspect-ratio: 16 / 9;"></div>
              <div class="rounded-3 bg-body-secondary" style="aspect-ratio: 16 / 9;"></div>
            </div>
            <div class="rounded-3 bg-body-secondary flex-grow-1" style="min-height: 12rem;"></div>
          </div>
        {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "app-shell",
      "Application shell",
      "Compose the shell from <code>sidebar_provider</code>, <code>sidebar</code>, and <code>sidebar_inset</code>. The header holds a team switcher, the content holds grouped menus, and the footer holds the account menu — each a ready Dropdown Menu and Avatar composition.",
      app_shell,
      preview_class="moo-example__preview--shell"
    ) }}
  </div>

  {{ render_reference(
    "The mobile drawer and collapse behavior build on Bootstrap's own Offcanvas and Collapse plugins; see the",
    "https://getbootstrap.com/docs/5.3/components/offcanvas/",
    "Bootstrap Offcanvas documentation"
  ) }}
{% endblock %}
