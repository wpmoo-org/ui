{% extends "layouts/catalog.html.jinja" %}
{% from "components/button.html.jinja" import button %}
{% from "components/button_group.html.jinja" import button_group %}
{% from "includes/page-header.html.jinja" import render_page_header %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example %}

{% block title %}Button Group — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Button Group",
    "Join related controls into one compact action surface."
  ) }}

  <div class="moo-component-examples">
    {% set basic_actions %}
      {% call button_group("Ticket actions", toolbar=true, extra_class="gap-2") %}
        {% call button_group("Ticket navigation") %}
          {{ button("", variant="outline", size="icon", aria_label="Go back", icon_start="arrow-left") }}
        {% endcall %}
        {% call button_group("Ticket review") %}
          {{ button("Archive", variant="outline") }}
          {{ button("Report", variant="outline") }}
          {{ button("Snooze", variant="outline") }}
        {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "basic-actions",
      "Composition",
      "Use <code>btn-group</code> for joined controls. Wrap separate groups in <code>btn-toolbar</code> when the toolbar needs its own spacing.",
      basic_actions
    ) }}

    {% set mixed_styles %}
      {% call button_group("Mixed semantic styles") %}
        {{ button("Danger", variant="destructive") }}
        {{ button("Warning", variant="warning") }}
        {{ button("Success", variant="success") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "mixed-styles",
      "Mixed styles",
      "Combine semantic <code>btn-*</code> variants when each action carries a different consequence.",
      mixed_styles
    ) }}

    {% set outlined_styles %}
      {% call button_group("Outlined actions") %}
        {{ button("Previous", variant="outline-primary") }}
        {{ button("Current", variant="outline-primary") }}
        {{ button("Next", variant="outline-primary") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "outlined-styles",
      "Outlined styles",
      "Use the same <code>btn-outline-*</code> variant across a group when the controls should share one quiet visual weight.",
      outlined_styles
    ) }}

    {% set icon_only_group %}
      {% call button_group("Media controls") %}
        {{ button("", variant="outline", size="icon", aria_label="Previous item", icon_start="chevron-left") }}
        {{ button("", variant="outline", size="icon", aria_label="Pin item", icon_start="pin") }}
        {{ button("", variant="outline", size="icon", aria_label="Next item", icon_start="chevron-right") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "icon-only-group",
      "Icon-only group",
      "Give every icon-only button a square <code>size=\"icon\"</code> shape and an <code>aria-label</code>; the icon alone is not an accessible name.",
      icon_only_group
    ) }}

    {% set size_groups %}
      <div class="d-flex flex-column align-items-center gap-3">
        {% call button_group("Small button group", size="sm") %}
          {{ button("Small", variant="outline") }}
          {{ button("Button", variant="outline") }}
          {{ button("Group", variant="outline") }}
          {{ button("", variant="outline", size="icon", aria_label="Add small action", icon_start="plus") }}
        {% endcall %}
        {% call button_group("Default button group") %}
          {{ button("Default", variant="outline") }}
          {{ button("Button", variant="outline") }}
          {{ button("Group", variant="outline") }}
          {{ button("", variant="outline", size="icon", aria_label="Add default action", icon_start="plus") }}
        {% endcall %}
        {% call button_group("Large button group", size="lg") %}
          {{ button("Large", variant="outline") }}
          {{ button("Button", variant="outline") }}
          {{ button("Group", variant="outline") }}
          {{ button("", variant="outline", size="icon", aria_label="Add large action", icon_start="plus") }}
        {% endcall %}
      </div>
    {% endset %}
    {{ render_example(
      "size-groups",
      "Size",
      "<code>btn-group-sm</code> and <code>btn-group-lg</code> apply one density to every button in the group, keeping joined edges aligned.",
      size_groups
    ) }}

    {% set vertical_group %}
      {% call button_group("Quantity controls", vertical=true) %}
        {{ button("", variant="outline", size="icon", aria_label="Increase value", icon_start="plus") }}
        {{ button("", variant="outline", size="icon", aria_label="Decrease value", icon_start="minus") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "vertical-group",
      "Orientation",
      "Use <code>btn-group-vertical</code> when related controls belong in a narrow rail or stacked tool palette.",
      vertical_group
    ) }}

    {% set toolbar_groups %}
      {% call button_group("Editor toolbar", toolbar=true, extra_class="gap-2") %}
        {% call button_group("History actions") %}
          {{ button("Undo", variant="outline") }}
          {{ button("Redo", variant="outline") }}
        {% endcall %}
        {% call button_group("Formatting actions") %}
          {{ button("Bold", variant="outline") }}
          {{ button("Italic", variant="outline") }}
          {{ button("Link", variant="outline") }}
        {% endcall %}
        {% call button_group("Publish action") %}
          {{ button("Publish", variant="secondary") }}
        {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "toolbar-groups",
      "Toolbar",
      "Use <code>btn-toolbar</code> for separate action clusters; <code>gap-2</code> spaces the clusters while each inner group stays joined.",
      toolbar_groups
    ) }}

    {% set rtl_preview %}
      <div dir="rtl">
        {% call button_group("إجراءات التذكرة") %}
          {{ button("أرشفة", variant="outline") }}
          {{ button("مراجعة", variant="outline") }}
          {{ button("تأجيل", variant="outline") }}
        {% endcall %}
      </div>
    {% endset %}
    {{ render_example(
      "rtl-preview",
      "Right-to-left layout",
      "With <code>dir=\"rtl\"</code>, Bootstrap keeps joined borders and action order coherent for right-to-left content.",
      rtl_preview
    ) }}
  </div>

  {{ render_reference(
    "For more grouping patterns, see the",
    "https://getbootstrap.com/docs/5.3/components/button-group/",
    "Bootstrap Button group documentation"
  ) }}

{% endblock %}
