{% extends "layouts/catalog.html.jinja" %}
{% from "components/button.html.jinja" import button %}
{% from "components/checkbox.html.jinja" import checkbox %}
{% from "components/field.html.jinja" import form, field, field_description, field_error, field_group, fieldset %}
{% from "components/input.html.jinja" import input %}
{% from "components/radio_group.html.jinja" import radio_group %}
{% from "components/select.html.jinja" import select %}
{% from "components/separator.html.jinja" import separator %}
{% from "components/switch.html.jinja" import switch %}
{% from "components/textarea.html.jinja" import textarea %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Field — Moo UI{% endblock %}

{% block content %}
{{ render_page_header(
"Field",
"Compose the ready Input, Textarea, Select, Checkbox, Radio Group, and Switch controls into accessible,
label-first fields using Bootstrap-native validation and semantic grouping."
) }}

<div class="moo-component-examples">
  {% set full %}
  {% call form(extra_class="needs-validation", novalidate=true) %}
  {% call fieldset("Deployment", description="Configure where and how this build ships.") %}
  {% call field_group() %}
  {% call field() %}
  {{ input(label="Project name", id="field-full-project", placeholder="marketing-site", required=true,
  describedby="field-full-project-error") }}
  {{ field_error("field-full-project-error", "Enter a project name.") }}
  {% endcall %}
  {% call field() %}
  {{ input(label="Build command", id="field-full-build", placeholder="npm run build",
  describedby="field-full-build-description") }}
  {{ field_description("field-full-build-description", "Runs before every deploy.") }}
  {% endcall %}
  {% endcall %}
  {% call field_group() %}
  <div class="d-flex flex-wrap gap-3">
    {% call field(extra_class="flex-fill") %}
    {{ select(label="Region", id="field-full-region", options=[
    {"label": "US East", "value": "us-east"},
    {"label": "EU West", "value": "eu-west"},
    {"label": "AP Southeast", "value": "ap-southeast"}
    ], selected="us-east") }}
    {% endcall %}
    {% call field(extra_class="flex-fill") %}
    {{ select(label="Instance size", id="field-full-size", options=[
    {"label": "Small", "value": "small"},
    {"label": "Medium", "value": "medium"},
    {"label": "Large", "value": "large"}
    ], selected="medium") }}
    {% endcall %}
    {% call field(extra_class="flex-fill") %}
    {{ input(label="Replicas", id="field-full-replicas", value="2") }}
    {% endcall %}
  </div>
  {% endcall %}
  {% endcall %}
  {{ separator() }}
  {% call fieldset("Notifications", description="Who to notify when this deploy finishes.") %}
  {% call field_group() %}
    {% call field() %}
    {{ switch(id="field-full-notify", label="Notify the whole channel", checked=true) }}
    {% endcall %}
  {% endcall %}
  {% call field_group() %}
    {% call field() %}
    {{ textarea(label="Notes", id="field-full-notes", placeholder="Add context for teammates watching the deploy log.",
    rows=3, describedby="field-full-notes-description") }}
    {{ field_description("field-full-notes-description", "Shown in the deploy log for teammates.") }}
    {% endcall %}
  {% endcall %}
  {% endcall %}
  <div class="d-flex gap-2">
    {{ button("Deploy", type="submit") }}
    {{ button("Cancel", variant="outline", type="reset") }}
  </div>
  {% endcall %}
  {% endset %}
  {{ render_example(
  "full",
  "Full example",
  "Build one compact form from <code>fieldset()</code>, <code>field_group()</code>, and control macros. Native
  Bootstrap validation is handled with <code>novalidate</code>, <code>needs-validation</code>, and standard
  field-level feedback.",
  full,
  preview_class="moo-example__preview--narrow"
  ) }}

  {% set basic %}
  {% call field() %}
  {{ input(label="Display name", id="field-basic-name", placeholder="Ada Lovelace",
  describedby="field-basic-name-description") }}
  {{ field_description("field-basic-name-description", "Shown across the workspace and on shared links.") }}
  {% endcall %}
  {% endset %}
  {{ render_example(
  "basic",
  "Basic field",
  "Pair <code>field()</code> with <code>field_description()</code> and connect it with
  <code>describedby</code> for assistive relationships.",
  basic
  ) }}

  {% set invalid %}
  {% call field() %}
  {{ input(label="Workspace slug", id="field-invalid-slug", value="my workspace", aria_invalid=true,
  describedby="field-invalid-slug-error") }}
  {{ field_error("field-invalid-slug-error", "Slugs can only contain lowercase letters, numbers, and hyphens.") }}
  {% endcall %}
  {% endset %}
  {{ render_example(
  "invalid",
  "Input with validation error",
  "Add <code>aria_invalid=true</code> to the control and <code>field_error()</code> directly below it; Bootstrap's own
  <code>.is-invalid</code> styling and <code>.invalid-feedback</code> display rule need no extra CSS.",
  invalid
  ) }}

  {% set disabled %}
  {% call field() %}
  {{ input(label="Read-only project", id="field-disabled-project", value="release-automation", disabled=true,
  describedby="field-disabled-project-description") }}
  {{ field_description("field-disabled-project-description", "This value is maintained centrally and can't be edited in this state.") }}
  {% endcall %}
  {% endset %}
  {{ render_example(
  "disabled",
  "Disabled field",
  "Keep the label and helper text visible when a field is temporarily unavailable by using the control's native
  <code>disabled</code> state.",
  disabled
  ) }}

  {% set group %}
  {% call field_group() %}
  {% call field() %}
  {{ input(label="First name", id="field-group-first", placeholder="Ada") }}
  {% endcall %}
  {% call field() %}
  {{ input(label="Last name", id="field-group-last", placeholder="Lovelace") }}
  {% endcall %}
  {% endcall %}
  {% endset %}
  {{ render_example(
  "group",
  "Field group",
  "Wrap several <code>field()</code> blocks in <code>field_group()</code> for a consistent gap between related fields.",
  group
  ) }}

  {% set textarea_field %}
  {% call field() %}
  {{ textarea(label="Release notes", id="field-textarea-notes", placeholder="What changed in this deploy?", rows=3,
  describedby="field-textarea-notes-description") }}
  {{ field_description("field-textarea-notes-description", "Shown to your team in the changelog.") }}
  {% endcall %}
  {% endset %}
  {{ render_example(
  "textarea",
  "Textarea",
  "The same <code>field()</code> wrapper works with multiline input while retaining the same spacing and helper-text contract.",
  textarea_field
  ) }}

  {% set select_field %}
  {% call field() %}
  {{ select(label="Time zone", id="field-select-timezone", options=[
  {"label": "Pacific Time", "value": "pt"},
  {"label": "Eastern Time", "value": "et"},
  {"label": "Central European Time", "value": "cet"}
  ], selected="et", describedby="field-select-timezone-description") }}
  {{ field_description("field-select-timezone-description", "Used to schedule your deploy window.") }}
  {% endcall %}
  {% endset %}
  {{ render_example(
  "select",
  "Select",
  "Use <code>field()</code> with <code>select()</code> for a consistent wrapper and helper-text flow.",
  select_field
  ) }}

  {% set fieldset_example %}
  {% call fieldset("Notifications", description="Choose what you want to hear about.") %}
  {% call field_group() %}
  {% call field() %}
  {{ switch(id="field-fieldset-product", label="Product updates", checked=true) }}
  {% endcall %}
  {% call field() %}
  {{ switch(id="field-fieldset-billing", label="Billing alerts", checked=true) }}
  {% endcall %}
  {% call field() %}
  {{ switch(id="field-fieldset-digest", label="Weekly digest") }}
  {% endcall %}
  {% endcall %}
  {% endcall %}
  {% endset %}
  {{ render_example(
  "fieldset",
  "Fieldset",
  "<code>fieldset()</code> renders a native <code>&lt;fieldset&gt;</code> with a <code>&lt;legend&gt;</code> and optional
  description, useful for semantic grouping with no extra styling.",
  fieldset_example
  ) }}

  {% set fieldset_group %}
  {% call fieldset("Support contact", description="Who should we reach out to about this project?") %}
  {% call field_group() %}
  {% call field() %}
  {{ input(label="Contact name", id="field-contact-name", placeholder="Grace Hopper") }}
  {% endcall %}
  <div class="d-flex flex-wrap gap-3">
    {% call field(extra_class="flex-fill") %}
    {{ input(label="Email", id="field-contact-email", type="text", placeholder="grace@example.com") }}
    {% endcall %}
    {% call field(extra_class="flex-fill") %}
    {{ input(label="Phone", id="field-contact-phone", placeholder="+1 (555) 010-0100") }}
    {% endcall %}
  </div>
  {% endcall %}
  {% endcall %}
  {% endset %}
  {{ render_example(
  "fieldset-group",
  "Fieldset with a nested row",
  "A row of side-by-side <code>field()</code> blocks nests inside <code>field_group()</code> just like any other
  field.",
  fieldset_group
  ) }}

  {% set checkbox_group %}
  {% call fieldset("Visible dashboard widgets", description="Choose what shows on your team's overview.") %}
  {% call field_group() %}
  {% call field() %}
  {{ checkbox(id="field-widget-revenue", label="Revenue", checked=true) }}
  {% endcall %}
  {% call field() %}
  {{ checkbox(id="field-widget-users", label="Active users", checked=true) }}
  {% endcall %}
  {% call field() %}
  {{ checkbox(id="field-widget-errors", label="Error rate") }}
  {% endcall %}
  {% call field() %}
  {{ checkbox(id="field-widget-deploys", label="Deploy history") }}
  {% endcall %}
  {% endcall %}
  {% endcall %}
  {% call field() %}
  {{ checkbox(id="field-sync", label="Sync settings across devices", checked=true, description="Preferences carry over
  to any device you sign into.") }}
  {% endcall %}
  {% endset %}
  {{ render_example(
  "checkbox",
  "Checkbox group",
  "<code>checkbox()</code> already carries its own label, so it can be composed directly inside
  <code>field_group()</code> when only choices and no extra helper text are needed.",
  checkbox_group
  ) }}

  {% set radio_field %}
  {{ radio_group("compute-tier", "Compute tier", [
  {"id": "field-tier-standard", "label": "Standard ($0.02/min)", "value": "standard", "checked": true},
  {"id": "field-tier-performance", "label": "Performance ($0.05/min)", "value": "performance"},
  {"id": "field-tier-turbo", "label": "Turbo ($0.12/min)", "value": "turbo"}
  ]) }}
  {% endset %}
  {{ render_example(
  "radio",
  "Radio group",
  "Radio Group renders a native structure internally, so it can be used as a complete unit next to other <code>field()</code>
  compositions.",
  radio_field
  ) }}

  {% set switch_field %}
  {{ switch(id="field-2fa", label="Require two-factor sign-in") }}
  {% endset %}
  {{ render_example(
  "switch",
  "Switch",
  "When a switch has an inline label and no helper text, the control macro is sufficient by itself in a compact layout.",
  switch_field
  ) }}

  {% set separated_group %}
  {% call fieldset("Build alerts", description="Notified the moment a deploy fails its build step.") %}
  {% call field_group() %}
  {% call field() %}
  {{ checkbox(id="field-build-alerts", label="Notify on failure", checked=true) }}
  {% endcall %}
  {% endcall %}
  {% endcall %}
  {{ separator() }}
  {% call fieldset("Usage alerts", description="Notified as this project approaches its monthly usage limit.") %}
  {% call field_group() %}
  {% call field() %}
  {{ checkbox(id="field-usage-80", label="Notify at 80% quota", checked=true) }}
  {% endcall %}
  {% call field() %}
  {{ checkbox(id="field-usage-100", label="Notify at 100% quota", checked=true) }}
  {% endcall %}
  {% endcall %}
  {% endcall %}
  {% endset %}
  {{ render_example(
  "separator",
  "Field group with a separator",
  "Use the existing <code>separator()</code> between grouped sections to create a clear transition in long option sets.",
  separated_group
  ) }}

  {% set arabic_rtl %}
  <div dir="rtl">
    {% call field() %}
    {{ input(label="اسم المشروع", id="field-rtl-arabic-project", placeholder="marketing-site",
    describedby="field-rtl-arabic-project-description") }}
    {{ field_description("field-rtl-arabic-project-description", "يظهر في لوحة النشر وفي روابط الفريق.") }}
    {% endcall %}
    {% call field() %}
    {{ textarea(label="ملاحظات", id="field-rtl-arabic-notes", placeholder="أضف ملاحظات النشر.", rows=3,
    describedby="field-rtl-arabic-notes-description") }}
    {{ field_description("field-rtl-arabic-notes-description", "تُظهر هذه الملاحظات فرق الدعم قبل الإقلاع.") }}
    {% endcall %}
  </div>
  {% endset %}
  {% set hebrew_rtl %}
  <div dir="rtl">
    {% call field() %}
    {{ input(label="שם הפרויקט", id="field-rtl-hebrew-project", placeholder="marketing-site",
    describedby="field-rtl-hebrew-project-description") }}
    {{ field_description("field-rtl-hebrew-project-description", "מופיע בלוח הפריסה ובקישורי הצוות.") }}
    {% endcall %}
    {% call field() %}
    {{ textarea(label="הערות פריסה", id="field-rtl-hebrew-notes", placeholder="הוסף הערות פריסה.", rows=3,
    describedby="field-rtl-hebrew-notes-description") }}
    {{ field_description("field-rtl-hebrew-notes-description", "הערות אלה מוצגות לצוותי התמיכה לפני ההשקה.") }}
    {% endcall %}
  </div>
  {% endset %}
  {% set english_rtl %}
  <div dir="rtl">
    {% call field() %}
    {{ input(label="Project name", id="field-rtl-english-project", placeholder="marketing-site",
    describedby="field-rtl-english-project-description") }}
    {{ field_description("field-rtl-english-project-description", "Displayed in the release dashboard and team links.") }}
    {% endcall %}
    {% call field() %}
    {{ textarea(label="Deployment notes", id="field-rtl-english-notes", placeholder="Add deployment notes.", rows=3,
    describedby="field-rtl-english-notes-description") }}
    {{ field_description("field-rtl-english-notes-description", "These notes show support teams before launch.") }}
    {% endcall %}
  </div>
  {% endset %}
  {{ render_rtl_example(
  "field-rtl",
  "Spacing and relationships remain stable in right-to-left layouts when controls are composed with <code>field()</code>.",
  arabic_rtl,
  hebrew_rtl,
  english_rtl,
  preview_class="moo-example__preview--narrow"
  ) }}
</div>

{{ render_reference(
"For Bootstrap's own form layout, validation states, and accessibility notes, see the",
"https://getbootstrap.com/docs/5.3/forms/validation/",
"Bootstrap Validation documentation"
) }}

{% endblock %}
