{% extends "layouts/catalog.html.jinja" %}
{% from "includes/page-header.html.jinja" import render_page_header %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "components/typography.html.jinja" import typography %}

{% block title %}Typography — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Typography",
    "Align headings, labels, and body copy with Bootstrap's utility-first text semantics and Moo UI tokenized roles."
  ) }}

  <div class="moo-component-examples">
    {% set headings %}
      <div class="d-grid gap-3">
        {{ typography("Product Console", variant="page-title") }}
        {{ typography("Operations playbook", variant="section-title") }}
        {{ typography("Incident summary", variant="example-title") }}
      </div>
    {% endset %}
    {{ render_example(
      "headings",
      "Headings",
      "Map semantic intent to the heading roles first, then use utility classes when visual level and HTML level need to differ.",
      headings
    ) }}

    {% set semantic_headings %}
      <div class="d-grid gap-2">
        <h1 class="mb-0">h1. Team roadmap</h1>
        <h2 class="mb-0">h2. Sprint planning</h2>
        <h3 class="mb-0">h3. Release checklist</h3>
        <h4 class="mb-0">h4. Ticket priorities</h4>
        <h5 class="mb-0">h5. Deployment notes</h5>
        <h6 class="mb-0">h6. Open action items</h6>
      </div>
    {% endset %}
    {{ render_example(
      "semantic-headings",
      "Semantic headings",
      "Keep the document outline meaningful when screen readers and search indexing are reading this content.",
      semantic_headings
    ) }}

    {% set heading_utilities %}
      <div class="d-grid gap-2">
        <p class="h1 mb-0">h1. Dashboard view</p>
        <p class="h2 mb-0">h2. Usage analytics</p>
        <p class="h3 mb-0">h3. Team activity</p>
        <p class="h4 mb-0">h4. API usage</p>
        <p class="h5 mb-0">h5. Integration status</p>
        <p class="h6 mb-0">h6. Audit log</p>
      </div>
    {% endset %}
    {{ render_example(
      "heading-utilities",
      "Heading utilities",
      "Use heading utility classes when the visual style must stay large but the document structure should stay compact.",
      heading_utilities
    ) }}

    {% set customizing_headings %}
      <h3 class="mb-0">Maintenance window <small class="text-body-secondary">Planned 02:00–03:00 UTC</small></h3>
    {% endset %}
    {{ render_example(
      "customizing-headings",
      "Customizing headings",
      "Use <code>small.text-body-secondary</code> for contextual metadata that should stay subordinate to the heading.",
      customizing_headings
    ) }}

    {% set display_headings %}
      <div class="d-grid gap-2">
        <h1 class="display-1 mb-0">Display 1 · Operations pulse</h1>
        <h1 class="display-2 mb-0">Display 2 · Capacity trend</h1>
        <h1 class="display-3 mb-0">Display 3 · Release wave</h1>
        <h1 class="display-4 mb-0">Display 4 · Delivery goals</h1>
        <h1 class="display-5 mb-0">Display 5 · Quality checks</h1>
        <h1 class="display-6 mb-0">Display 6 · Readability</h1>
      </div>
    {% endset %}
    {{ render_example(
      "display-headings",
      "Display headings",
      "Use <code>display-1</code> through <code>display-6</code> when a heading needs more visual presence than the surrounding content hierarchy.",
      display_headings
    ) }}

    {% set supporting_text %}
      <div class="d-grid gap-3">
        {{ typography("Track status, ownership, and escalation points from one shared index.", variant="page-description") }}
        {{ typography("Muted text fits status chips and non-blocking helper notes.", variant="muted") }}
        {{ typography("Section label", variant="section-label") }}
      </div>
    {% endset %}
    {{ render_example(
      "supporting-text",
      "Supporting text",
      "Use lead, secondary, and label roles to show hierarchy without inventing one-off text styles for each page.",
      supporting_text
    ) }}

    {% set lead %}
      <p class="lead mb-0">Lead copy is useful for a short onboarding message or migration note.</p>
    {% endset %}
    {{ render_example(
      "lead",
      "Lead",
      "Add <code>lead</code> when an introductory paragraph needs more visual weight than ordinary body copy.",
      lead
    ) }}

    {% set inline_elements %}
      <div class="d-grid gap-2">
        <p class="mb-0">Use <mark>mark</mark> to highlight text for reference.</p>
        <p class="mb-0"><del>This line is no longer accurate.</del></p>
        <p class="mb-0"><s>This line is no longer relevant.</s></p>
        <p class="mb-0"><ins>This line was added to the document.</ins></p>
        <p class="mb-0"><u>This line carries a non-textual annotation.</u></p>
        <p class="mb-0"><small>This is fine print and supporting detail.</small></p>
        <p class="mb-0"><strong>This line carries strong importance.</strong></p>
        <p class="mb-0"><em>This line carries emphasis.</em></p>
      </div>
    {% endset %}
    {{ render_example(
      "inline-elements",
      "Inline text elements",
      "Use semantic inline elements for their meaning: <code>mark</code> highlights, <code>del</code> removes, <code>ins</code> adds, and <code>strong</code>/<code>em</code> convey emphasis.",
      inline_elements
    ) }}

    {% set abbreviation %}
      <p class="mb-0"><abbr title="HyperText Markup Language" class="initialism">HTML</abbr> keeps its expanded meaning available on hover.</p>
    {% endset %}
    {{ render_example(
      "abbreviation",
      "Abbreviations",
      "Add a <code>title</code> to <code>abbr</code> so an acronym has an accessible expanded meaning; <code>initialism</code> gives it a slightly smaller treatment.",
      abbreviation
    ) }}

    {% set blockquote %}
      <figure class="mb-0">
        <blockquote class="blockquote mb-2">
          <p class="mb-0">A calm interface makes the next action easier to find.</p>
        </blockquote>
        <figcaption class="blockquote-footer mt-2 mb-0">
          A design principle in <cite title="Moo UI handbook">Moo UI handbook</cite>
        </figcaption>
      </figure>
    {% endset %}
    {{ render_example(
      "blockquote",
      "Blockquotes",
      "Wrap a quotation in <code>blockquote</code> and keep its attribution outside the quote with <code>blockquote-footer</code> and <code>cite</code>.",
      blockquote
    ) }}

    {% set blockquote_alignment %}
      <div class="d-grid gap-3 w-100">
        <figure class="text-center mb-0">
          <blockquote class="blockquote mb-2">
            <p class="mb-0">A calm interface makes the next action easier to find.</p>
          </blockquote>
          <figcaption class="blockquote-footer mt-2 mb-0">
            A design principle in <cite title="Moo UI handbook">Moo UI handbook</cite>
          </figcaption>
        </figure>
        <figure class="text-end mb-0">
          <blockquote class="blockquote mb-2">
            <p class="mb-0">A calm interface makes the next action easier to find.</p>
          </blockquote>
          <figcaption class="blockquote-footer mt-2 mb-0">
            A design principle in <cite title="Moo UI handbook">Moo UI handbook</cite>
          </figcaption>
        </figure>
      </div>
    {% endset %}
    {{ render_example(
      "blockquote-alignment",
      "Blockquote alignment",
      "Use <code>text-center</code> or <code>text-end</code> on the figure to align a quote and its attribution together.",
      blockquote_alignment
    ) }}

    {% set lists %}
      <div class="d-grid gap-3 w-100">
        <ul class="list-unstyled mb-0">
          <li>Unstyled lists keep their structure without bullets.</li>
          <li>The content remains a real list for assistive technology.</li>
        </ul>
        <ul class="list-inline mb-0">
          <li class="list-inline-item">Inline item one</li>
          <li class="list-inline-item">Inline item two</li>
          <li class="list-inline-item">Inline item three</li>
        </ul>
        <dl class="row mb-0">
          <dt class="col-sm-3">Term</dt>
          <dd class="col-sm-9">A short definition aligned with the grid.</dd>
          <dt class="col-sm-3">Another term</dt>
          <dd class="col-sm-9 mb-0">Another definition in the same rhythm.</dd>
        </dl>
      </div>
    {% endset %}
    {{ render_example(
      "lists",
      "Lists",
      "Use <code>list-unstyled</code> for quiet lists, <code>list-inline</code> for compact rows, and the grid classes to align a description list.",
      lists
    ) }}

    {% set text_alignment %}
      <div class="d-grid gap-2 w-100">
        <p class="text-start mb-0">Start-aligned text follows the reading direction.</p>
        <p class="text-center mb-0">Center-aligned text suits short, focused labels.</p>
        <p class="text-end mb-0">End-aligned text closes the row cleanly.</p>
      </div>
    {% endset %}
    {{ render_example(
      "text-alignment",
      "Alignment",
      "Use <code>text-start</code>, <code>text-center</code>, and <code>text-end</code> to align text without a custom selector.",
      text_alignment
    ) }}

    {% set text_transform %}
      <div class="d-grid gap-2">
        <p class="text-lowercase mb-0">QUIET SYSTEM STATUS</p>
        <p class="text-uppercase mb-0">quiet system status</p>
        <p class="text-capitalize mb-0">quiet system status</p>
      </div>
    {% endset %}
    {{ render_example(
      "text-transform",
      "Transform",
      "Use <code>text-lowercase</code>, <code>text-uppercase</code>, or <code>text-capitalize</code> when the displayed casing is part of the content treatment.",
      text_transform
    ) }}

    {% set text_scale %}
      <div class="d-grid gap-2">
        <p class="fs-5 mb-0">A slightly larger supporting line.</p>
        <p class="fw-semibold mb-0">A stronger label for an important state.</p>
        <p class="fst-italic mb-0">A quiet note that stays in the same hierarchy.</p>
      </div>
    {% endset %}
    {{ render_example(
      "text-scale",
      "Size and emphasis",
      "Use <code>fs-*</code> for font size and <code>fw-*</code>/<code>fst-*</code> for weight or italics; these utilities change treatment without replacing semantic elements.",
      text_scale
    ) }}

    {% set line_height %}
      <div class="d-grid gap-2">
        <p class="lh-1 mb-0">Tight line-height keeps a compact label close together.</p>
        <p class="lh-base mb-0">Base line-height keeps ordinary reading comfortable.</p>
        <p class="lh-lg mb-0">Large line-height gives a longer sentence more air.</p>
      </div>
    {% endset %}
    {{ render_example(
      "line-height",
      "Line height",
      "Use <code>lh-1</code>, <code>lh-base</code>, or <code>lh-lg</code> when text density needs to change without a custom line-height declaration.",
      line_height
    ) }}

    {% set text_decoration %}
      <div class="d-grid gap-2">
        <p class="text-decoration-underline mb-0">Underline a policy reference before users confirm action.</p>
        <p class="text-decoration-line-through mb-0">Strike through an obsolete process step that was revised.</p>
      </div>
    {% endset %}
    {{ render_example(
      "text-decoration",
      "Text decoration",
      "Use <code>text-decoration-underline</code> or <code>text-decoration-line-through</code> when the decoration communicates the text state.",
      text_decoration
    ) }}

    {% set monospace %}
      <p class="font-monospace mb-0">npm run lint --workspace=ui</p>
    {% endset %}
    {{ render_example(
      "monospace",
      "Monospace",
      "Apply <code>font-monospace</code> to identifiers and terminal-like values when a fixed-width face improves scanning.",
      monospace
    ) }}

    {% set inline_code %}
      <p class="mb-0">Use {{ typography("npm run format", variant="inline-code") }} for local CI-aligned formatting.</p>
    {% endset %}
    {{ render_example(
      "inline-code",
      "Inline code",
      "Wrap public classes, attributes, and contracts in <code>&lt;code&gt;</code> so technical names stay distinct inside prose.",
      inline_code
    ) }}

    {% set typography_rtl_arabic %}
      <div dir="rtl" class="d-grid gap-3">
        {{ typography("إرشادات التدقيق اليومي", variant="section-title") }}
        <p class="lead mb-0">يبدأ كل يوم بفحص واضح للمؤشرات المفتاحية وسلامة عملية الإبلاغ.</p>
        <p class="mb-0 text-body-secondary">تم تحديث الملخص في توقيت <strong>UTC 07:00</strong>، ويمكن مراجعة البنود المفتوحة بنفس التسلسل.</p>
        <ul class="list-unstyled mb-0">
          <li>تحقق من حالة الخدمة، وخطة الاسترجاع، ومسؤولية النشر.</li>
          <li>سجل قرارات الحوكمة قبل اعتماد أي تغيير إضافي.</li>
        </ul>
      </div>
    {% endset %}

    {% set typography_rtl_hebrew %}
      <div dir="rtl" class="d-grid gap-3">
        {{ typography("הנחיות ביקורת יומית", variant="section-title") }}
        <p class="lead mb-0">כל יום מתחיל בסקירה ברורה של מדדי מפתח ובטיחות תהליך הדיווח.</p>
        <p class="mb-0 text-body-secondary">עדכון תקציר ב־<strong>UTC 07:00</strong>; פתיחת פריטים בהלימה קבועה.</p>
        <ul class="list-unstyled mb-0">
          <li>בדוק סטטוס שירות, תוכנית שחזור, ואחריות פריסה.</li>
          <li>תעד החלטות ממשל לפני אימות שינוי נוסף.</li>
        </ul>
      </div>
    {% endset %}

    {% set typography_rtl_english %}
      <div dir="rtl" class="d-grid gap-3">
        {{ typography("Daily audit checklist", variant="section-title") }}
        <p class="lead mb-0">Every shift begins with a clear review of key signals and reporting safety.</p>
        <p class="mb-0 text-body-secondary">The summary refreshes at <strong>UTC 07:00</strong>, then open items are reviewed in order.</p>
        <ul class="list-unstyled mb-0">
          <li>Confirm service status, recovery plan, and deployment owner.</li>
          <li>Log governance decisions before any additional rollout.</li>
        </ul>
      </div>
    {% endset %}

    {{ render_rtl_example(
      "typography-rtl",
      "RTL",
      typography_rtl_arabic,
      typography_rtl_hebrew,
      typography_rtl_english,
      preview_class="moo-example__preview--narrow"
    ) }}
  </div>

  {{ render_reference(
    "For more text patterns, see the",
    "https://getbootstrap.com/docs/5.3/utilities/text/",
    "Bootstrap Text utilities documentation"
  ) }}

{% endblock %}
