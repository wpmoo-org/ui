{% extends "layouts/catalog.html.jinja" %}
{% from "components/button.html.jinja" import button %}
{% from "components/spinner.html.jinja" import spinner %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header with context %}

{% block title %}Spinner — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Spinner",
    "Show an indeterminate loading state using the same loader-circle icon as the reference, spun with Bootstrap's own animation."
  ) }}

  <div class="moo-component-examples">
    {% set default %}
      {{ spinner() }}
    {% endset %}
    {{ render_example(
      "default",
      "Default",
      "A rotating <code>loader-circle</code> icon built from <code>currentColor</code>, so it adapts to any theme without extra CSS.",
      default
    ) }}

    {% set small %}
      {{ spinner(size="sm") }}
    {% endset %}
    {{ render_example(
      "small",
      "Small",
      "Set <code>size=\"sm\"</code> to use inside compact contexts like buttons.",
      small
    ) }}

    {% set in_button %}
      <div class="d-flex gap-2">
        {{ button("Loading...", loading=true, disabled=true) }}
        {{ button("Please wait", variant="outline", loading=true, disabled=true) }}
      </div>
    {% endset %}
    {{ render_example(
      "button",
      "Button",
      "Set <code>loading=true</code> on a button to swap its leading icon for a spinner.",
      in_button
    ) }}

    {% set rtl_arabic %}
      <div class="d-flex align-items-center gap-2" dir="rtl">
        {{ spinner(aria_label="جارٍ تحميل التحديثات") }}
        <span>جارٍ تحميل التحديثات</span>
      </div>
    {% endset %}

    {% set rtl_hebrew %}
      <div class="d-flex align-items-center gap-2" dir="rtl">
        {{ spinner(aria_label="טוען עדכונים") }}
        <span>טוען עדכונים</span>
      </div>
    {% endset %}

    {% set rtl_english %}
      <div class="d-flex align-items-center gap-2" dir="rtl">
        {{ spinner(aria_label="Loading updates") }}
        <span>Loading updates</span>
      </div>
    {% endset %}

    {{ render_rtl_example(
      "spinner",
      "Use the same loading row translated exactly into Arabic, Hebrew, and English; the spinner itself has no directional geometry, so only the label and its order change.",
      rtl_arabic,
      rtl_hebrew,
      rtl_english
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's source behavior and reduced-motion handling, see the",
    "https://getbootstrap.com/docs/5.3/components/spinners/",
    "Bootstrap Spinners documentation"
  ) }}

{% endblock %}
