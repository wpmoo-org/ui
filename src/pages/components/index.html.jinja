{% extends "layouts/catalog.html.jinja" %}
{% from "components/badge.html.jinja" import badge %}
{% from "components/button.html.jinja" import button %}
{% from "components/card.html.jinja" import card %}
{% from "components/dropdown_menu.html.jinja" import dropdown, dropdown_divider, dropdown_header, dropdown_item %}
{% from "components/input.html.jinja" import input %}
{% from "components/input_group.html.jinja" import input_group, input_group_text %}
{% from "components/separator.html.jinja" import separator %}
{% from "components/typography.html.jinja" import typography %}
{% from "includes/component-previews.html.jinja" import component_preview %}
{% from "includes/doc-toc.html.jinja" import render_doc_toc %}
{% from "includes/page-header.html.jinja" import render_page_header with context %}
{% from "includes/page-navigation.html.jinja" import render_section_page_actions, render_section_page_pagination %}

{% block title %}Components — Moo UI{% endblock %}

{% set component_descriptions = {
  "button": "Trigger actions with Bootstrap buttons shaped to the Moo visual language.",
  "button-group": "Join related actions into one compact control surface.",
  "card": "Group content, metadata, and actions inside a flexible surface.",
  "typography": "Keep headings, support copy, and inline code consistent.",
  "kbd": "Show keyboard input in clear surrounding instructions.",
  "input": "Capture single-line text with native form-control behavior.",
  "textarea": "Capture longer messages with the same field contract.",
  "input-group": "Attach text, shortcuts, and actions to a field.",
  "select": "Let users choose from a native option list.",
  "dropdown-menu": "Collect secondary actions in a Bootstrap dropdown.",
  "badge": "Mark counts, labels, and compact statuses.",
  "avatar": "Represent people, teams, or accounts.",
  "navigation": "Group static destinations for sidebars and sections.",
  "separator": "Separate content with horizontal and vertical rules.",
  "skeleton": "Show a loading placeholder while real content arrives.",
  "sidebar": "Compose a collapsible app shell navigation from ready parts.",
  "close-button": "Dismiss alerts, dialogs, and other transient content.",
  "alert": "Surface a contextual message with an icon, title, and action.",
  "breadcrumb": "Show the current page's location within a hierarchy.",
  "pagination": "Navigate a series of related content across multiple pages.",
  "progress": "Show the completion progress of a task as a slim bar.",
  "table": "Display rows and columns of related data.",
  "checkbox": "Toggle a single option on or off.",
  "radio-group": "Choose exactly one option from a set.",
  "switch": "Toggle a setting on or off.",
  "spinner": "Show an indeterminate loading state.",
  "accordion": "Reveal one section of content at a time.",
  "tabs": "Switch between related views in the same space.",
  "collapsible": "Toggle the visibility of a section of content."
} %}

{% block content %}
  <div class="moo-doc-layout">
    <article class="moo-doc-page">
      {{ render_page_header(
        "Components",
        "Browse the Bootstrap-native primitives that make up the Moo UI shell.",
        id="catalog",
        actions=render_section_page_actions("components", site_pages, root_path)
      ) }}

      <section class="moo-catalog__dashboard" aria-label="Catalog filters">
        <div class="moo-catalog__toolbar">
          {% call input_group() %}
            {{ input(
              aria_label="Filter components",
              id="catalog-search",
              type="search",
              placeholder="Filter components..."
            ) }}
            {{ input_group_text(render_icon("search", "inline-start")) }}
          {% endcall %}
          {% call dropdown("All catalog", align="end", extra_class="moo-catalog__status-menu", caret=true) %}
            {{ dropdown_item("All catalog", active=true, attrs='data-moo-catalog-section-filter="all"') }}
            {{ dropdown_item("Components", attrs='data-moo-catalog-section-filter="components"') }}
            {{ dropdown_item("Utilities", attrs='data-moo-catalog-section-filter="utilities"') }}
          {% endcall %}
          {% call dropdown("View", align="end", extra_class="moo-catalog__toolbar-menu", caret=true) %}
            {{ dropdown_header("Catalog view") }}
            {{ dropdown_item("Components", href="#components", active=true, icon="blocks") }}
            {{ dropdown_item("Utilities", href="#utilities", icon="sparkles") }}
            {{ dropdown_divider() }}
            {{ dropdown_item("Bootstrap references", href="https://getbootstrap.com/docs/5.3/", icon="book-open") }}
          {% endcall %}
        </div>

        {{ separator(extra_class="my-4") }}

        <section aria-labelledby="components" data-moo-catalog-section="components">
          {{ typography("Components", variant="section-title", id="components") }}
          <div class="moo-catalog__grid" id="components-grid">
            {% for component in catalog | sort(attribute="label") %}
              {% call card(extra_class="h-100 moo-catalog__app-card moo-catalog__showcase-card", body_class="d-grid gap-4") %}
                <div class="moo-catalog__showcase-preview">
                  {{ component_preview(component.slug, root_path) }}
                </div>
                <div>
                  <h2 class="h5 mb-2">
                    <a class="stretched-link text-body text-decoration-none" href="{{ site_href("components/" ~ component.slug ~ ".html", root_path) }}">{{ component.label }}</a>
                  </h2>
                  <p class="text-body-secondary mb-0">
                    {{ component_descriptions.get(component.slug, "Bootstrap-native component primitive.") }}
                  </p>
                </div>
              {% endcall %}
            {% endfor %}
          </div>
        </section>

        <section class="mt-5" aria-labelledby="utilities" data-moo-catalog-section="utilities">
          {{ typography("Utilities", variant="section-title", id="utilities") }}
          <div class="moo-catalog__grid moo-catalog__grid--compact" id="utilities-grid">
            {% for utility in utilities %}
              {% call card(extra_class="h-100 moo-catalog__app-card", body_class="d-grid gap-3") %}
                <div class="d-flex align-items-start justify-content-between gap-3">
                  <span class="moo-catalog__app-icon" aria-hidden="true">
                    {{ render_icon("sparkles", "inline-start") }}
                  </span>
                  {{ badge("Ready", variant="outline") }}
                </div>
                <div>
                  <h2 class="h5 mb-2">{{ utility.label }}</h2>
                  <p class="text-body-secondary mb-0">
                    Reusable behavior that supports the component catalog without becoming a component.
                  </p>
                </div>
                <div>
                  {{ button(
                    "Open",
                    variant="outline",
                    size="sm",
                    element="a",
                    href=site_href("utils/" ~ utility.slug ~ ".html", root_path)
                  ) }}
                </div>
              {% endcall %}
            {% endfor %}
          </div>
        </section>
      </section>

      {{ render_section_page_pagination("components", site_pages, root_path) }}
    </article>

    {{ render_doc_toc([
      {"id": "components", "label": "Components"}
    ]) }}
  </div>
{% endblock %}
