{% extends "layouts/catalog.html.jinja" %}
{% from "components/badge.html.jinja" import badge %}
{% from "components/table.html.jinja" import table, table_row_actions %}
{% from "components/dropdown_menu.html.jinja" import dropdown_item, dropdown_divider %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Table — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Table",
    "Display related rows and columns with Bootstrap's native, responsive table markup."
  ) }}

  <div class="moo-component-examples">
    {% set basic %}
      {{ table(
        ["Request", "Owner", "Status", "SLA"],
        [
          ["Partner agreement", "Mira Kaya", badge("Pending", variant="warning"), "2h 12m"],
          ["Compliance review", "Noah Demir", badge("Ready", variant="outline"), "4h 05m"],
          ["Workspace access", "Lena Aras", badge("Done", variant="success"), "Closed"]
        ],
        align=["", "", "", "end"],
        caption="Customer service desk queue at a glance.",
        row_header=true
      ) }}
    {% endset %}
    {{ render_example(
      "basic",
      "Basic",
      "Compose statuses from the ready Badge macro; right-align the numeric column.",
      basic,
      preview_class="moo-example__preview--medium"
    ) }}

    {% set footer %}
      {{ table(
        ["Line item", "Amount"],
        [["Portal seats", "$240"], ["Storage add-on", "$36"], ["Credit", "-$20"]],
        footer=["Total", "$256"],
        align=["", "end"],
        row_header=true
      ) }}
    {% endset %}
    {{ render_example(
      "footer",
      "Footer",
      "Pass <code>footer</code> for a summary row that closes out a usage ledger.",
      footer,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set actions %}
      {% set web_actions %}
        {% call table_row_actions(aria_label="Open actions for Web frontend") %}
          {{ dropdown_item("View logs") }}
          {{ dropdown_item("Redeploy") }}
          {{ dropdown_divider() }}
          {{ dropdown_item("Roll back", destructive=true) }}
        {% endcall %}
      {% endset %}
      {% set api_actions %}
        {% call table_row_actions(aria_label="Open actions for API gateway") %}
          {{ dropdown_item("View logs") }}
          {{ dropdown_item("Redeploy") }}
          {{ dropdown_divider() }}
          {{ dropdown_item("Roll back", destructive=true) }}
        {% endcall %}
      {% endset %}
      {% set worker_actions %}
        {% call table_row_actions(aria_label="Open actions for Batch worker") %}
          {{ dropdown_item("View logs") }}
          {{ dropdown_item("Redeploy") }}
          {{ dropdown_divider() }}
          {{ dropdown_item("Roll back", destructive=true) }}
        {% endcall %}
      {% endset %}
      {{ table(
        ["Deployment", "Status", "Actions"],
        [
          ["Web frontend", badge("Live", variant="success"), web_actions],
          ["API gateway", badge("Rolling out", variant="warning"), api_actions],
          ["Batch worker", badge("Failed", variant="destructive"), worker_actions]
        ],
        align=["", "", "end"],
        row_header=true
      ) }}
    {% endset %}
    {{ render_example(
      "actions",
      "Actions",
      "A row actions column composed from the ready table_row_actions() trigger and the standalone Dropdown Menu macros.",
      actions,
      preview_class="moo-example__preview--medium"
    ) }}

    {% set compact %}
      {{ table(
        ["Workspace ID", "Workspace", "Plan", "Requests"],
        [
          ["m00-portal", "Moo Portal", "Growth", "18"],
          ["m01-partners", "Partner Desk", "Business", "9"],
          ["m02-billing", "Billing Hub", "Starter", "4"],
          ["m03-support", "Support Lab", "Trial", "2"]
        ],
        align=["", "", "", "end"],
        row_ids=["m00-portal", "m01-partners", "m02-billing", "m03-support"],
        striped=true,
        hover=true,
        small=true,
        caption="Compact admin usage rows for a support team.",
        caption_top=true,
        row_header=true
      ) }}
    {% endset %}
    {{ render_example(
      "compact",
      "Compact, striped, and hoverable",
      "Bootstrap's own <code>striped</code>, <code>hover</code>, and <code>small</code> modifiers combine freely for denser, scannable rows.",
      compact,
      preview_class="moo-example__preview--medium"
    ) }}

    {% set rtl_arabic %}
      <div dir="rtl">
        {{ table(
          ["التكرار", "المالك", "الحالة", "الوقت المقدر"],
          [
            ["مراجعة العميل", "محمد", badge("معلق", variant="warning"), "6h 40m"],
            ["إصدار الفاتورة", "سارة", badge("جاهز", variant="outline"), "2h 11m"],
            ["وصول المنصة", "ليلى", badge("مكتمل", variant="success"), "مغلق"]
          ],
          align=["", "", "", "end"],
          row_header=true
        ) }}
      </div>
    {% endset %}

    {% set rtl_hebrew %}
      <div dir="rtl">
        {{ table(
          ["בקשה", "אחראי", "סטטוס", "זמן משוער"],
          [
            ["סקירת לקוח", "מיכאל", badge("ממתין", variant="warning"), "6h 40m"],
            ["הפקת חשבונית", "סערה", badge("מוכן", variant="outline"), "2h 11m"],
            ["גישה לפלטפורמה", "לירון", badge("בוצע", variant="success"), "סגור"]
          ],
          align=["", "", "", "end"],
          row_header=true
        ) }}
      </div>
    {% endset %}

    {% set rtl_english %}
      <div dir="rtl">
        {{ table(
          ["Request", "Owner", "Status", "SLA"],
          [
            ["Customer review", "Michael", badge("Pending", variant="warning"), "6h 40m"],
            ["Invoice build", "Sara", badge("Ready", variant="outline"), "2h 11m"],
            ["Platform access", "Liron", badge("Done", variant="success"), "Closed"]
          ],
          align=["", "", "", "end"],
          row_header=true
        ) }}
      </div>
    {% endset %}

    {{ render_rtl_example(
      "table",
      "Use one compact queue summary table in Arabic, Hebrew, and English.",
      rtl_arabic,
      rtl_hebrew,
      rtl_english,
      preview_class="moo-example__preview--narrow"
    ) }}
  </div>

  <p class="text-body-secondary">
    Need sorting, filtering, or pagination on top of this? That calls for a dedicated Data Table
    component built on top of this Table; it isn't part of this catalog yet.
  </p>

  {{ render_reference(
    "For Bootstrap's source behavior and contextual row/cell variants, see the",
    "https://getbootstrap.com/docs/5.3/content/tables/",
    "Bootstrap Tables documentation"
  ) }}

{% endblock %}
