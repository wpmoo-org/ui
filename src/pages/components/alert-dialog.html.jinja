{% extends "layouts/catalog.html.jinja" %}
{% from "components/alert_dialog.html.jinja" import alert_dialog, alert_dialog_header %}
{% from "components/dialog.html.jinja" import dialog_footer %}
{% from "components/button.html.jinja" import button %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header with context %}

{% block title %}Alert Dialog — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Alert Dialog",
    "A modal dialog that interrupts the user with important content and expects a response, built on Dialog's static-backdrop option."
  ) }}

  <div class="moo-component-examples">
    {% set basic %}
      {{ button("Discard draft", variant="outline", dialog_target="alert-dialog-basic") }}
      {% call alert_dialog("alert-dialog-basic", describedby="alert-dialog-basic-description") %}
        {{ alert_dialog_header(
          "alert-dialog-basic",
          "Discard this draft invoice?",
          "Any line items you have entered will be lost. This cannot be undone."
        ) }}
        {% call dialog_footer() %}
          {{ button("Cancel", variant="outline", dismiss="modal") }}
          {{ button("Discard", dismiss="modal") }}
        {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "basic",
      "Basic",
      "A title, description, and Cancel/Continue-style actions; the backdrop and Escape key are both disabled.",
      basic
    ) }}

    {% set small %}
      {{ button("Leave without saving", variant="outline", dialog_target="alert-dialog-small") }}
      {% call alert_dialog("alert-dialog-small", size="sm", describedby="alert-dialog-small-description") %}
        {{ alert_dialog_header(
          "alert-dialog-small",
          "Leave without saving?",
          "Your changes to this record will not be kept."
        ) }}
        {% call dialog_footer() %}
          {{ button("Cancel", variant="outline", dismiss="modal") }}
          {{ button("Leave", dismiss="modal") }}
        {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "small",
      "Small",
      "size=\"sm\" reuses Dialog's existing modal-sm class for compact confirmations.",
      small
    ) }}

    {% set small_media %}
      {{ button("Stop import", variant="outline", dialog_target="alert-dialog-small-media") }}
      {% call alert_dialog("alert-dialog-small-media", size="sm", describedby="alert-dialog-small-media-description") %}
        {{ alert_dialog_header(
          "alert-dialog-small-media",
          "Stop this import?",
          "Rows that have not finished processing will stay queued for the next run.",
          icon="circle-alert"
        ) }}
        {% call dialog_footer() %}
          {{ button("Keep running", variant="outline", dismiss="modal") }}
          {{ button("Stop import", dismiss="modal") }}
        {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "small-media",
      "Small with media",
      "Use the compact size with a small icon when a short confirmation needs extra signal.",
      small_media
    ) }}

    {% set media %}
      {{ button("Pause sync", variant="outline", dialog_target="alert-dialog-media") }}
      {% call alert_dialog("alert-dialog-media", describedby="alert-dialog-media-description") %}
        {{ alert_dialog_header(
          "alert-dialog-media",
          "Pause nightly synchronization?",
          "New records will wait in the import queue until the next manual run.",
          icon="cloud-off"
        ) }}
        {% call dialog_footer() %}
          {{ button("Keep running", variant="outline", dismiss="modal") }}
          {{ button("Pause sync", dismiss="modal") }}
        {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "media",
      "Media",
      "Pass an icon name to <code>alert_dialog_header()</code> for confirmations that benefit from a small visual cue.",
      media
    ) }}

    {% set destructive %}
      {{ button("Delete customer", variant="outline", dialog_target="alert-dialog-destructive") }}
      {% call alert_dialog("alert-dialog-destructive", describedby="alert-dialog-destructive-description") %}
        {{ alert_dialog_header(
          "alert-dialog-destructive",
          "Delete this customer record?",
          "This removes their profile and order history permanently."
        ) }}
        {% call dialog_footer() %}
          {{ button("Cancel", variant="outline", dismiss="modal") }}
          {{ button("Delete", variant="destructive", dismiss="modal") }}
        {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "destructive",
      "Destructive action",
      "Pair the outline Cancel button with a destructive-variant action for irreversible operations.",
      destructive
    ) }}

    {% set rtl_arabic %}
      <div dir="rtl">
        {{ button("حذف بيانات العميل", variant="outline", dialog_target="alert-dialog-rtl") }}
        {% call alert_dialog("alert-dialog-rtl", direction="rtl", describedby="alert-dialog-rtl-description") %}
          {{ alert_dialog_header(
            "alert-dialog-rtl",
            "هل تريد حذف بيانات هذا العميل؟",
            "سيؤدي هذا إلى إزالة ملفه الشخصي وسجل الطلبات نهائيًا."
          ) }}
          {% call dialog_footer() %}
            {{ button("إلغاء", variant="outline", dismiss="modal") }}
            {{ button("حذف", variant="destructive", dismiss="modal") }}
          {% endcall %}
        {% endcall %}
      </div>
    {% endset %}

    {% set rtl_hebrew %}
      <div dir="rtl">
        {{ button("מחיקת נתוני לקוח", variant="outline", dialog_target="alert-dialog-rtl-hebrew") }}
        {% call alert_dialog("alert-dialog-rtl-hebrew", direction="rtl", describedby="alert-dialog-rtl-hebrew-description") %}
          {{ alert_dialog_header(
            "alert-dialog-rtl-hebrew",
            "למחוק את נתוני הלקוח האלה?",
            "פעולה זו מסירה את פרופיל הלקוח ואת היסטוריית ההזמנות לצמיתות."
          ) }}
          {% call dialog_footer() %}
            {{ button("ביטול", variant="outline", dismiss="modal") }}
            {{ button("מחיקה", variant="destructive", dismiss="modal") }}
          {% endcall %}
        {% endcall %}
      </div>
    {% endset %}

    {% set rtl_english %}
      <div dir="rtl">
        {{ button("Delete customer data", variant="outline", dialog_target="alert-dialog-rtl-english") }}
        {% call alert_dialog("alert-dialog-rtl-english", direction="rtl", describedby="alert-dialog-rtl-english-description") %}
          {{ alert_dialog_header(
            "alert-dialog-rtl-english",
            "Delete this customer data?",
            "This removes the customer profile and order history permanently."
          ) }}
          {% call dialog_footer() %}
            {{ button("Cancel", variant="outline", dismiss="modal") }}
            {{ button("Delete", variant="destructive", dismiss="modal") }}
          {% endcall %}
        {% endcall %}
      </div>
    {% endset %}

    {{ render_rtl_example(
      "alert-dialog",
      "Use tabs to compare Arabic, Hebrew, and English alert dialogs inside the same right-to-left layout.",
      rtl_arabic,
      rtl_hebrew,
      rtl_english,
      preview_class="moo-example__preview--fit"
    ) }}
  </div>

  {{ render_reference(
    "For the underlying Modal plugin options, focus management, and accessibility notes, see the",
    "https://getbootstrap.com/docs/5.3/components/modal/#static-backdrop",
    "Bootstrap Modal documentation"
  ) }}

{% endblock %}
