{% extends "layouts/catalog.html.jinja" %}
{% from "components/collapsible.html.jinja" import collapsible %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Collapsible — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Collapsible",
    "Toggle the visibility of a section of content using the ready Button macro and Bootstrap's Collapse plugin."
  ) }}

  <div class="moo-component-examples">
    {% set basic %}
      {{ collapsible(
        "collapsible-basic",
        "Order #4189",
        "Placed on March 14 &middot; 3 items &middot; Standard shipping (5-7 days).",
        trigger_aria_label="Toggle order details"
      ) }}
    {% endset %}
    {{ render_example(
      "basic",
      "Basic",
      "The trigger is an icon-only Button; set <code>open=true</code> to start expanded.",
      basic
    ) }}

    {% set open %}
      {{ collapsible(
        "collapsible-open",
        "Notification settings",
        "Email alerts are on. Push notifications are off.",
        trigger_aria_label="Toggle notification settings",
        open=true
      ) }}
    {% endset %}
    {{ render_example(
      "open",
      "Open by default",
      "Set <code>open=true</code> to start expanded and mark the trigger's <code>aria-expanded</code> accordingly.",
      open
    ) }}

    {% set rtl %}
      <div dir="rtl">
        {{ collapsible(
          "collapsible-rtl",
          "الطلب #4189",
          "تم الطلب في 14 مارس &middot; 3 عناصر &middot; شحن قياسي (5-7 أيام).",
          trigger_aria_label="إظهار تفاصيل الطلب"
        ) }}
      </div>
    {% endset %}
    {{ render_example(
      "rtl",
      "Right-to-left layout",
      "The title and trigger swap sides without mirrored custom CSS.",
      rtl
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's Collapse plugin behavior and accessibility notes, see the",
    "https://getbootstrap.com/docs/5.3/components/collapse/",
    "Bootstrap Collapse documentation"
  ) }}

{% endblock %}
