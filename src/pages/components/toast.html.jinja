{% extends "layouts/catalog.html.jinja" %}
{% from "components/button.html.jinja" import button %}
{% from "components/toast.html.jinja" import toast, toast_container %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header with context %}
{% block title %}Toast — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Toast",
    "Surface short operational updates that should stay visible long enough to be noticed."
  ) }}

  <div class="moo-component-examples">
    {% set basic %}
      {{ button("Show approval toast", variant="outline", toast_target="toast-basic") }}
      {% call toast_container(placement="bottom-end") %}
        {{ toast("toast-basic", "Workflow", "Backup completed successfully.", timestamp="just now") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "basic",
      "Basic",
      "Hook a toast to a Button with <code>toast_target</code>; Bootstrap handles the reveal/close behavior in the shared catalog wiring and toast macro.",
      basic
    ) }}

    {% set stacking %}
      <div class="d-flex flex-wrap gap-2">
        {{ button("Show first alert", variant="outline", toast_target="toast-stack-1") }}
        {{ button("Show second alert", variant="outline", toast_target="toast-stack-2") }}
      </div>
      {% call toast_container(placement="bottom-end") %}
        {{ toast("toast-stack-1", "Ingestion", "Invoice set synced.", timestamp="1 min ago") }}
        {{ toast("toast-stack-2", "Ingestion", "Receipt batch synced.", timestamp="just now") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "stacking",
      "Stacking",
      "Stack multiple follow-up events in one container so they retain spacing and timing.",
      stacking
    ) }}

    {% set persistent %}
      {{ button("Show persistent toast", variant="outline", toast_target="toast-persistent") }}
      {% call toast_container(placement="bottom-end") %}
        {{ toast("toast-persistent", "Queue", "Sync timed out — retry from the operations panel.", autohide=false) }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "persistent",
      "No autohide",
      "Set <code>autohide=false</code> for actions that require manual acknowledgement.",
      persistent
    ) }}

    {% set rtl_arabic %}
      <div class="d-inline-flex" dir="rtl">
        {{ button("إظهار تنبيه المراجعة", variant="outline", icon_start="circle-alert", toast_target="toast-rtl-arabic") }}
        {% call toast_container(placement="bottom-end") %}
          {{ toast("toast-rtl-arabic", "المراجعة", "تمت مراجعة الطلب بنجاح.", timestamp="الآن") }}
        {% endcall %}
      </div>
    {% endset %}

    {% set rtl_hebrew %}
      <div class="d-inline-flex" dir="rtl">
        {{ button("הצג התראת סקירה", variant="outline", icon_start="circle-alert", toast_target="toast-rtl-hebrew") }}
        {% call toast_container(placement="bottom-end") %}
          {{ toast("toast-rtl-hebrew", "סקירה", "הבקשה אושרה בהצלחה.", timestamp="כרגע") }}
        {% endcall %}
      </div>
    {% endset %}

    {% set rtl_english %}
      <div class="d-inline-flex" dir="rtl">
        {{ button("Show review toast", variant="outline", icon_start="circle-alert", toast_target="toast-rtl-english") }}
        {% call toast_container(placement="bottom-end") %}
          {{ toast("toast-rtl-english", "Review", "The request passed review.", timestamp="now") }}
        {% endcall %}
      </div>
    {% endset %}

    {{ render_rtl_example(
      "toast",
      "Compare Arabic, Hebrew, and English toast actions inside a compact RTL shell.",
      rtl_arabic,
      rtl_hebrew,
      rtl_english
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's Toast plugin options, stacking, and accessibility notes, see the",
    "https://getbootstrap.com/docs/5.3/components/toasts/",
    "Bootstrap Toasts documentation"
  ) }}

{% endblock %}
