{% extends "layouts/catalog.html.jinja" %}
{% from "components/button.html.jinja" import button %}
{% from "components/button_group.html.jinja" import button_group %}
{% from "includes/page-header.html.jinja" import render_page_header %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example %}

{% block title %}Button — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Buttons",
    "Use Bootstrap button styles for actions in forms, dialogs, and more."
  ) }}

  <div class="moo-component-examples">
    {% set core_variants %}
      {{ button("Primary") }}
      {{ button("Secondary", variant="secondary") }}
      {{ button("Success", variant="success") }}
      {{ button("Danger", variant="destructive") }}
      {{ button("Warning", variant="warning") }}
      {{ button("Info", variant="info") }}
      {{ button("Light", variant="light") }}
      {{ button("Dark", variant="dark") }}
      {{ button("Link", variant="link") }}
    {% endset %}
    {{ render_example(
      "core-variants",
      "Variants",
      "Choose a Bootstrap variant for the action's emphasis. Keep the meaning in the label too; color alone is not enough for assistive technology.",
      core_variants
    ) }}

    {% set semantic_elements %}
      {{ button("Link", variant="outline", element="a", href="#button-tags") }}
      {{ button("Button") }}
      {{ button("Submit", element="input", type="submit") }}
      {{ button("Reset", element="input", variant="secondary", type="reset") }}
    {% endset %}
    {{ render_example(
      "semantic-elements",
      "Button tags",
      "Bootstrap button classes work on <code>&lt;button&gt;</code>, <code>&lt;a&gt;</code>, and <code>&lt;input&gt;</code>. Use the element that matches navigation, an action, or form submission.",
      semantic_elements
    ) }}

    {% set disabled_states %}
      {{ button("Awaiting approval", variant="secondary", disabled=true) }}
      {{ button("Archived guide", variant="outline", disabled=true) }}
    {% endset %}
    {{ render_example(
      "disabled-states",
      "Disabled state",
      "The native <code>disabled</code> attribute removes interaction and hover states from buttons. Prefer a real button for unavailable actions; disabled links need extra accessibility handling.",
      disabled_states
    ) }}

    {% set icon_actions %}
      {{ button("Create team space", icon_start="plus") }}
      {{ button("Invite collaborators", variant="outline", icon_end="arrow-right") }}
      {{ button("", variant="secondary", size="icon", aria_label="Pin dashboard", icon_start="pin") }}
    {% endset %}
    {{ render_example(
      "icon-actions",
      "Icons",
      "Inline icons reinforce a visible label. Icon-only buttons need an <code>aria-label</code>; the decorative SVG stays hidden from assistive technology.",
      icon_actions
    ) }}

    {% set outline_variants %}
      {{ button("Primary", variant="outline-primary") }}
      {{ button("Secondary", variant="outline") }}
      {{ button("Success", variant="outline-success") }}
      {{ button("Danger", variant="outline-danger") }}
    {% endset %}
    {{ render_example(
      "outline-variants",
      "Outline buttons",
      "Use <code>btn-outline-*</code> when a filled surface is too strong. The variant keeps its semantic color on the border and hover state.",
      outline_variants
    ) }}

    {% set button_size_examples %}
      <div class="d-flex flex-column align-items-center gap-3">
        <div class="d-flex flex-wrap align-items-center justify-content-center gap-2">
          {{ button("Small button", variant="outline", size="xs") }}
          {{ button("", variant="outline", size="icon-xs", aria_label="Add small button", icon_start="plus") }}
        </div>
        <div class="d-flex flex-wrap align-items-center justify-content-center gap-2">
          {{ button("Small button", variant="outline", size="sm") }}
          {{ button("", variant="outline", size="icon-sm", aria_label="Add small button", icon_start="plus") }}
        </div>
        <div class="d-flex flex-wrap align-items-center justify-content-center gap-2">
          {{ button("Button", variant="outline") }}
          {{ button("", variant="outline", size="icon", aria_label="Add button", icon_start="plus") }}
        </div>
        <div class="d-flex flex-wrap align-items-center justify-content-center gap-2">
          {{ button("Large button", variant="outline", size="lg") }}
          {{ button("", variant="outline", size="icon-lg", aria_label="Add large button", icon_start="plus") }}
        </div>
      </div>
    {% endset %}
    {{ render_example(
      "button-sizes",
      "Sizes",
      "Use Bootstrap's small and large scales when control density changes. Moo's icon sizes keep square controls aligned with the same scale.",
      button_size_examples
    ) }}

    {% set full_width_actions %}
      <div class="d-grid gap-2">
        {{ button("Create workspace", extra_class="w-100") }}
        {{ button("Invite collaborators", variant="outline", extra_class="w-100") }}
      </div>
    {% endset %}
    {{ render_example(
      "full-width-actions",
      "Block buttons",
      "<code>d-grid gap-2</code> stacks actions with consistent spacing, while <code>w-100</code> lets each button fill the available width. This is a layout choice, not a new button variant.",
      full_width_actions
    ) }}

    {% set toggle_state %}
      {{ button("Pin this view", variant="outline", toggle=true) }}
    {% endset %}
    {{ render_example(
      "toggle-state",
      "Toggle states",
      "<code>data-bs-toggle=\"button\"</code> asks Bootstrap's button plugin to switch the active state on click. <code>aria-pressed=\"false\"</code> exposes the initial state to assistive technology; use <code>true</code> together with <code>active</code> when preselecting it.",
      toggle_state
    ) }}

    {% set rtl_preview %}
      <div class="d-flex flex-wrap gap-2" dir="rtl">
        {{ button("إنشاء مساحة", icon_start="plus") }}
        {{ button("فتح التفاصيل", variant="outline", icon_end="arrow-right") }}
      </div>
    {% endset %}
    {{ render_example(
      "rtl-preview",
      "Right-to-left layout",
      "<code>dir=\"rtl\"</code> lets the browser resolve logical start and end spacing for Arabic and other RTL content. Use semantic icon positions instead of manually flipping the SVG.",
      rtl_preview
    ) }}

    {% set related_button_group %}
      <div class="d-flex flex-column align-items-center gap-3">
        {% call button_group("Related actions") %}
          {{ button("Previous", variant="outline") }}
          {{ button("Next", variant="outline") }}
        {% endcall %}
      </div>
    {% endset %}
    {% set related_button_group_description %}
      Group adjacent actions that belong together. See the <a href="../components/button-group.html">Button Group</a> component for more patterns.
    {% endset %}
    {{ render_example(
      "related-button-group",
      "Button group",
      related_button_group_description,
      related_button_group
    ) }}
  </div>

  {{ render_reference(
    "For more detailed information, see the",
    "https://getbootstrap.com/docs/5.3/components/buttons/",
    "Bootstrap Buttons documentation"
  ) }}

{% endblock %}
