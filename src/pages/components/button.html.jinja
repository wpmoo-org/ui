{% extends "layouts/catalog.html.jinja" %}
{% from "components/button.html.jinja" import button, button_sizes, button_variants %}
{% from "components/example.html.jinja" import render_example %}

{% block title %}Button — Moo UI{% endblock %}

{% block content %}
  <header class="moo-component-header">
    <h1 class="display-5 fw-semibold">Button</h1>
    <p class="lead text-body-secondary mb-0">
      Trigger actions and guide navigation with clear, familiar controls.
    </p>
  </header>

  <div class="moo-component-examples">
    {% set core_variants %}
      {{ button("Launch workspace") }}
      {{ button("Save draft", variant="secondary") }}
      {{ button("Compare changes", variant="outline") }}
      {{ button("Open details", variant="ghost") }}
      {{ button("Remove access", variant="destructive") }}
      {{ button("Read release notes", variant="link") }}
    {% endset %}
    {{ render_example(
      "core-variants",
      "Core variants",
      "Choose emphasis that matches the consequence of the action.",
      core_variants
    ) }}

    {% set semantic_elements %}
      {{ button("Open handbook", variant="outline") }}
      {{ button("Submit request", element="input", type="submit") }}
      {{ button("Reset filters", variant="secondary", type="reset") }}
    {% endset %}
    {{ render_example(
      "semantic-elements",
      "Semantic elements",
      "Use the native element that matches the control's real behavior.",
      semantic_elements
    ) }}

    {% set disabled_states %}
      {{ button("Awaiting approval", variant="secondary", disabled=true) }}
      {{ button("Archived guide", variant="outline", disabled=true) }}
    {% endset %}
    {{ render_example(
      "disabled-states",
      "Unavailable actions",
      "Disabled controls remain legible while leaving the interaction path.",
      disabled_states
    ) }}

    {% set icon_actions %}
      {{ button("Create team space", icon_start="plus") }}
      {{ button("Invite collaborators", variant="outline", icon_end="arrow-right") }}
      {{ button("", variant="secondary", size="icon", aria_label="Pin dashboard", icon_start="pin") }}
    {% endset %}
    {{ render_example(
      "icon-actions",
      "Actions with icons",
      "Icons reinforce meaning without replacing an accessible name.",
      icon_actions
    ) }}

    {% set bootstrap_colors %}
      {{ button("Deploy safely", variant="success") }}
      {{ button("Check forecast", variant="warning") }}
      {{ button("Inspect signal", variant="info") }}
      {{ button("Use light mode", variant="light") }}
      {{ button("Switch contrast", variant="dark") }}
    {% endset %}
    {{ render_example(
      "bootstrap-colors",
      "Bootstrap colors",
      "Keep familiar semantic colors when the interface needs a broader signal.",
      bootstrap_colors
    ) }}

    {% set outline_variants %}
      {{ button("Start preview", variant="outline-primary") }}
      {{ button("Mark complete", variant="outline-success") }}
      {{ button("Revoke invitation", variant="outline-danger") }}
    {% endset %}
    {{ render_example(
      "outline-variants",
      "Outline variants",
      "Use a lighter visual weight without losing the action's meaning.",
      outline_variants
    ) }}

    {% set button_size_examples %}
      <div class="d-flex flex-column align-items-center gap-3 mx-auto">
        <div class="d-flex flex-wrap align-items-center justify-content-center gap-2">
          {{ button("Quick note", variant="outline", size="xs") }}
          {{ button("", variant="outline", size="icon-xs", aria_label="Add quick note", icon_start="plus") }}
        </div>
        <div class="d-flex flex-wrap align-items-center justify-content-center gap-2">
          {{ button("Compact action", variant="outline", size="sm") }}
          {{ button("", variant="outline", size="icon-sm", aria_label="Add compact action", icon_start="plus") }}
        </div>
        <div class="d-flex flex-wrap align-items-center justify-content-center gap-2">
          {{ button("Standard action", variant="outline") }}
          {{ button("", variant="outline", size="icon", aria_label="Add standard action", icon_start="plus") }}
        </div>
        <div class="d-flex flex-wrap align-items-center justify-content-center gap-2">
          {{ button("Expanded action", variant="outline", size="lg") }}
          {{ button("", variant="outline", size="icon-lg", aria_label="Add expanded action", icon_start="plus") }}
        </div>
      </div>
    {% endset %}
    {{ render_example(
      "button-sizes",
      "Sizes",
      "Match control height to the density of the surrounding interface.",
      button_size_examples
    ) }}

    {% set full_width_actions %}
      <div class="d-grid gap-2">
        {{ button("Create workspace", extra_class="w-100") }}
        {{ button("Invite collaborators", variant="outline", extra_class="w-100") }}
      </div>
    {% endset %}
    {{ render_example(
      "full-width-actions",
      "Full-width actions",
      "Stack primary paths when the available width is narrow or focused.",
      full_width_actions
    ) }}

    {% set toggle_state %}
      {{ button("Pin this view", variant="outline", toggle=true) }}
    {% endset %}
    {{ render_example(
      "toggle-state",
      "Toggle state",
      "Bootstrap manages the pressed state without a component-specific script.",
      toggle_state
    ) }}

    {% set rtl_preview %}
      <div class="d-flex flex-wrap gap-2" dir="rtl">
        {{ button("إنشاء مساحة", icon_start="plus") }}
        {{ button("فتح التفاصيل", variant="outline", icon_end="arrow-right") }}
      </div>
    {% endset %}
    {{ render_example(
      "rtl-preview",
      "Right-to-left layout",
      "Logical spacing keeps labels and icons coherent in either direction.",
      rtl_preview
    ) }}
  </div>

  <section class="moo-component-reference" aria-labelledby="button-reference-title">
    <h2 class="h3" id="button-reference-title">API Reference</h2>
    <p class="text-body-secondary">
      Use the Jinja macro to emit Bootstrap-native markup with Moo UI defaults.
    </p>
    <pre class="overflow-x-auto rounded-3 border bg-body-tertiary p-3"><code>button(
  label,
  variant="default",
  size="default",
  element="button",
  type="button",
  href="",
  disabled=false,
  aria_label="",
  icon_start="",
  icon_end="",
  extra_class="",
  toggle=false
)</code></pre>
    <div class="table-responsive">
      <table class="table align-middle">
        <thead>
          <tr>
            <th scope="col">Parameter</th>
            <th scope="col">Value</th>
            <th scope="col">HTML or behavior</th>
          </tr>
        </thead>
        <tbody>
          {% for variant_name, variant_class in button_variants.items() %}
          <tr>
            {% if loop.first %}
              <th scope="rowgroup" rowspan="{{ button_variants | length }}"><code>variant</code></th>
            {% endif %}
            <td>
              <code>{{ variant_name }}</code>
              {% if variant_name == "default" %}<span class="text-body-secondary">(default)</span>{% endif %}
            </td>
            <td>
              <code>btn {{ variant_class }}</code>
              {% if variant_name == "ghost" %}<span class="badge text-bg-secondary">Moo</span>{% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
        <tbody>
          {% for size_name, size_config in button_sizes.items() %}
          <tr>
            {% if loop.first %}
              <th scope="rowgroup" rowspan="{{ button_sizes | length }}"><code>size</code></th>
            {% endif %}
            <td>
              <code>{{ size_name }}</code>
              {% if size_name == "default" %}<span class="text-body-secondary">(default)</span>{% endif %}
            </td>
            <td>
              <code>btn{% if size_config["class"] %} {{ size_config["class"] }}{% endif %}</code>
              {% if size_name in ("xs", "icon", "icon-xs", "icon-sm", "icon-lg") %}<span class="badge text-bg-secondary">Moo</span>{% endif %}
              — {{ size_config["dimensions"] }}
            </td>
          </tr>
          {% endfor %}
        </tbody>
        <tbody>
          <tr>
            <th scope="row"><code>element</code></th>
            <td><code>button</code> (default), <code>a</code>, <code>input</code></td>
            <td>Preserves the native action, navigation, or form-control element.</td>
          </tr>
          <tr>
            <th scope="row"><code>type</code></th>
            <td><code>button</code> (default), <code>submit</code>, <code>reset</code></td>
            <td>Emitted for <code>button</code> and <code>input</code> elements.</td>
          </tr>
          <tr>
            <th scope="row"><code>href</code></th>
            <td>URL string</td>
            <td>Emitted only for an enabled <code>a</code> element.</td>
          </tr>
          <tr>
            <th scope="row"><code>disabled</code></th>
            <td><code>false</code> (default) or <code>true</code></td>
            <td>Uses native <code>disabled</code>; anchors omit <code>href</code> and receive <code>aria-disabled="true"</code> plus <code>tabindex="-1"</code>.</td>
          </tr>
          <tr>
            <th scope="row"><code>aria_label</code></th>
            <td>Accessible-name string</td>
            <td>Required when the visible <code>label</code> is empty.</td>
          </tr>
          <tr>
            <th scope="row"><code>icon_start</code>, <code>icon_end</code></th>
            <td><code>plus</code>, <code>arrow-right</code>, <code>pin</code></td>
            <td>Emits a decorative SVG with logical icon spacing.</td>
          </tr>
          <tr>
            <th scope="row"><code>extra_class</code></th>
            <td>Class string</td>
            <td>Adds Bootstrap utilities such as <code>w-100</code> or <code>rounded-pill</code>.</td>
          </tr>
          <tr>
            <th scope="row"><code>toggle</code></th>
            <td><code>false</code> (default) or <code>true</code></td>
            <td>Adds <code>data-bs-toggle="button"</code> and <code>aria-pressed="false"</code> to a button.</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="text-body-secondary mt-3 mb-0">
      <strong>Deferred:</strong> Loading visuals remain deferred until Spinner;
      joined controls remain deferred until Button Group.
    </p>
  </section>
{% endblock %}
