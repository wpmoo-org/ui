{% extends "layouts/catalog.html.jinja" %}
{% from "components/button.html.jinja" import button %}
{% from "components/button_group.html.jinja" import button_group %}
{% from "includes/page-header.html.jinja" import render_page_header %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}

{% block title %}Button — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Buttons",
    "Use Bootstrap button styles for reliable production actions: publish, review, and move work forward."
  ) }}

  <div class="moo-component-examples">
    {% set core_variants %}
      <div class="d-flex flex-column align-items-center gap-2">
        <div class="d-flex flex-wrap justify-content-center gap-2">
          {{ button("Publish") }}
          {{ button("Reschedule", variant="secondary") }}
          {{ button("Mark approved", variant="success") }}
          {{ button("Needs review", variant="warning") }}
        </div>
        <div class="d-flex flex-wrap justify-content-center gap-2">
          {{ button("Reject", variant="destructive") }}
          {{ button("Open workspace", variant="outline") }}
          {{ button("More options", variant="ghost") }}
        </div>
      </div>
    {% endset %}
    {{ render_example(
      "core-variants",
      "Variants",
      "Choose a variant for the action's consequence: default for normal operations, success for confirmation, and destructive for irreversible steps.",
      core_variants
    ) }}

    {% set semantic_elements %}
      <div class="d-flex flex-wrap gap-2">
        {{ button("Open runbook", variant="outline", element="a", href="#button-tags") }}
        {{ button("Submit approval", type="submit") }}
        {{ button("Clear queue", element="input", type="reset") }}
      </div>
    {% endset %}
    {{ render_example(
      "semantic-elements",
      "Button tags",
      "Use the right element for the context: links for navigation, buttons for actions, and input buttons for form workflows.",
      semantic_elements
    ) }}

    {% set outline_variants %}
      <div class="d-flex flex-wrap gap-2">
        {{ button("Keep draft", variant="outline") }}
        {{ button("Archive queue", variant="outline-primary") }}
        {{ button("Mark blocked", variant="outline-danger") }}
      </div>
    {% endset %}
    {{ render_example(
      "outline-variants",
      "Outlined actions",
      "Outlined styles stay visible without taking visual priority from primary actions.",
      outline_variants
    ) }}

    {% set icon_actions %}
      <div class="d-flex flex-wrap gap-2">
        {{ button("Create task", icon_start="user-plus") }}
        {{ button("Continue process", variant="outline", icon_end="arrow-right") }}
        {{ button("", variant="secondary", size="icon", aria_label="Pin workspace", icon_start="pin") }}
      </div>
    {% endset %}
    {{ render_example(
      "icon-actions",
      "Icons",
      "Keep icon placement explicit: leading icons clarify operation type, trailing icons indicate direction.",
      icon_actions
    ) }}

    {% set button_states %}
      <div class="d-flex flex-wrap gap-2">
        {{ button("Read-only mode", variant="outline", disabled=true) }}
        {{ button("Retry", variant="secondary", disabled=true) }}
        {{ button("Saving", variant="outline", loading=true, disabled=true) }}
      </div>
    {% endset %}
    {{ render_example(
      "button-states",
      "States",
      "Use disabled and loading states to make temporary limits and async work obvious to operators.",
      button_states
    ) }}

    {% set button_size_examples %}
      <div class="d-flex flex-column gap-2">
        <div class="d-flex flex-wrap align-items-center gap-2">
          {{ button("XS", variant="outline", size="xs") }}
          {{ button("", variant="outline", size="icon-xs", aria_label="Create micro task", icon_start="plus") }}
        </div>
        <div class="d-flex flex-wrap align-items-center gap-2">
          {{ button("Small", variant="outline", size="sm") }}
          {{ button("", variant="outline", size="icon-sm", aria_label="Create small task", icon_start="plus") }}
        </div>
        <div class="d-flex flex-wrap align-items-center gap-2">
          {{ button("Default", variant="outline") }}
          {{ button("", variant="outline", size="icon", aria_label="Create task", icon_start="plus") }}
        </div>
        <div class="d-flex flex-wrap align-items-center gap-2">
          {{ button("Large", variant="outline", size="lg") }}
          {{ button("", variant="outline", size="icon-lg", aria_label="Create large task", icon_start="plus") }}
        </div>
      </div>
    {% endset %}
    {{ render_example(
      "button-sizes",
      "Sizes",
      "Size options should reflect component density. Matching text and icon buttons keeps alignment steady when a toolbar grows or shrinks.",
      button_size_examples
    ) }}

    {% set full_width_actions %}
      <div class="d-grid gap-2">
        {{ button("Create workspace", extra_class="w-100") }}
        {{ button("Invite collaborators", variant="outline", extra_class="w-100") }}
      </div>
    {% endset %}
    {{ render_example(
      "full-width-actions",
      "Block buttons",
      "<code>d-grid gap-2</code> stacks actions with consistent spacing, while <code>w-100</code> lets each button fill the available width. This is a layout choice, not a new button variant.",
      full_width_actions
    ) }}

    {% set toggle_state %}
      {{ button("Follow this ticket", variant="outline", toggle=true) }}
    {% endset %}
    {{ render_example(
      "toggle-state",
      "Toggle states",
      "<code>data-bs-toggle=\"button\"</code> keeps the pressed state synchronized. <code>aria-pressed=\"false\"</code> marks an initial inactive state.",
      toggle_state
    ) }}

    {% set related_button_group %}
      <div class="d-flex flex-column align-items-start gap-3">
        {% call button_group("Queue actions") %}
          {{ button("Previous", variant="outline") }}
          {{ button("Next", variant="outline") }}
        {% endcall %}
      </div>
    {% endset %}
    {% set related_button_group_description %}
      Group adjacent actions that belong together. See the <a href="../components/button-group.html">Button Group</a> component for broader toolbar behavior.
    {% endset %}
    {{ render_example(
      "related-button-group",
      "Button group",
      related_button_group_description,
      related_button_group
    ) }}

    {% set rtl_arabic %}
      <div class="d-inline-flex gap-2" dir="rtl">
        {{ button("حفظ", variant="outline", icon_start="save") }}
        {{ button("نشر", variant="success", icon_start="send") }}
      </div>
    {% endset %}

    {% set rtl_hebrew %}
      <div class="d-inline-flex gap-2" dir="rtl">
        {{ button("שמור", variant="outline", icon_start="save") }}
        {{ button("פרסם", variant="success", icon_start="send") }}
      </div>
    {% endset %}

    {% set rtl_english %}
      <div class="d-inline-flex gap-2" dir="rtl">
        {{ button("Save", variant="outline", icon_start="save") }}
        {{ button("Publish", variant="success", icon_start="send") }}
      </div>
    {% endset %}

    {{ render_rtl_example(
      "button",
      "Use tabs to compare Arabic, Hebrew, and English button actions in RTL layout.",
      rtl_arabic,
      rtl_hebrew,
      rtl_english
    ) }}
  </div>

  {{ render_reference(
    "For more detailed information, see the",
    "https://getbootstrap.com/docs/5.3/components/buttons/",
    "Bootstrap Buttons documentation"
  ) }}

{% endblock %}
