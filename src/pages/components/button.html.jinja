{% extends "layouts/catalog.html.jinja" %}
{% from "components/button.html.jinja" import button, button_sizes, button_variants %}
{% from "components/example.html.jinja" import render_example %}

{% block title %}Button — Moo UI{% endblock %}

{% block content %}
  <header class="moo-component-header">
    <h1 class="display-5 fw-semibold">Button</h1>
    <p class="lead text-body-secondary mb-0">
      Trigger actions and guide navigation with clear, familiar controls.
    </p>
  </header>

  <div class="moo-component-examples">
    {% set core_variants %}
      {{ button("Launch workspace") }}
      {{ button("Save draft", variant="secondary") }}
      {{ button("Compare changes", variant="outline") }}
      {{ button("Open details", variant="ghost") }}
      {{ button("Remove access", variant="destructive") }}
      {{ button("Read release notes", variant="link") }}
    {% endset %}
    {{ render_example(
      "core-variants",
      "Core variants",
      "Choose emphasis that matches the consequence of the action.",
      core_variants
    ) }}

    {% set semantic_elements %}
      {{ button("Open handbook", variant="outline") }}
      {{ button("Submit request", element="input", type="submit") }}
      {{ button("Reset filters", variant="secondary", type="reset") }}
    {% endset %}
    {{ render_example(
      "semantic-elements",
      "Semantic elements",
      "Use the native element that matches the control's real behavior.",
      semantic_elements
    ) }}

    {% set disabled_states %}
      {{ button("Awaiting approval", variant="secondary", disabled=true) }}
      {{ button("Archived guide", variant="outline", disabled=true) }}
    {% endset %}
    {{ render_example(
      "disabled-states",
      "Unavailable actions",
      "Disabled controls remain legible while leaving the interaction path.",
      disabled_states
    ) }}

    {% set icon_actions %}
      {{ button("Create team space", icon_start="plus") }}
      {{ button("Invite collaborators", variant="outline", icon_end="arrow-right") }}
      {{ button("", variant="secondary", size="icon", aria_label="Pin dashboard", icon_start="pin") }}
    {% endset %}
    {{ render_example(
      "icon-actions",
      "Actions with icons",
      "Icons reinforce meaning without replacing an accessible name.",
      icon_actions
    ) }}

    {% set bootstrap_colors %}
      {{ button("Deploy safely", variant="success") }}
      {{ button("Check forecast", variant="warning") }}
      {{ button("Inspect signal", variant="info") }}
      {{ button("Use light mode", variant="light") }}
      {{ button("Switch contrast", variant="dark") }}
    {% endset %}
    {{ render_example(
      "bootstrap-colors",
      "Bootstrap colors",
      "Keep familiar semantic colors when the interface needs a broader signal.",
      bootstrap_colors
    ) }}

    {% set outline_variants %}
      {{ button("Start preview", variant="outline-primary") }}
      {{ button("Mark complete", variant="outline-success") }}
      {{ button("Revoke invitation", variant="outline-danger") }}
    {% endset %}
    {{ render_example(
      "outline-variants",
      "Outline variants",
      "Use a lighter visual weight without losing the action's meaning.",
      outline_variants
    ) }}

    {% set button_size_examples %}
      <div class="d-flex flex-column align-items-center gap-3">
        <div class="d-flex flex-wrap align-items-center justify-content-center gap-2">
          {{ button("Quick note", variant="outline", size="xs") }}
          {{ button("", variant="outline", size="icon-xs", aria_label="Add quick note", icon_start="plus") }}
        </div>
        <div class="d-flex flex-wrap align-items-center justify-content-center gap-2">
          {{ button("Compact action", variant="outline", size="sm") }}
          {{ button("", variant="outline", size="icon-sm", aria_label="Add compact action", icon_start="plus") }}
        </div>
        <div class="d-flex flex-wrap align-items-center justify-content-center gap-2">
          {{ button("Standard action", variant="outline") }}
          {{ button("", variant="outline", size="icon", aria_label="Add standard action", icon_start="plus") }}
        </div>
        <div class="d-flex flex-wrap align-items-center justify-content-center gap-2">
          {{ button("Expanded action", variant="outline", size="lg") }}
          {{ button("", variant="outline", size="icon-lg", aria_label="Add expanded action", icon_start="plus") }}
        </div>
      </div>
    {% endset %}
    {{ render_example(
      "button-sizes",
      "Sizes",
      "Match control height to the density of the surrounding interface.",
      button_size_examples
    ) }}

    {% set full_width_actions %}
      <div class="d-grid gap-2">
        {{ button("Create workspace", extra_class="w-100") }}
        {{ button("Invite collaborators", variant="outline", extra_class="w-100") }}
      </div>
    {% endset %}
    {{ render_example(
      "full-width-actions",
      "Full-width actions",
      "Stack primary paths when the available width is narrow or focused.",
      full_width_actions
    ) }}

    {% set toggle_state %}
      {{ button("Pin this view", variant="outline", toggle=true) }}
    {% endset %}
    {{ render_example(
      "toggle-state",
      "Toggle state",
      "Bootstrap manages the pressed state without a component-specific script.",
      toggle_state
    ) }}

    {% set rtl_preview %}
      <div class="d-flex flex-wrap gap-2" dir="rtl">
        {{ button("إنشاء مساحة", icon_start="plus") }}
        {{ button("فتح التفاصيل", variant="outline", icon_end="arrow-right") }}
      </div>
    {% endset %}
    {{ render_example(
      "rtl-preview",
      "Right-to-left layout",
      "Logical spacing keeps labels and icons coherent in either direction.",
      rtl_preview
    ) }}
  </div>

  <section class="moo-component-reference" aria-labelledby="button-reference-title">
    <h2 class="h3" id="button-reference-title">API Reference</h2>
    <p class="text-body-secondary">
      Use Bootstrap button classes directly. Copy exact rendered HTML from each
      example's View markup panel.
    </p>
    <div class="table-responsive">
      <table class="table align-middle">
        <thead>
          <tr>
            <th scope="col">Class or attribute</th>
            <th scope="col">Use</th>
            <th scope="col">Behavior</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row"><code>btn-primary</code></th>
            <td>Primary action</td>
            <td>Uses Moo foreground and surface tokens.</td>
          </tr>
          <tr>
            <th scope="row"><code>btn-secondary</code> / <code>btn-outline-secondary</code></th>
            <td>Secondary action</td>
            <td>Matches the compact shadcn-like neutral treatment.</td>
          </tr>
          <tr>
            <th scope="row"><code>btn-ghost</code> / <code>btn-danger</code> / <code>btn-link</code></th>
            <td>Special intent</td>
            <td>Covers low-emphasis, destructive, and text-link actions.</td>
          </tr>
          <tr>
            <th scope="row"><code>btn-xs</code>, <code>btn-sm</code>, <code>btn-lg</code></th>
            <td>Text button density</td>
            <td>Maps to the 24 / 28 / 32 / 36 px height scale.</td>
          </tr>
          <tr>
            <th scope="row"><code>btn-icon</code> variants</th>
            <td>Icon-only controls</td>
            <td>Keep controls square and require an accessible name.</td>
          </tr>
          <tr>
            <th scope="row"><code>disabled</code></th>
            <td>Unavailable action</td>
            <td>Uses native disabled behavior with Moo runtime contrast tokens.</td>
          </tr>
          <tr>
            <th scope="row"><code>data-bs-toggle="button"</code></th>
            <td>Pressed state</td>
            <td>Uses Bootstrap's native toggle behavior.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
{% endblock %}
