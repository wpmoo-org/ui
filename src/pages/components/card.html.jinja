{% extends "layouts/catalog.html.jinja" %}
{% from "components/button.html.jinja" import button %}
{% from "components/card.html.jinja" import card %}
{% from "components/example.html.jinja" import render_example %}

{% block title %}Card — Moo UI{% endblock %}

{% block content %}
  <header class="moo-component-header">
    <h1 class="display-5 fw-semibold">Card</h1>
    <p class="lead text-body-secondary mb-0">
      Group related content on one quiet, self-contained surface.
    </p>
  </header>

  <div class="moo-component-examples">
    {% set content_card %}
      {% call card(style="width: 22rem;") %}
        <p class="card-text mb-0">A single content section works when the card holds one short, self-contained note.</p>
      {% endcall %}
    {% endset %}
    {{ render_example(
      "card-content",
      "Content only",
      "Start with one padded body when the card holds a single block of content.",
      content_card
    ) }}

    {% set basic_card %}
      {% call card(
        "Team workspace",
        "Everyone you invite can open and edit the shared boards.",
        style="width: 22rem;"
      ) %}
        <p class="card-text mb-0">Four members joined in the last update. Manage who stays from the access panel whenever the team changes.</p>
      {% endcall %}
    {% endset %}
    {{ render_example(
      "card-basic",
      "Header and content",
      "Add a header with a title and description above the content section.",
      basic_card
    ) }}

    {% set actions_card %}
      {% set actions_footer %}
        {{ button("Discard", variant="outline") }}
        {{ button("Save changes") }}
      {% endset %}
      {% call card(
        "Discard changes?",
        "Your recent edits to this board are still unsaved.",
        footer=actions_footer,
        style="width: 22rem;",
        footer_class="justify-content-end"
      ) %}
        <p class="card-text mb-0">Saving keeps the current layout for everyone. Discarding restores the last published version.</p>
      {% endcall %}
    {% endset %}
    {{ render_example(
      "card-actions",
      "Footer actions",
      "Place related actions in a footer using finished Button controls.",
      actions_card
    ) }}

    {% set rtl_card %}
      {% set rtl_footer %}
        {{ button("حفظ") }}
      {% endset %}
      {% call card(
        "مساحة العمل",
        "يمكن لكل شخص تدعوه فتح اللوحات المشتركة وتحريرها.",
        footer=rtl_footer,
        style="width: 22rem;",
        dir="rtl",
        footer_class="justify-content-end"
      ) %}
        <p class="card-text mb-0">انضم أربعة أعضاء في آخر تحديث. يمكنك إدارة من يبقى من لوحة الوصول.</p>
      {% endcall %}
    {% endset %}
    {{ render_example(
      "card-rtl",
      "Right-to-left layout",
      "The same structure stays coherent when the writing direction flips.",
      rtl_card
    ) }}
  </div>

  <section class="moo-component-reference" aria-labelledby="card-reference-title">
    <h2 class="h3" id="card-reference-title">API Reference</h2>
    <p class="text-body-secondary">
      Use Bootstrap card classes directly. Copy exact rendered HTML from each
      example's View markup panel.
    </p>
    <div class="table-responsive">
      <table class="table align-middle">
        <thead>
          <tr>
            <th scope="col">Class</th>
            <th scope="col">Use</th>
            <th scope="col">Behavior</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row"><code>card</code></th>
            <td>Root surface</td>
            <td>Owns the border, radius, shadow, background, and vertical rhythm.</td>
          </tr>
          <tr>
            <th scope="row"><code>card-header</code></th>
            <td>Title area</td>
            <td>Stacks a title and description with no divider or fill.</td>
          </tr>
          <tr>
            <th scope="row"><code>card-title</code> / <code>card-subtitle</code></th>
            <td>Heading and description</td>
            <td>Renders a semibold title and a muted secondary line.</td>
          </tr>
          <tr>
            <th scope="row"><code>card-body</code> / <code>card-text</code></th>
            <td>Main content</td>
            <td>Holds the padded content section and its copy.</td>
          </tr>
          <tr>
            <th scope="row"><code>card-footer</code></th>
            <td>Action row</td>
            <td>Aligns finished controls in a row with no divider.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
{% endblock %}
