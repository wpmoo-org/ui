{% extends "layouts/catalog.html.jinja" %}
{% from "components/button.html.jinja" import button %}
{% from "components/card.html.jinja" import card %}
{% from "includes/page-header.html.jinja" import render_page_header %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}

{% block title %}Card — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Card",
    "Group related content into a compact, structured surface with predictable spacing."
  ) }}

  <div class="moo-component-examples">
    {% set content_card %}
      {% call card() %}
        A short note can stay compact by using a single card body without a separate header or footer.
      {% endcall %}
    {% endset %}
    {{ render_example(
      "card-content",
      "Content only",
      "Use a bare <code>card</code> for short notes, hints, and status messages where one section is enough.",
      content_card,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set summary_card %}
      {% call card(
        "Incident recap",
        "Recent checks and owner notes for the active release."
      ) %}
        <div class="d-grid gap-2">
          <div class="d-flex justify-content-between">
            <span class="text-body-secondary">Service</span>
            <span class="fw-medium">Payments</span>
          </div>
          <div class="d-flex justify-content-between">
            <span class="text-body-secondary">Status</span>
            <span>In review</span>
          </div>
        </div>
      {% endcall %}
    {% endset %}
    {{ render_example(
      "card-summary",
      "Header and content",
      "Use <code>card-title</code> and <code>card-subtitle</code> to pair concise copy with focused body rows.",
      summary_card,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set actions_card %}
      {% set actions_footer %}
        {{ button("Keep for next pass", variant="outline") }}
        {{ button("Mark complete") }}
      {% endset %}
      {% call card(
        "Operational checkpoint",
        "Publish the summary only when all verification steps are confirmed.",
        footer=actions_footer,
        footer_class="justify-content-end"
      ) %}
        <div class="small d-grid gap-2">
          <div class="d-flex justify-content-between">
            <span class="text-body-secondary">Checks</span>
            <span>4 / 5</span>
          </div>
          <div class="d-flex justify-content-between">
            <span class="text-body-secondary">Approver</span>
            <span>Ops lead</span>
          </div>
        </div>
      {% endcall %}
    {% endset %}
    {{ render_example(
      "card-actions",
      "Action footer",
      "Keep actions in <code>card-footer</code> so copy and controls remain within one clear command surface.",
      actions_card,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set arabic_card %}
      {% call card(
        "الموافقة على الإصدار مطلوبة",
        "تأكيد القائمة قبل فتح نافذة النشر.",
        dir="rtl"
      ) %}
        <div class="d-grid gap-2">
          <div class="d-flex justify-content-between">
            <span class="text-body-secondary">المسؤول</span>
            <span class="fw-medium">مدير الإصدار</span>
          </div>
          <div class="d-flex justify-content-between">
            <span class="text-body-secondary">الحالة</span>
            <span>بانتظار الاعتماد</span>
          </div>
        </div>
      {% endcall %}
    {% endset %}

    {% set hebrew_card %}
      {% call card(
        "נדרש אישור לגרסה",
        "יש לאשר את הרשימה לפני פתיחת חלון הפריסה.",
        dir="rtl"
      ) %}
        <div class="d-grid gap-2">
          <div class="d-flex justify-content-between">
            <span class="text-body-secondary">אחראי</span>
            <span class="fw-medium">מנהל הגרסה</span>
          </div>
          <div class="d-flex justify-content-between">
            <span class="text-body-secondary">סטטוס</span>
            <span>ממתין לאישור</span>
          </div>
        </div>
      {% endcall %}
    {% endset %}

    {% set english_card %}
      {% call card(
        "Release approval needed",
        "Confirm the checklist before the deploy window opens.",
        dir="rtl"
      ) %}
        <div class="d-grid gap-2">
          <div class="d-flex justify-content-between">
            <span class="text-body-secondary">Owner</span>
            <span class="fw-medium">Release manager</span>
          </div>
          <div class="d-flex justify-content-between">
            <span class="text-body-secondary">Status</span>
            <span>Awaiting sign-off</span>
          </div>
        </div>
      {% endcall %}
    {% endset %}

    {{ render_rtl_example(
      "card",
      "Use tabs to compare the same release-approval card translated exactly into Arabic, Hebrew, and English.",
      arabic_card,
      hebrew_card,
      english_card,
      preview_class="moo-example__preview--narrow"
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap-native card semantics and options, see the",
    "https://getbootstrap.com/docs/5.3/components/card/",
    "Bootstrap Card documentation"
  ) }}

{% endblock %}
