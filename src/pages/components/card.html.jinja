{% extends "layouts/catalog.html.jinja" %}
{% from "components/api_reference.html.jinja" import render_api_reference %}
{% from "components/button.html.jinja" import button %}
{% from "components/card.html.jinja" import card %}
{% from "components/example.html.jinja" import render_example %}
{% from "components/typography.html.jinja" import typography %}

{% block title %}Card — Moo UI{% endblock %}

{% block content %}
  <header class="moo-component-header">
    {{ typography("Card", variant="page-title") }}
    {{ typography(
      "Group related content on one quiet, self-contained surface.",
      variant="page-description"
    ) }}
  </header>

  <div class="moo-component-examples">
    {% set content_card %}
      {% call card() %}
        <p class="mb-0">A single content section works when the card holds one short, self-contained note.</p>
      {% endcall %}
    {% endset %}
    {{ render_example(
      "card-content",
      "Content only",
      "Start with one padded body when the card holds a single block of content.",
      content_card,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set basic_card %}
      {% call card(
        "Team workspace",
        "Everyone you invite can open and edit the shared boards."
      ) %}
        <p class="mb-0">Four members joined in the last update. Manage who stays from the access panel whenever the team changes.</p>
      {% endcall %}
    {% endset %}
    {{ render_example(
      "card-basic",
      "Header and content",
      "Add a header with a title and description above the content section.",
      basic_card,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set actions_card %}
      {% set actions_footer %}
        {{ button("Discard", variant="outline") }}
        {{ button("Save changes") }}
      {% endset %}
      {% call card(
        "Discard changes?",
        "Your recent edits to this board are still unsaved.",
        footer=actions_footer,
        footer_class="justify-content-end"
      ) %}
        <p class="mb-0">Saving keeps the current layout for everyone. Discarding restores the last published version.</p>
      {% endcall %}
    {% endset %}
    {{ render_example(
      "card-actions",
      "Footer actions",
      "Place related actions in a footer using finished Button controls.",
      actions_card,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set rtl_card %}
      {% set rtl_footer %}
        {{ button("حفظ") }}
      {% endset %}
      {% call card(
        "مساحة العمل",
        "يمكن لكل شخص تدعوه فتح اللوحات المشتركة وتحريرها.",
        footer=rtl_footer,
        dir="rtl",
        footer_class="justify-content-end"
      ) %}
        <p class="mb-0">انضم أربعة أعضاء في آخر تحديث. يمكنك إدارة من يبقى من لوحة الوصول.</p>
      {% endcall %}
    {% endset %}
    {{ render_example(
      "card-rtl",
      "Right-to-left layout",
      "The same structure stays coherent when the writing direction flips.",
      rtl_card,
      preview_class="moo-example__preview--narrow"
    ) }}
  </div>

  {% set api_rows = [
    {"contract": "card", "use": "Root surface", "behavior": "Owns border, radius, shadow, background, and vertical rhythm."},
    {"contract": "card-header", "use": "Title area", "behavior": "Stacks a title and description with no divider or fill."},
    {"contract": "card-title / card-subtitle", "use": "Heading and description", "behavior": "Renders a semibold title and a muted secondary line."},
    {"contract": "card-body / card-text", "use": "Main content", "behavior": "Holds the padded content section and its copy."},
    {"contract": "card-footer", "use": "Action row", "behavior": "Aligns finished controls in a row with no divider."}
  ] %}
  {{ render_api_reference(
    "card",
    "Use Bootstrap card classes directly. Copy exact rendered HTML from each example's View Code panel.",
    api_rows
  ) }}
{% endblock %}
