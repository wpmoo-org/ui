{% extends "layouts/catalog.html.jinja" %}
{% from "components/switch.html.jinja" import switch %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header with context %}

{% block title %}Switch — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Switch",
    "Activate feature flags and settings with Bootstrap's native form-switch control."
  ) }}

  <div class="moo-component-examples">
    {% set default %}
      <div class="d-grid gap-2">
        {{ switch("switch-default", label="Enable workflow backup window") }}
        {{ switch("switch-checked", label="Enable workflow backup window", checked=true) }}
      </div>
    {% endset %}
    {{ render_example(
      "default",
      "Default",
      "Show the same label with both off and on states when rollout toggles are introduced.",
      default,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set with_description %}
      {{ switch(
        "switch-description",
        label="Background sync",
        description="Keep team data synchronized across all devices after a network reconnect.",
        checked=true
      ) }}
    {% endset %}
    {{ render_example(
      "with-description",
      "With description",
      "Add supporting copy below the label with <code>description</code>.",
      with_description,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set disabled %}
      <div class="d-grid gap-2">
        {{ switch("switch-disabled", label="Force MFA at login", disabled=true) }}
        {{ switch("switch-disabled-checked", label="Force MFA at login", checked=true, disabled=true) }}
      </div>
    {% endset %}
    {{ render_example(
      "disabled",
      "Disabled",
      "Disabled switches lower opacity and drop pointer interaction in both states.",
      disabled,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set invalid %}
      {{ switch("switch-invalid", label="Collect usage analytics", invalid=true) }}
    {% endset %}
    {{ render_example(
      "invalid",
      "Invalid",
      "Set <code>invalid=true</code> to pair with a form's validation state.",
      invalid,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set rtl_arabic %}
      <div class="d-inline-flex" dir="rtl">
        {{ switch("switch-rtl-arabic", label="تفعيل المزامنة الخلفية", checked=true) }}
      </div>
    {% endset %}

    {% set rtl_hebrew %}
      <div class="d-inline-flex" dir="rtl">
        {{ switch("switch-rtl-hebrew", label="הפעלת סנכרון רקע", checked=true) }}
      </div>
    {% endset %}

    {% set rtl_english %}
      <div class="d-inline-flex" dir="rtl">
        {{ switch("switch-rtl-english", label="Enable background sync", checked=true) }}
      </div>
    {% endset %}

    {{ render_rtl_example(
      "switch",
      "RTL",
      rtl_arabic,
      rtl_hebrew,
      rtl_english,
      preview_class="moo-example__preview--narrow"
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's source behavior and the shared form-check family, see the",
    "https://getbootstrap.com/docs/5.3/forms/checks-radios/",
    "Bootstrap Checks and radios documentation"
  ) }}

{% endblock %}
