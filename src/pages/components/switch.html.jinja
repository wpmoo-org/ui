{% extends "layouts/catalog.html.jinja" %}
{% from "components/switch.html.jinja" import switch %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Switch — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Switch",
    "Toggle a setting on or off using Bootstrap's native switch contract."
  ) }}

  <div class="moo-component-examples">
    {% set default %}
      <div class="d-grid gap-2">
        {{ switch("switch-default", label="Auto-lock screen") }}
        {{ switch("switch-checked", label="Auto-lock screen", checked=true) }}
      </div>
    {% endset %}
    {{ render_example(
      "default",
      "Default",
      "Off and on states share the same label contract.",
      default,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set with_description %}
      {{ switch(
        "switch-description",
        label="Background sync",
        description="Keep your data up to date across devices while the app is closed.",
        checked=true
      ) }}
    {% endset %}
    {{ render_example(
      "with-description",
      "With description",
      "Add supporting copy below the label with <code>description</code>.",
      with_description,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set disabled %}
      <div class="d-grid gap-2">
        {{ switch("switch-disabled", label="Two-factor authentication", disabled=true) }}
        {{ switch("switch-disabled-checked", label="Two-factor authentication", checked=true, disabled=true) }}
      </div>
    {% endset %}
    {{ render_example(
      "disabled",
      "Disabled",
      "Disabled switches lower opacity and drop pointer interaction in both states.",
      disabled,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set invalid %}
      {{ switch("switch-invalid", label="Enable analytics tracking", invalid=true) }}
    {% endset %}
    {{ render_example(
      "invalid",
      "Invalid",
      "Set <code>invalid=true</code> to pair with a form's validation state.",
      invalid,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set rtl %}
      <div dir="rtl">
        {{ switch("switch-rtl", label="القفل التلقائي للشاشة") }}
      </div>
    {% endset %}
    {{ render_example(
      "rtl",
      "Right-to-left layout",
      "The input and label swap sides without mirrored custom CSS.",
      rtl,
      preview_class="moo-example__preview--narrow"
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's source behavior and the shared form-check family, see the",
    "https://getbootstrap.com/docs/5.3/forms/checks-radios/",
    "Bootstrap Checks and radios documentation"
  ) }}

{% endblock %}
