{% extends "layouts/catalog.html.jinja" %}
{% from "components/pagination.html.jinja" import pagination, pagination_ellipsis, pagination_item, pagination_next, pagination_prev %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header with context %}

{% block title %}Pagination — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Pagination",
    "Navigate paged results with native Bootstrap pagination controls."
  ) }}

  <div class="moo-component-examples">
    {% set default %}
      {% call pagination() %}
        {{ pagination_prev(label="Previous page") }}
        {{ pagination_item("1") }}
        {{ pagination_item("2", active=true) }}
        {{ pagination_item("3") }}
        {{ pagination_ellipsis() }}
        {{ pagination_next() }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "default",
      "Default",
      "Use page numbers with Previous/Next and an ellipsis for long result sets.",
      default,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set disabled_ends %}
      {% call pagination() %}
        {{ pagination_prev(disabled=true, label="Previous") }}
        {{ pagination_item("1", active=true) }}
        {{ pagination_item("2") }}
        {{ pagination_item("3") }}
        {{ pagination_next(label="Next") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "disabled-ends",
      "Disabled boundary",
      "Keep Previous disabled on the first page while remaining actions stay available.",
      disabled_ends,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set sizes %}
      <div class="d-flex flex-column gap-3">
        {% call pagination(size="sm") %}
          {{ pagination_prev(label="Previous") }}
          {{ pagination_item("1", active=true) }}
          {{ pagination_item("2") }}
          {{ pagination_next(label="Next") }}
        {% endcall %}
        {% call pagination(size="lg") %}
          {{ pagination_prev(label="Previous") }}
          {{ pagination_item("1", active=true) }}
          {{ pagination_item("2") }}
          {{ pagination_next() }}
        {% endcall %}
      </div>
    {% endset %}
    {{ render_example(
      "sizes",
      "Sizes",
      "Use compact and larger controls with Bootstrap size variants when the layout needs density.",
      sizes,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set rtl_arabic %}
      <div dir="rtl">
        {% call pagination() %}
          {{ pagination_prev(label="السابق") }}
          {{ pagination_item("1") }}
          {{ pagination_item("2", active=true) }}
          {{ pagination_item("3") }}
          {{ pagination_ellipsis(label="صفحات إضافية") }}
          {{ pagination_next(label="التالي") }}
        {% endcall %}
      </div>
    {% endset %}

    {% set rtl_hebrew %}
      <div dir="rtl">
        {% call pagination() %}
          {{ pagination_prev(label="הקודם") }}
          {{ pagination_item("1") }}
          {{ pagination_item("2", active=true) }}
          {{ pagination_item("3") }}
          {{ pagination_ellipsis(label="עמודים נוספים") }}
          {{ pagination_next(label="הבא") }}
        {% endcall %}
      </div>
    {% endset %}

    {% set rtl_english %}
      <div dir="rtl">
        {% call pagination() %}
          {{ pagination_prev(label="Previous") }}
          {{ pagination_item("1") }}
          {{ pagination_item("2", active=true) }}
          {{ pagination_item("3") }}
          {{ pagination_ellipsis() }}
          {{ pagination_next(label="Next") }}
        {% endcall %}
      </div>
    {% endset %}

    {{ render_rtl_example(
      "pagination",
      "Use the same page range, active state, and skipped-pages marker across Arabic, Hebrew, and English in RTL direction.",
      rtl_arabic,
      rtl_hebrew,
      rtl_english,
      preview_class="moo-example__preview--narrow"
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's source behavior and sizing variables, see the",
    "https://getbootstrap.com/docs/5.3/components/pagination/",
    "Bootstrap Pagination documentation"
  ) }}

{% endblock %}
