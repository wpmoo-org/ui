{% extends "layouts/catalog.html.jinja" %}
{% from "components/button.html.jinja" import button %}
{% from "components/popover.html.jinja" import popover_dismiss_trigger %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Popover — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Popover",
    "Add compact, contextual details to workflow actions with Bootstrap's native popover behavior."
  ) }}

  <div class="moo-component-examples">
    {% set basic %}
      {{ button(
        "Review update",
        variant="outline",
        popover_title="Routing review",
        popover_content="Approve this request, reassign it, or return it for clarification."
      ) }}
    {% endset %}
    {{ render_example(
      "basic",
      "Basic",
      "Use <code>popover_title</code> and <code>popover_content</code> on a standard button trigger for quick inline context.",
      basic,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set placements %}
      <div class="d-flex flex-wrap gap-2">
        {{ button("Top", variant="outline", popover_content="Keep the action rail visible while reviewing this item.", popover_placement="top") }}
        {{ button("Right", variant="outline", popover_content="Open queue details to the right when space is available.", popover_placement="right") }}
        {{ button("Bottom", variant="outline", popover_content="Show helper text underneath the current control.", popover_placement="bottom") }}
        {{ button("Left", variant="outline", popover_content="Reserve space on the left for this control-heavy view.", popover_placement="left") }}
      </div>
    {% endset %}
    {{ render_example(
      "placements",
      "Placement",
      "Set <code>popover_placement</code> to <code>top</code>, <code>right</code>, <code>bottom</code>, or <code>left</code> to position the popover close to the action.",
      placements,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set rich_content %}
      {{ button(
        "View guidance",
        variant="outline",
        popover_title="Queue notes",
        popover_content="Review <strong>priority rules</strong> and <code>follow-up notes</code> before owners change.",
        popover_html=true
      ) }}
    {% endset %}
    {{ render_example(
      "rich-content",
      "Rich content",
      "Set <code>popover_html=true</code> to format body content. Bootstrap still applies its default sanitizer, so stay with allowlisted tags like <code>&lt;strong&gt;</code> and <code>&lt;code&gt;</code>.",
      rich_content,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set dismiss %}
      {{ popover_dismiss_trigger("Dismiss details", "Click anywhere outside this panel to close it.", title="Dismissible note") }}
    {% endset %}
    {{ render_example(
      "dismiss",
      "Dismiss on next click",
      "Bootstrap only supports the focus-triggered dismiss pattern reliably on an <code>&lt;a&gt;</code> element with <code>tabindex=\"0\"</code>, not a <code>&lt;button&gt;</code>, so this uses the dedicated <code>popover_dismiss_trigger()</code> macro.",
      dismiss,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set disabled %}
      <span class="d-inline-block" tabindex="0" data-bs-toggle="popover" data-bs-trigger="hover focus" data-bs-content="This action is currently unavailable">
        {{ button("Archive", variant="outline", disabled=true) }}
      </span>
    {% endset %}
    {{ render_example(
      "disabled-trigger",
      "Disabled trigger",
      "A <code>disabled</code> control does not receive pointer or focus events, so attach the popover to a focusable <code>&lt;span&gt;</code> wrapper.",
      disabled,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set rtl_arabic %}
      <div dir="rtl">
        {{ button(
          "فتح ملاحظة المراجعة",
          variant="outline",
          size="sm",
          popover_title="ملاحظة المراجعة",
          popover_content="تحقق من هذه الخطوة قبل إرسال الإشعار النهائي.",
          popover_placement="bottom"
        ) }}
      </div>
    {% endset %}

    {% set rtl_hebrew %}
      <div dir="rtl">
        {{ button(
          "פתח הערת ביקורת",
          variant="outline",
          size="sm",
          popover_title="הערת ביקורת",
          popover_content="בדוק את הצעד לפני שליחת ההתרעה הסופית.",
          popover_placement="bottom"
        ) }}
      </div>
    {% endset %}

    {% set rtl_english %}
      <div dir="rtl">
        {{ button(
          "Open review note",
          variant="outline",
          size="sm",
          popover_title="Review note",
          popover_content="Check this step before sending the final notice.",
          popover_placement="bottom"
        ) }}
      </div>
    {% endset %}

    {{ render_rtl_example(
      "popover-rtl",
      "Compare Arabic, Hebrew, and English popover triggers in the same review workflow.",
      rtl_arabic,
      rtl_hebrew,
      rtl_english,
      preview_class="moo-example__preview--narrow"
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's Popover plugin options, positioning, and accessibility notes, see the",
    "https://getbootstrap.com/docs/5.3/components/popovers/",
    "Bootstrap Popovers documentation"
  ) }}

{% endblock %}
