{% extends "layouts/catalog.html.jinja" %}
{% from "components/radio_group.html.jinja" import radio_group %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Radio Group — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Radio Group",
    "Let users choose one option from a related set using native Bootstrap radio controls."
  ) }}

  <div class="moo-component-examples">
    {% set default %}
      {{ radio_group(
        "radio-default",
        "Incident alert channel",
        [
          {"id": "radio-default-email", "label": "Email", "checked": true},
          {"id": "radio-default-sms", "label": "SMS"},
          {"id": "radio-default-webhook", "label": "Webhook"}
        ]
      ) }}
    {% endset %}
    {{ render_example(
      "default",
      "Default",
      "Use one compact set of mutually exclusive options for a common selection workflow.",
      default
    ) }}

    {% set with_description %}
      {{ radio_group(
        "radio-format",
        "Export destination",
        [
          {
            "id": "radio-format-drive",
            "label": "Shared drive",
            "description": "Saves to the operations drive folder.",
            "checked": true
          },
          {
            "id": "radio-format-sftp",
            "label": "SFTP",
            "description": "Available for scheduled sync jobs only."
          }
        ]
      ) }}
    {% endset %}
    {{ render_example(
      "with-description",
      "With description",
      "Show option-level helper text when each choice has a different operational impact.",
      with_description
    ) }}

    {% set disabled %}
      {{ radio_group(
        "radio-disabled",
        "Task completion notification",
        [
          {"id": "radio-disabled-portal", "label": "Team portal", "checked": true},
          {
            "id": "radio-disabled-mobile",
            "label": "Mobile push (temporarily paused)",
            "disabled": true
          }
        ]
      ) }}
    {% endset %}
    {{ render_example(
      "disabled",
      "Disabled",
      "Disable only options that are currently unavailable in the current environment.",
      disabled
    ) }}

    {% set radio_rtl_arabic %}
      <div dir="rtl">
        {{ radio_group(
          "radio-rtl-channel-arabic",
          "قناة التنبيه",
          [
            {"id": "radio-rtl-email-arabic", "label": "البريد الإلكتروني", "checked": true},
            {"id": "radio-rtl-sms-arabic", "label": "رسالة نصية قصيرة"}
          ]
        ) }}
      </div>
    {% endset %}

    {% set radio_rtl_hebrew %}
      <div dir="rtl">
        {{ radio_group(
          "radio-rtl-channel-hebrew",
          "ערוץ התראות",
          [
            {"id": "radio-rtl-email-hebrew", "label": "דוא״ל", "checked": true},
            {"id": "radio-rtl-sms-hebrew", "label": "מסרון"}
          ]
        ) }}
      </div>
    {% endset %}

    {% set radio_rtl_english %}
      <div dir="rtl">
        {{ radio_group(
          "radio-rtl-channel-english",
          "Notification channel",
          [
            {"id": "radio-rtl-email-english", "label": "Email", "checked": true},
            {"id": "radio-rtl-sms-english", "label": "SMS"}
          ]
        ) }}
      </div>
    {% endset %}

    {{ render_rtl_example(
      "radio-group",
      "Choose the same notification channel in Arabic, Hebrew, and English, with RTL layout on each tab.",
      radio_rtl_arabic,
      radio_rtl_hebrew,
      radio_rtl_english
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's source behavior and the shared form-check family, see the",
    "https://getbootstrap.com/docs/5.3/forms/checks-radios/",
    "Bootstrap Checks and radios documentation"
  ) }}

{% endblock %}
