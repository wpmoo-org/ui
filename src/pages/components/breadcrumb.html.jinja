{% extends "layouts/catalog.html.jinja" %}
{% from "components/breadcrumb.html.jinja" import breadcrumb %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header with context %}

{% block title %}Breadcrumb — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Breadcrumb",
    "Indicate the current page's location within a hierarchy using Bootstrap's native breadcrumb list."
  ) }}

  <div class="moo-component-examples">
    {% set current_only %}
      {{ breadcrumb([{"label": "Workspace"}]) }}
    {% endset %}
    {{ render_example(
      "current-only",
      "Current page only",
      "A single item renders as the current, non-linked page.",
      current_only
    ) }}

    {% set trail %}
      {{ breadcrumb([
        {"label": "Workspace", "href": "#"},
        {"label": "Projects", "href": "#"},
        {"label": "Growth dashboard"}
      ]) }}
    {% endset %}
    {{ render_example(
      "trail",
      "Trail",
      "Every item but the last links back up the hierarchy; the last item marks <code>aria-current=\"page\"</code>.",
      trail
    ) }}

    {% set custom_separator %}
      {{ breadcrumb([
        {"label": "Workspace", "href": "#"},
        {"label": "Projects", "href": "#"},
        {"label": "Growth dashboard"}
      ], divider="•") }}
    {% endset %}
    {{ render_example(
      "custom-separator",
      "Custom separator",
      "Swap the divider glyph per instance through Bootstrap's own --bs-breadcrumb-divider custom property.",
      custom_separator
    ) }}

    {% set dropdown_example %}
      {{ breadcrumb([
        {"label": "Workspace", "href": "#"},
        {"label": "Projects", "dropdown_items": [
          {"label": "Projects", "href": "#"},
          {"label": "Reports", "href": "#"},
          {"label": "Automations", "href": "#"}
        ]},
        {"label": "Growth dashboard"}
      ]) }}
    {% endset %}
    {{ render_example(
      "dropdown",
      "Dropdown",
      "Let a middle segment open a menu of sibling sections instead of linking to just one.",
      dropdown_example
    ) }}

    {% set collapsed %}
      {{ breadcrumb([
        {"label": "Workspace", "href": "#"},
        {"ellipsis": true},
        {"label": "Projects", "href": "#"},
        {"label": "Growth dashboard"}
      ]) }}
    {% endset %}
    {{ render_example(
      "collapsed",
      "Collapsed",
      "Mark skipped levels with an ellipsis segment when the full trail would crowd the layout.",
      collapsed
    ) }}

    {% set arabic_breadcrumb %}
      <div dir="rtl">
        {{ breadcrumb([
          {"label": "مساحة العمل", "href": "#"},
          {"label": "المراجعات", "href": "#"},
          {"label": "طلبات اليوم"}
        ]) }}
      </div>
    {% endset %}

    {% set hebrew_breadcrumb %}
      <div dir="rtl">
        {{ breadcrumb([
          {"label": "סביבת עבודה", "href": "#"},
          {"label": "חיוב", "href": "#"},
          {"label": "חשבוניות פתוחות"}
        ]) }}
      </div>
    {% endset %}

    {% set english_breadcrumb %}
      <div dir="rtl">
        {{ breadcrumb([
          {"label": "Workspace", "href": "#"},
          {"label": "Support queue", "href": "#"},
          {"label": "Escalations"}
        ]) }}
      </div>
    {% endset %}

    {{ render_rtl_example(
      "breadcrumb",
      "Use tabs to compare practical breadcrumb trails inside Arabic, Hebrew, and English right-to-left layouts.",
      arabic_breadcrumb,
      hebrew_breadcrumb,
      english_breadcrumb,
      preview_class="moo-example__preview--fit"
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's source behavior and divider customization, see the",
    "https://getbootstrap.com/docs/5.3/components/breadcrumb/",
    "Bootstrap Breadcrumb documentation"
  ) }}

{% endblock %}
