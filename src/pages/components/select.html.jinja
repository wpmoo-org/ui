{% extends "layouts/catalog.html.jinja" %}
{% from "components/select.html.jinja" import select %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Select — Moo UI{% endblock %}

{% set fruit_options = [
  {"value": "", "label": "Select a fruit", "selected": true, "disabled": true},
  {"value": "apple", "label": "Apple"},
  {"value": "banana", "label": "Banana"},
  {"value": "blueberry", "label": "Blueberry"},
  {"value": "grapes", "label": "Grapes"},
  {"value": "pineapple", "label": "Pineapple"}
] %}

{% set grouped_options = [
  {
    "label": "Fruits",
    "options": [
      {"value": "apple", "label": "Apple"},
      {"value": "banana", "label": "Banana"},
      {"value": "blueberry", "label": "Blueberry"},
      {"value": "grapes", "label": "Grapes"},
      {"value": "pineapple", "label": "Pineapple"}
    ]
  },
  {
    "label": "Vegetables",
    "options": [
      {"value": "aubergine", "label": "Aubergine"},
      {"value": "broccoli", "label": "Broccoli"},
      {"value": "carrot", "label": "Carrot"}
    ]
  }
] %}

{% block content %}
  {{ render_page_header(
    "Select",
    "Display a native select for choosing one option from a compact list."
  ) }}

  <div class="moo-component-examples">
    {% set default %}
      <div class="d-grid gap-2">
        {{ select(
          aria_label="Fruit",
          options=fruit_options
        ) }}
      </div>
    {% endset %}
    {{ render_example(
      "default",
      "Default",
      "Use <code>form-select</code> when the browser-owned menu is enough. Native option menus stay accessible and platform-correct.",
      default,
      "moo-example__preview--narrow"
    ) }}

    {% set groups %}
      <div class="d-grid gap-2">
        {{ select(
          aria_label="Grouped fruit and vegetable options",
          options=grouped_options,
          selected="carrot"
        ) }}
      </div>
    {% endset %}
    {{ render_example(
      "groups",
      "Groups",
      "Use native <code>optgroup</code> sections when a short menu benefits from labels but does not need search or custom actions.",
      groups,
      "moo-example__preview--narrow"
    ) }}

    {% set disabled %}
      <div class="d-grid gap-2">
        {{ select(
          aria_label="Disabled fruit select",
          options=fruit_options,
          disabled=true
        ) }}
      </div>
    {% endset %}
    {{ render_example(
      "disabled",
      "Disabled",
      "Use the native <code>disabled</code> attribute when a choice should remain visible but unavailable.",
      disabled,
      "moo-example__preview--narrow"
    ) }}

    {% set invalid %}
      <div class="moo-field w-100">
        {{ select(
          label="Fruit",
          id="fruit-invalid",
          options=fruit_options,
          invalid=true,
          required=true,
          describedby="fruit-invalid-feedback"
        ) }}
        <div class="invalid-feedback d-block" id="fruit-invalid-feedback">Please select a fruit.</div>
      </div>
    {% endset %}
    {{ render_example(
      "invalid",
      "Invalid",
      "Pair <code>is-invalid</code> with <code>aria-invalid=\"true\"</code> and an error message when validation blocks submission.",
      invalid,
      "moo-example__preview--narrow"
    ) }}

    {% set rtl %}
      <div class="d-grid gap-2" dir="rtl">
        {{ select(
          aria_label="فاكهة",
          options=[
            {"value": "", "label": "اختر فاكهة", "selected": true, "disabled": true},
            {"value": "apple", "label": "تفاح"},
            {"value": "banana", "label": "موز"},
            {"value": "grapes", "label": "عنب"}
          ],
          dir="rtl"
        ) }}
      </div>
    {% endset %}
    {{ render_example(
      "rtl",
      "Right-to-left layout",
      "Use <code>dir=\"rtl\"</code> on the select or parent form when labels and options read right-to-left.",
      rtl,
      "moo-example__preview--narrow"
    ) }}
  </div>

  {{ render_reference(
    "For native select constraints and Sass variables, see the",
    "https://getbootstrap.com/docs/5.3/forms/select/",
    "Bootstrap Select documentation"
  ) }}

{% endblock %}
