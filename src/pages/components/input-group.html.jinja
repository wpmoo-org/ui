{% extends "layouts/catalog.html.jinja" %}
{% from "components/button.html.jinja" import button, icon as button_icon %}
{% from "components/dropdown_menu.html.jinja" import dropdown_item, dropdown_menu %}
{% from "components/input.html.jinja" import input %}
{% from "components/input_group.html.jinja" import input_group, input_group_block_addon, input_group_text %}
{% from "components/kbd.html.jinja" import kbd %}
{% from "components/textarea.html.jinja" import textarea %}
{% from "components/field.html.jinja" import field, field_description %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Input Group — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Input Group",
    "Add icons, text, buttons, and helper content to inputs with Bootstrap's native grouping behavior."
  ) }}

  <div class="moo-component-examples">
    {% set icon_start %}
      {% call field() %}
        {% call input_group() %}
          {{ input_group_text(button_icon("search", "inline-start")) }}
          {{ input(
            id="icon-start-search",
            type="search",
            placeholder="Search queue conversations",
            aria_label="Search queue conversations",
            describedby="icon-start-search-help"
          ) }}
        {% endcall %}
        {{ field_description("icon-start-search-help", "A leading icon keeps search intent visible before users type.") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "icon-start",
      "Icon at start",
      "Place a decorative icon in <code>input-group-text</code> before the input when it clarifies the field's purpose.",
      icon_start,
      "moo-example__preview--narrow"
    ) }}

    {% set icon_end %}
      {% call field() %}
        {% call input_group() %}
          {{ input(
            id="icon-end-password",
            placeholder="Current password",
            aria_label="Current password",
            describedby="icon-end-password-help"
          ) }}
          {{ input_group_text(button_icon("eye-off", "inline-start")) }}
        {% endcall %}
        {{ field_description("icon-end-password-help", "Place trailing actions on the control edge where users expect validation and visibility actions.") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "icon-end",
      "Icon at end",
      "Place the addon after the input when the affordance belongs to the trailing edge.",
      icon_end,
      "moo-example__preview--narrow"
    ) }}

    {% set search_results %}
      {% call input_group() %}
        {{ input_group_text(button_icon("search", "inline-start")) }}
        {{ input(
          aria_label="Search results",
          type="search",
          placeholder="Search..."
        ) }}
        {{ input_group_text("12 results") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "search-results",
      "Search results",
      "Keep a result count in the same surface while the input remains the editable control.",
      search_results,
      "moo-example__preview--narrow"
    ) }}

    {% set text_addons %}
      <div class="d-grid gap-3">
        {% call input_group() %}
          {{ input_group_text("$") }}
          {{ input(aria_label="Amount", placeholder="0.00") }}
          {{ input_group_text("USD") }}
        {% endcall %}
        {% call input_group() %}
          {{ input_group_text("https://") }}
          {{ input(aria_label="Site path", placeholder="example.com") }}
          {{ input_group_text(".com") }}
        {% endcall %}
        {% call input_group() %}
          {{ input(aria_label="Work email", placeholder="Enter your username") }}
          {{ input_group_text("@company.com") }}
        {% endcall %}
        {% call input_group() %}
          {{ textarea(
            aria_label="Message",
            placeholder="Enter your message",
            rows=2
          ) }}
          {% call input_group_block_addon("end") %}
            {{ input_group_text("120 characters left") }}
          {% endcall %}
        {% endcall %}
      </div>
    {% endset %}
    {{ render_example(
      "text-addons",
      "Text",
      "",
      text_addons,
      "moo-example__preview--narrow"
    ) }}

    {% set button_addon %}
      <div class="d-grid gap-3">
        {% call input_group() %}
          {{ input(
            aria_label="Profile URL",
            placeholder="https://example.com/moo",
            readonly=true
          ) }}
          {{ button(
            "",
            variant="ghost",
            size="icon-xs",
            aria_label="Copy profile URL",
            icon_start="copy",
            extra_class="border-0"
          ) }}
        {% endcall %}

        {% call input_group("rounded-pill") %}
          {{ button(
            "",
            variant="ghost",
            size="icon-xs",
            aria_label="About secure URLs",
            icon_start="info",
            extra_class="border-0"
          ) }}
          {{ input_group_text("https://") }}
          {{ input(aria_label="Secure URL") }}
          {{ button(
            "",
            variant="ghost",
            size="icon-xs",
            aria_label="Favorite URL",
            icon_start="star",
            toggle=true,
            extra_class="border-0"
          ) }}
        {% endcall %}

        {% call input_group() %}
          {{ input(
            aria_label="Search",
            type="search",
            placeholder="Type to search..."
          ) }}
          {{ button(
            "Search",
            variant="ghost",
            size="xs",
            extra_class="border-0"
          ) }}
        {% endcall %}
      </div>
    {% endset %}
    {{ render_example(
      "button-addon",
      "Button",
      "",
      button_addon,
      "moo-example__preview--narrow"
    ) }}

    {% set shortcut %}
      {% call input_group() %}
        {{ input(
          aria_label="Command search",
          type="search",
          placeholder="Search commands..."
        ) }}
        {{ input_group_text(kbd("⌘K")) }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "kbd",
      "Kbd",
      "Use a single keyboard hint in the trailing addon; avoid splitting one shortcut into separate visual controls.",
      shortcut,
      "moo-example__preview--narrow"
    ) }}

    {% set dropdown_groups %}
      <div class="d-grid gap-3">
        {% call input_group() %}
          {{ input(
            aria_label="File name",
            placeholder="Enter file name"
          ) }}
          {{ button("", variant="ghost", size="icon-xs", aria_label="More file actions", icon_start="ellipsis", dropdown=true, dropdown_offset="0,8", extra_class="border-0") }}
          {% call dropdown_menu(align="end") %}
            {{ dropdown_item("Settings") }}
            {{ dropdown_item("Copy path") }}
            {{ dropdown_item("Open location") }}
          {% endcall %}
        {% endcall %}
        {% call input_group() %}
          {{ input(
            aria_label="Search query",
            type="search",
            placeholder="Enter search query"
          ) }}
          {{ button(
            "Search In...",
            variant="link",
            size="xs",
            dropdown=true,
            dropdown_offset="0,8"
          ) }}
          {% call dropdown_menu(align="end") %}
            {{ dropdown_item("Documentation") }}
            {{ dropdown_item("Blog Posts") }}
            {{ dropdown_item("Changelog") }}
          {% endcall %}
        {% endcall %}
      </div>
    {% endset %}
    {{ render_example(
      "dropdown",
      "Dropdown",
      "Use an icon-only menu for file actions or a labeled menu when the input action needs a search scope.",
      dropdown_groups,
      "moo-example__preview--narrow"
    ) }}

    {% set block_start %}
      <div class="d-grid gap-3">
        {% call input_group() %}
          {% call input_group_block_addon("start") %}
            {{ input_group_text("Full Name", for_id="block-start-input") }}
          {% endcall %}
          {{ input(
            aria_label="Display name",
            id="block-start-input",
            placeholder="Enter your name"
          ) }}
        {% endcall %}
        {% call input_group() %}
          {% call input_group_block_addon("start") %}
            {{ input_group_text("script.js", for_id="block-start-textarea") }}
          {% endcall %}
          {{ textarea(
            aria_label="Code snippet",
            id="block-start-textarea",
            placeholder="console.log('Hello, world!');",
            rows=3
          ) }}
        {% endcall %}
      </div>
    {% endset %}
    {{ render_example(
      "block-start",
      "Block-start addons",
      "Place a label-like addon above an input or textarea while keeping the control focusable.",
      block_start,
      "moo-example__preview--narrow"
    ) }}

    {% set block_end_input %}
      {% call input_group() %}
        {{ input(
          aria_label="Amount",
          id="block-end-input-control",
          placeholder="Enter amount"
        ) }}
        {% call input_group_block_addon("end") %}
          {{ input_group_text("USD", extra_class="flex-grow-1", for_id="block-end-input-control") }}
        {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "block-end-input",
      "Block-end input",
      "Place a unit below the input when the supporting content belongs to the field.",
      block_end_input,
      "moo-example__preview--narrow"
    ) }}

    {% set block_end_textarea %}
      {% call input_group() %}
        {{ textarea(
          aria_label="Comment",
          id="block-end-textarea-control",
          placeholder="Write a comment..."
        ) }}
        {% call input_group_block_addon("end", "d-flex align-items-center justify-content-between") %}
          {{ input_group_text("0/280", extra_class="flex-grow-1", for_id="block-end-textarea-control") }}
          {{ button("Post", variant="default") }}
        {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "block-end-textarea",
      "Block-end textarea",
      "Keep a counter and action below the textarea when both belong to the field.",
      block_end_textarea,
      "moo-example__preview--narrow"
    ) }}

    {% set custom_input %}
      {% call input_group() %}
        {{ textarea(
          aria_label="Custom message",
          placeholder="Write a message...",
          rows=4
        ) }}
        {% call input_group_block_addon("end", "justify-content-end") %}
          {{ button("Submit") }}
        {% endcall %}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "custom-input",
      "Custom Input",
      "Combine a textarea and action in one Bootstrap input group.",
      custom_input,
      "moo-example__preview--narrow"
    ) }}

    {% set rtl_arabic %}
      <div dir="rtl">
        {% call input_group() %}
          {{ input(
            aria_label="بحث",
            id="input-group-rtl-arabic",
            type="search",
            placeholder="ابحث داخل المحادثة"
          ) }}
          {{ input_group_text(kbd("⌘K")) }}
        {% endcall %}
      </div>
    {% endset %}

    {% set rtl_hebrew %}
      <div dir="rtl">
        {% call input_group() %}
          {{ input(
            aria_label="חיפוש",
            id="input-group-rtl-hebrew",
            type="search",
            placeholder="חפש בצ'אנל"
          ) }}
          {{ input_group_text(kbd("⌘K")) }}
        {% endcall %}
      </div>
    {% endset %}

    {% set rtl_english %}
      <div dir="rtl">
        {% call input_group() %}
          {{ input(
            aria_label="Search",
            id="input-group-rtl-english",
            type="search",
            placeholder="Search the channel"
          ) }}
          {{ input_group_text(kbd("⌘K")) }}
        {% endcall %}
      </div>
    {% endset %}

    {{ render_rtl_example(
      "rtl",
      "Use one compact search control in Arabic, Hebrew, and English to verify mirrored composition inside RTL containers.",
      rtl_arabic,
      rtl_hebrew,
      rtl_english,
      preview_class="moo-example__preview--narrow"
    ) }}
  </div>

  {{ render_reference(
    "For more addon combinations, see the",
    "https://getbootstrap.com/docs/5.3/forms/input-group/",
    "Bootstrap Input group documentation"
  ) }}

{% endblock %}
