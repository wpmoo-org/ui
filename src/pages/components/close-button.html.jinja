{% extends "layouts/catalog.html.jinja" %}
{% from "components/close_button.html.jinja" import close_button %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Close Button — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Close Button",
    "Dismiss alerts, dialogs, and other transient content with Bootstrap's native .btn-close."
  ) }}

  <div class="moo-component-examples">
    {% set default %}
      <div class="d-inline-flex">
        {{ close_button() }}
      </div>
    {% endset %}
    {{ render_example(
      "default",
      "Default",
      "Provide an accessible label; the icon itself carries no visible text.",
      default,
      preview_class="moo-example__preview--fit"
    ) }}

    {% set disabled %}
      <div class="d-inline-flex">
        {{ close_button(disabled=true) }}
      </div>
    {% endset %}
    {{ render_example(
      "disabled",
      "Disabled",
      "Disabled close buttons lower opacity and drop pointer and hover interaction.",
      disabled,
      preview_class="moo-example__preview--fit"
    ) }}

    {% set in_context %}
      <div class="d-flex align-items-start justify-content-between gap-3 p-3 rounded-3 bg-body-secondary" style="width: 20rem;">
        <div>
          <div class="fw-medium">Update available</div>
          <div class="text-body-secondary small">Version 2.1 is ready to install.</div>
        </div>
        {{ close_button() }}
      </div>
    {% endset %}
    {{ render_example(
      "in-context",
      "In context",
      "Pair with a flex row to dismiss a notice, alert, or toast.",
      in_context
    ) }}

    {% set rtl_arabic %}
      <div class="d-inline-flex align-items-start justify-content-between gap-3 p-3 rounded-3 bg-body-secondary" dir="rtl">
        <div>
          <div class="fw-medium">تم تجاهل الحادث</div>
          <div class="text-body-secondary small">تم مسح تنبيه الحادث.</div>
        </div>
        {{ close_button(aria_label="إغلاق") }}
      </div>
    {% endset %}

    {% set rtl_hebrew %}
      <div class="d-inline-flex align-items-start justify-content-between gap-3 p-3 rounded-3 bg-body-secondary" dir="rtl">
        <div>
          <div class="fw-medium">האירוע נסגר</div>
          <div class="text-body-secondary small">התראת האירוע נוקתה.</div>
        </div>
        {{ close_button(aria_label="סגירה") }}
      </div>
    {% endset %}

    {% set rtl_english %}
      <div class="d-inline-flex align-items-start justify-content-between gap-3 p-3 rounded-3 bg-body-secondary" dir="rtl">
        <div>
          <div class="fw-medium">Incident dismissed</div>
          <div class="text-body-secondary small">The incident alert was cleared.</div>
        </div>
        {{ close_button(aria_label="Close") }}
      </div>
    {% endset %}

    {{ render_rtl_example(
      "close-button-ribbon",
      "Compare Arabic, Hebrew, and English close actions in an RTL layout for operations workflows.",
      rtl_arabic,
      rtl_hebrew,
      rtl_english,
      preview_class="moo-example__preview--narrow"
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's source behavior and CSS variables, see the",
    "https://getbootstrap.com/docs/5.3/components/close-button/",
    "Bootstrap Close button documentation"
  ) }}

{% endblock %}
