{% extends "layouts/catalog.html.jinja" %}
{% from "components/checkbox.html.jinja" import checkbox %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header with context %}

{% block title %}Checkbox — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Checkbox",
    "Toggle a single option using Bootstrap's native checkbox contract."
  ) }}

  <div class="moo-component-examples">
    {% set default %}
      <div class="d-inline-grid gap-2">
        {{ checkbox("checkbox-default", label="Subscribe to the newsletter") }}
        {{ checkbox("checkbox-checked", label="Subscribe to the newsletter", checked=true) }}
      </div>
    {% endset %}
    {{ render_example(
      "default",
      "Default",
      "Unchecked and checked states share the same label contract.",
      default,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set with_description %}
      {{ checkbox(
        "checkbox-description",
        label="Subscribe to the newsletter",
        description="You can unsubscribe at any time from your account settings.",
        checked=true
      ) }}
    {% endset %}
    {{ render_example(
      "with-description",
      "With description",
      "Add supporting copy below the label with <code>description</code>.",
      with_description,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set disabled %}
      <div class="d-inline-grid gap-2">
        {{ checkbox("checkbox-disabled", label="Sync files automatically", disabled=true) }}
        {{ checkbox("checkbox-disabled-checked", label="Sync files automatically", checked=true, disabled=true) }}
      </div>
    {% endset %}
    {{ render_example(
      "disabled",
      "Disabled",
      "Disabled checkboxes lower opacity and drop pointer interaction in both states.",
      disabled,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set invalid %}
      {{ checkbox("checkbox-invalid", label="Subscribe to the newsletter", invalid=true) }}
    {% endset %}
    {{ render_example(
      "invalid",
      "Invalid",
      "Set <code>invalid=true</code> to pair with a form's validation state.",
      invalid,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set rtl_arabic %}
      <div class="d-inline-flex" dir="rtl">
        {{ checkbox("checkbox-rtl-arabic", label="الموافقة على طلب الوصول إلى مساحة العمل") }}
      </div>
    {% endset %}

    {% set rtl_hebrew %}
      <div class="d-inline-flex" dir="rtl">
        {{ checkbox("checkbox-rtl-hebrew", label="אישור בקשת גישה לסביבת העבודה") }}
      </div>
    {% endset %}

    {% set rtl_english %}
      <div class="d-inline-flex" dir="rtl">
        {{ checkbox("checkbox-rtl-english", label="Approve workspace access request") }}
      </div>
    {% endset %}

    {{ render_rtl_example(
      "checkbox",
      "Compare Arabic, Hebrew, and English checkbox labels in an RTL layout for support and access-control workflows.",
      rtl_arabic,
      rtl_hebrew,
      rtl_english,
      preview_class="moo-example__preview--narrow"
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's source behavior and the shared form-check family, see the",
    "https://getbootstrap.com/docs/5.3/forms/checks-radios/",
    "Bootstrap Checks and radios documentation"
  ) }}

{% endblock %}
