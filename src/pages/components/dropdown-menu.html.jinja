{% extends "layouts/catalog.html.jinja" %}
{% from "components/dropdown_menu.html.jinja" import dropdown, dropdown_divider, dropdown_header, dropdown_item %}
{% from "components/alert.html.jinja" import alert %}
{% from "components/checkbox.html.jinja" import checkbox %}
{% from "components/radio_group.html.jinja" import radio_group %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Dropdown Menu — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Dropdown Menu",
    "Collect contextual actions in one compact surface using Bootstrap's native dropdown behavior and placement."
  ) }}

  <div class="moo-component-examples">
    {% set grouped %}
      {% call dropdown("Project actions", align="start", offset="0,6") %}
        {{ dropdown_header("Project") }}
        {{ dropdown_item("Open project", icon="folder-open", shortcut="⌘O") }}
        {{ dropdown_item("Rename project", icon="pencil") }}
        {{ dropdown_divider() }}
        {{ dropdown_item("Archive", icon="archive") }}
        {{ dropdown_item("Delete", icon="trash-2", destructive=true) }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "grouped",
      "Headers and separators",
      "Use headers for workflow groups, then split dense items with a divider before destructive actions.",
      grouped,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set shortcuts %}
      {% call dropdown("Task queue", align="end", offset="0,6") %}
        {{ dropdown_item("Mark complete", icon="check", shortcut="⌘D") }}
        {{ dropdown_item("Add note", icon="pencil", shortcut="⌘N") }}
        {{ dropdown_divider() }}
        {{ dropdown_item("Assign owner", icon="users", shortcut="⌥⌘O") }}
        {{ dropdown_item("Waiting on approval", icon="clock", disabled=true) }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "shortcuts",
      "Keyboard hints",
      "Expose key equivalents beside actions so power users can run the same flow from keyboard and pointer.",
      shortcuts,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set iconed %}
      {% call dropdown("Workspace commands", offset="0,6") %}
        {{ dropdown_item("Duplicate", icon="copy", icon_box=true, shortcut="⇧⌘D") }}
        {{ dropdown_item("Share", icon="share", shortcut="⌘⇧S") }}
        {{ dropdown_divider() }}
        {{ dropdown_item("New tab", icon="layout-dashboard", shortcut="⌘T") }}
        {{ dropdown_item("Invite team", icon="plus", shortcut="⌘I") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "icons",
      "Icon-led rows",
      "Leading icons and optional shortcut text keep each command quickly recognizable in compact menus.",
      iconed,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set toggles %}
      {% call dropdown("View options", auto_close="outside", offset="0,6") %}
        <li class="px-3 py-1 text-nowrap">
          {{ checkbox("dropdown-closed-projects", label="Show closed projects", checked=true) }}
        </li>
        <li class="px-3 py-1 text-nowrap">
          {{ checkbox("dropdown-notify-team", label="Notify teammates on updates") }}
        </li>
        <li class="px-3 py-1 text-nowrap">
          {{ checkbox("dropdown-confidential", label="Allow confidential exports", disabled=true) }}
        </li>
        {{ dropdown_divider() }}
        {{ dropdown_item("Reset view", icon="undo") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "toggles",
      "Checkbox-like actions",
      "Stateful controls can live inside a dropdown for temporary view filters without leaving the current context.",
      toggles,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set selection %}
      {% call dropdown("Sort", auto_close="outside", offset="0,6") %}
        <li class="px-3 py-1">
          {{ radio_group(
            "dropdown-sort", "Sort by", [
              {"id": "dropdown-sort-recent", "label": "Most recent", "checked": true},
              {"id": "dropdown-sort-name", "label": "Name"},
              {"id": "dropdown-sort-urgency", "label": "Urgency"}
            ])
          }}
        </li>
        {{ dropdown_divider() }}
        {{ dropdown_item("Reverse order", icon="redo", shortcut="⇧⌘R") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "radios",
      "Radio-like choices",
      "Use exclusive choices inside a small open context when one sort mode must be selected before returning to the page.",
      selection,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set destructive %}
      {% call dropdown("Danger zone", variant="outline", align="end", offset="0,6") %}
        {{ dropdown_item("Pause publishing", icon="clock") }}
        {{ dropdown_item("Transfer ownership", icon="users") }}
        {{ dropdown_divider() }}
        {{ dropdown_item("Delete project", icon="trash-2", destructive=true, shortcut="⌘⌫") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "destructive",
      "Destructive entry",
      "Keep irreversible actions distinct and use a separate section or separator to reduce mis-clicks.",
      destructive,
      preview_class="moo-example__preview--narrow"
    ) }}

    {% set rtl_arabic %}
      <div class="d-inline-flex" dir="rtl">
        {% call dropdown("الإجراءات", offset="0,6") %}
          {{ dropdown_item("فتح مساحة العمل", icon="folder-open", shortcut="⌘O") }}
          {{ dropdown_divider() }}
          {{ dropdown_item("مشاركة مساحة العمل", icon="share", shortcut="⌘S") }}
          {{ dropdown_item("حذف مساحة العمل", icon="trash-2", destructive=true, shortcut="⌘⌫") }}
        {% endcall %}
      </div>
    {% endset %}

    {% set rtl_hebrew %}
      <div class="d-inline-flex" dir="rtl">
        {% call dropdown("פעולות", offset="0,6") %}
          {{ dropdown_item("פתח סביבת עבודה", icon="folder-open", shortcut="⌘O") }}
          {{ dropdown_divider() }}
          {{ dropdown_item("שתף סביבת עבודה", icon="share", shortcut="⌘S") }}
          {{ dropdown_item("מחק סביבת עבודה", icon="trash-2", destructive=true, shortcut="⌘⌫") }}
        {% endcall %}
      </div>
    {% endset %}

    {% set rtl_english %}
      <div class="d-inline-flex" dir="rtl">
        {% call dropdown("Actions", offset="0,6") %}
          {{ dropdown_item("Open workspace", icon="folder-open", shortcut="⌘O") }}
          {{ dropdown_divider() }}
          {{ dropdown_item("Share workspace", icon="share", shortcut="⌘S") }}
          {{ dropdown_item("Delete workspace", icon="trash-2", destructive=true, shortcut="⌘⌫") }}
        {% endcall %}
      </div>
    {% endset %}

    {{ render_rtl_example(
      "dropdown-menu",
      "Compare Arabic, Hebrew, and English menu flows with the same trigger, icons, shortcuts, divider, and destructive action in RTL layout.",
      rtl_arabic,
      rtl_hebrew,
      rtl_english,
      preview_class="moo-example__preview--narrow"
    ) }}
  </div>

  {{ alert(
    "Submenu gap",
    "Bootstrap has no native submenu in dropdowns, so this catalog keeps nested workflows as separate top-level commands to preserve keyboard behavior and predictable focus.",
    icon="triangle-alert"
  ) }}

  {{ render_reference(
    "For plugin behavior, alignment, and placement options, see the",
    "https://getbootstrap.com/docs/5.3/components/dropdowns/",
    "Bootstrap Dropdown documentation"
  ) }}

{% endblock %}
