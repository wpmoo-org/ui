{% extends "layouts/catalog.html.jinja" %}
{% from "components/navigation.html.jinja" import nav_item, nav_menu %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example, render_rtl_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Navigation — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Navigation",
    "Create compact, semantic navigation surfaces with Bootstrap-native <code>nav</code> patterns for app shells."
  ) }}

  <div class="moo-component-examples">
    {% set horizontal %}
      {% call nav_menu("Workspace sections") %}
        {{ nav_item("Dashboard", href="#", active=true) }}
        {{ nav_item("Tasks", href="#") }}
        {{ nav_item("Apps", href="#") }}
        {{ nav_item("Settings", href="#", disabled=true) }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "horizontal-pills",
      "Pills",
      "Use a compact pill row for workspace routes where current context should be clearly emphasized.",
      horizontal
    ) }}

    {% set sidebar %}
      {% call nav_menu("App sections", vertical=true) %}
        {{ nav_item("Dashboard", href="#", icon="layout-dashboard", active=true) }}
        {{ nav_item("Tasks", href="#", icon="list-check") }}
        {{ nav_item("Apps", href="#", icon="package") }}
        {{ nav_item("Chats", href="#", icon="messages-square", badge_label="3", badge_variant="default") }}
        {{ nav_item("Users", href="#", icon="users") }}
        {{ nav_item("Settings", href="#", icon="settings", end_icon="chevron-right") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "sidebar",
      "Sidebar list",
      "Use one-level, icon-led sidebar items for predictable routes; nested flyouts are handled in a dedicated sidebar pattern.",
      sidebar,
      preview_class="moo-example__preview--fit"
    ) }}

    {% set underline %}
      {% call nav_menu("Project filters", style="underline") %}
        {{ nav_item("All", href="#", active=true) }}
        {{ nav_item("Open", href="#") }}
        {{ nav_item("Archived", href="#") }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "underline",
      "Underline",
      "Use underlines for lightweight filters in narrow views where emphasis should stay subtle.",
      underline
    ) }}

    {% set base %}
      {% call nav_menu("Plain navigation", style="base") %}
        {{ nav_item("Overview", href="#", active=true) }}
        {{ nav_item("Reports", href="#") }}
        {{ nav_item("Disabled", disabled=true) }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "base",
      "Base nav",
      "Use the base style when surrounding layout defines the visual weight and only the active link needs state.",
      base
    ) }}

    {% set nav_rtl_arabic %}
      {% call nav_menu("أقسام التطبيق", vertical=true, dir="rtl") %}
        {{ nav_item("لوحة التحكم", href="#", icon="layout-dashboard", active=true) }}
        {{ nav_item("المهام", href="#", icon="list-check") }}
        {{ nav_item("التطبيقات", href="#", icon="package", badge_label="3", badge_variant="default") }}
      {% endcall %}
    {% endset %}

    {% set nav_rtl_hebrew %}
      {% call nav_menu("אזורי האפליקציה", vertical=true, dir="rtl") %}
        {{ nav_item("לוח בקרה", href="#", icon="layout-dashboard", active=true) }}
        {{ nav_item("משימות", href="#", icon="list-check") }}
        {{ nav_item("יישומים", href="#", icon="package", badge_label="3", badge_variant="default") }}
      {% endcall %}
    {% endset %}

    {% set nav_rtl_english %}
      {% call nav_menu("App sections", vertical=true, dir="rtl") %}
        {{ nav_item("Dashboard", href="#", icon="layout-dashboard", active=true) }}
        {{ nav_item("Tasks", href="#", icon="list-check") }}
        {{ nav_item("Apps", href="#", icon="package", badge_label="3", badge_variant="default") }}
      {% endcall %}
    {% endset %}

    {{ render_rtl_example(
      "navigation",
      "Validate the same sidebar navigation pattern in Arabic, Hebrew, and English while rendering in RTL direction.",
      nav_rtl_arabic,
      nav_rtl_hebrew,
      nav_rtl_english,
      preview_class="moo-example__preview--fit"
    ) }}
  </div>

  {{ render_reference(
    "For dynamic tabs, pills, and JavaScript tab panels, continue with the",
    "https://getbootstrap.com/docs/5.3/components/navs-tabs/",
    "Bootstrap Navs and tabs documentation"
  ) }}

{% endblock %}
