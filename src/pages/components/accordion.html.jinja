{% extends "layouts/catalog.html.jinja" %}
{% from "components/accordion.html.jinja" import accordion %}
{% from "components/card.html.jinja" import card %}
{% from "components/tabs.html.jinja" import tabs %}
{% from "includes/documentation-reference.html.jinja" import render_reference %}
{% from "includes/example.html.jinja" import render_example %}
{% from "includes/page-header.html.jinja" import render_page_header %}

{% block title %}Accordion — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Accordion",
    "Reveal one section of content at a time using Bootstrap's Collapse plugin."
  ) }}

  <div class="moo-component-examples">
    {% set basic %}
      {{ accordion(
        "accordion-basic",
        [
          {
            "id": "priority",
            "title": "How are review requests prioritized?",
            "content": "Requests with customer-facing blockers move to the top of the queue. Routine copy or metadata changes stay grouped for the next review window.",
            "open": true
          },
          {
            "id": "approval",
            "title": "What happens after approval?",
            "content": "The request is archived, the workspace owner is notified, and follow-up tasks stay attached to the same audit trail."
          },
          {
            "id": "reopen",
            "title": "Who can reopen a closed request?",
            "content": "Administrators and assigned reviewers can reopen a request when the customer adds new evidence."
          }
        ]
      ) }}
    {% endset %}
    {{ render_example(
      "basic",
      "Basic",
      "Only one item stays open at a time; opening another closes the current one.",
      basic,
      preview_class="moo-example__preview--medium"
    ) }}

    {% set multiple %}
      {{ accordion(
        "accordion-multiple",
        [
          {
            "id": "intake",
            "title": "Intake checks",
            "content": "Identity, contact, and billing records passed the nightly validation.",
            "open": true
          },
          {
            "id": "documents",
            "title": "Document review",
            "content": "Two uploaded files are waiting for the operations team.",
            "open": true
          },
          {
            "id": "handoff",
            "title": "Handoff notes",
            "content": "The customer success team will receive a summary when all open checks pass."
          }
        ],
        always_open=true
      ) }}
    {% endset %}
    {{ render_example(
      "multiple",
      "Multiple",
      "Set <code>always_open=true</code> to let more than one item stay open at the same time.",
      multiple,
      preview_class="moo-example__preview--medium"
    ) }}

    {% set bordered %}
      {{ accordion(
        "accordion-borders",
        [
          {
            "id": "plan",
            "title": "How does workspace billing work?",
            "content": "Invoicing is calculated at the end of each cycle. You can switch between monthly and annual plans, and the next renewal date is shown in the workspace summary."
          },
          {
            "id": "security",
            "title": "Are billing changes reviewed?",
            "content": "Payment-method updates are logged and require one administrator confirmation before they are applied."
          },
          {
            "id": "support",
            "title": "What happens on a failed charge?",
            "content": "Services move into a grace state and suspend after the grace period if the card cannot be recovered."
          }
        ],
        flush=false
      ) }}
    {% endset %}
    {{ render_example(
      "bordered",
      "Bordered",
      "Use a bordered accordion for policy blocks that sit directly on surface boundaries.",
      bordered,
      preview_class="moo-example__preview--medium"
    ) }}

    {% set disabled %}
      {{ accordion(
        "accordion-disabled",
        [
          {
            "id": "owner",
            "title": "Transfer workspace ownership",
            "content": "Owners can move a workspace to another internal administrator."
          },
          {
            "id": "retention",
            "title": "Change retention policy",
            "content": "Policy changes are locked while the legal hold is active.",
            "disabled": true
          },
          {
            "id": "export",
            "title": "Export audit history",
            "content": "Exports include request status, reviewer notes, and attachment metadata."
          }
        ]
      ) }}
    {% endset %}
    {{ render_example(
      "disabled",
      "Disabled",
      "Set <code>disabled</code> on an item to remove it from keyboard and pointer interaction.",
      disabled,
      preview_class="moo-example__preview--medium"
    ) }}

    {% set in_card %}
      {% call card(
        title="Workspace billing",
        subtitle="Plan, invoice, and cancellation questions for operations teams."
      ) %}
        {{ accordion(
          "accordion-in-card",
          [
            {
              "id": "plan",
              "title": "Which plan should a team choose?",
              "content": "Small teams usually start with shared operations, then move to dedicated review seats when approval volume grows.",
              "open": true
            },
            {
              "id": "invoice",
              "title": "How are invoices reviewed?",
              "content": "Invoices are grouped by workspace and include the renewal window, seats, and any service adjustments."
            },
            {
              "id": "cancel",
              "title": "Can a workspace cancel immediately?",
              "content": "Owners can cancel renewal at any time. Active service continues until the current billing period ends."
            }
          ]
        ) }}
      {% endcall %}
    {% endset %}
    {{ render_example(
      "in-card",
      "In a card",
      "Wrap the accordion in a card for settings surfaces that need a clearer container boundary.",
      in_card,
      preview_class="moo-example__preview--medium"
    ) }}

    {% set arabic_accordion %}
      <div dir="rtl">
        {{ accordion(
          "accordion-rtl-arabic",
          [
            {
              "id": "priority",
              "title": "كيف نرتب الطلبات؟",
              "content": "تظهر الطلبات العاجلة أولاً في قائمة الفريق.",
              "open": true
            },
            {
              "id": "handoff",
              "title": "متى نرسل الملخص؟",
              "content": "يرسل الملخص بعد اكتمال الفحوصات الأساسية."
            },
            {
              "id": "owner",
              "title": "من يراجع النتيجة؟",
              "content": "يراجعها مسؤول المساحة قبل الإغلاق."
            }
          ]
        ) }}
      </div>
    {% endset %}

    {% set hebrew_accordion %}
      <div dir="rtl">
        {{ accordion(
          "accordion-rtl-hebrew",
          [
            {
              "id": "priority",
              "title": "איך מתעדפים בקשות?",
              "content": "בקשות שחוסמות לקוחות עולות לראש התור.",
              "open": true
            },
            {
              "id": "summary",
              "title": "מתי שולחים סיכום?",
              "content": "הסיכום נשלח אחרי השלמת הבדיקות העיקריות."
            },
            {
              "id": "reviewer",
              "title": "מי מאשר את התוצאה?",
              "content": "מנהל סביבת העבודה מאשר לפני סגירה."
            }
          ]
        ) }}
      </div>
    {% endset %}

    {% set english_accordion %}
      <div dir="rtl">
        {{ accordion(
          "accordion-rtl-english",
          [
            {
              "id": "priority",
              "title": "How are requests ordered?",
              "content": "Customer-facing blockers stay at the top of the review queue.",
              "open": true
            },
            {
              "id": "summary",
              "title": "When is the summary sent?",
              "content": "The summary goes out after the required checks pass."
            },
            {
              "id": "reviewer",
              "title": "Who signs off?",
              "content": "A workspace admin confirms the result before closure."
            }
          ]
        ) }}
      </div>
    {% endset %}

    {% set rtl %}
      {{ tabs(
        "accordion-direction-tabs",
        [
          {
            "id": "arabic",
            "title": "Arabic",
            "content": arabic_accordion,
            "active": true
          },
          {
            "id": "hebrew",
            "title": "Hebrew",
            "content": hebrew_accordion
          },
          {
            "id": "english",
            "title": "English",
            "content": english_accordion
          }
        ]
      ) }}
    {% endset %}
    {{ render_example(
      "rtl",
      "Direction aware",
      "Use tabs to compare Arabic, Hebrew, and English accordions without custom mirrored CSS.",
      rtl,
      preview_class="moo-example__preview--medium"
    ) }}
  </div>

  {{ render_reference(
    "For Bootstrap's Collapse plugin behavior and accessibility notes, see the",
    "https://getbootstrap.com/docs/5.3/components/accordion/",
    "Bootstrap Accordion documentation"
  ) }}

{% endblock %}
