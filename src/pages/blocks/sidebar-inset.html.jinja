{% extends "layouts/catalog.html.jinja" %}
{% from "blocks/sidebar_shell.html.jinja" import render_sidebar_shell %}
{% from "includes/block-example.html.jinja" import render_block_example %}
{% from "includes/page-header.html.jinja" import render_page_header with context %}

{% block title %}Sidebar (Inset) — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Sidebar (Inset)",
    "A composed application shell using the inset sidebar variant — the page content becomes a floating, rounded card inset from the sidebar."
  ) }}

  <div class="moo-component-examples">
    {% set screen %}
      {{ render_sidebar_shell(
        key="block-sidebar-inset",
        sidebar_id="block-sidebar-inset-demo",
        variant="inset",
        demo_copy="portal"
      ) }}
    {% endset %}
    {{ render_block_example(
      "sidebar-inset",
      "Inset sidebar",
      "The page content becomes a floating, rounded card inset from the sidebar, using the same header, content, and footer macros as the default variant.",
      screen,
      preview_class="moo-example__preview--shell",
      frame_src=site_href("blocks/previews/sidebar-inset.html", root_path)
    ) }}
  </div>
{% endblock %}
