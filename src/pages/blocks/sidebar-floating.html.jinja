{% extends "layouts/catalog.html.jinja" %}
{% from "blocks/sidebar_shell.html.jinja" import render_sidebar_shell %}
{% from "includes/block-example.html.jinja" import render_block_example %}
{% from "includes/page-header.html.jinja" import render_page_header with context %}

{% block title %}Sidebar (Floating) — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Sidebar (Floating)",
    "A composed application shell using the floating sidebar variant — the sidebar detaches from the edge as a bordered, elevated card."
  ) }}

  <div class="moo-component-examples">
    {% set screen %}
      {{ render_sidebar_shell(
        key="block-sidebar-floating",
        sidebar_id="block-sidebar-floating-demo",
        variant="floating",
        demo_copy="portal"
      ) }}
    {% endset %}
    {{ render_block_example(
      "sidebar-floating",
      "Floating sidebar",
      "The sidebar detaches from the edge with a border, radius, and shadow, using the same header, content, and footer macros as the default variant.",
      screen,
      preview_class="moo-example__preview--shell",
      frame_src=site_href("blocks/previews/sidebar-floating.html", root_path)
    ) }}
  </div>
{% endblock %}
