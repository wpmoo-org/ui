{% extends "layouts/catalog.html.jinja" %}
{% from "components/button.html.jinja" import button %}
{% from "components/card.html.jinja" import card %}
{% from "components/typography.html.jinja" import typography %}

{% block title %}Moo UI{% endblock %}

{% block content %}
  <section class="moo-catalog__intro" aria-labelledby="home-title">
    {{ typography("Moo UI", variant="page-title", id="home-title") }}
    <p class="lead text-body-secondary mb-0">
      A Bootstrap-native component system shaped to the shadcn visual language.
    </p>
  </section>

  <section class="moo-catalog__dashboard" aria-label="Get started">
    <div class="moo-catalog__grid moo-catalog__grid--compact">
      {% call card(extra_class="h-100 moo-catalog__app-card", body_class="d-grid gap-3") %}
        <div>
          <h2 class="h5 mb-2">Components</h2>
          <p class="text-body-secondary mb-0">
            Browse the Bootstrap-native primitives that make up the Moo UI shell.
          </p>
        </div>
        <div>
          {{ button(
            "Browse Components",
            variant="outline",
            size="sm",
            element="a",
            href=root_path ~ "components/index.html"
          ) }}
        </div>
      {% endcall %}
      {% call card(extra_class="h-100 moo-catalog__app-card", body_class="d-grid gap-3") %}
        <div>
          <h2 class="h5 mb-2">Blocks</h2>
          <p class="text-body-secondary mb-0">
            Full composed screens built from ready component macros.
          </p>
        </div>
        <div>
          {{ button(
            "Browse Blocks",
            variant="outline",
            size="sm",
            element="a",
            href=root_path ~ "blocks/index.html"
          ) }}
        </div>
      {% endcall %}
    </div>
  </section>
{% endblock %}
