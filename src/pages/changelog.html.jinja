{% extends "layouts/catalog.html.jinja" %}
{% from "includes/doc-toc.html.jinja" import render_doc_toc %}
{% from "includes/page-header.html.jinja" import render_page_header %}
{% from "includes/page-navigation.html.jinja" import render_section_page_actions, render_section_page_pagination %}

{% block title %}Changelog - Moo UI{% endblock %}

{% block content %}
  <div class="moo-doc-layout">
    <article class="moo-doc-page">
      {{ render_page_header(
        "Changelog",
        "Product-facing notes for the public Moo UI package and catalog.",
        id="changelog",
        actions=render_section_page_actions(current_slug, sections, root_path)
      ) }}

      <section class="moo-changelog" aria-label="Moo UI release history">
        <article class="moo-changelog__release" aria-labelledby="documentation-navigation">
          <div class="moo-changelog__release-heading">
            <span class="badge text-bg-dark">v0.2.1</span>
            <span class="text-body-secondary">Documentation navigation</span>
          </div>
          <h2 id="documentation-navigation">Documentation Navigation</h2>
          <p>Added page-level copy, AI handoff, and previous/next navigation across the public documentation.</p>

          <div class="moo-changelog__changes">
            <div class="moo-changelog__change-row">
              <span class="moo-changelog__change-label">Updated</span>
              <span>Section landing pages now share the same narrow documentation layout, TOC rhythm, and release-aware install links.</span>
            </div>
          </div>
        </article>

        <article class="moo-changelog__release" aria-labelledby="wave-4-components">
          <div class="moo-changelog__release-heading">
            <span class="badge text-bg-dark">v0.2.0</span>
            <span class="text-body-secondary">Component catalog expansion</span>
          </div>
          <h2 id="wave-4-components">Wave 4 Components</h2>
          <p>Expanded the Bootstrap-native catalog with polished component examples, shared RTL previews, and refreshed overlay behavior.</p>

          <div class="moo-changelog__changes">
            <div class="moo-changelog__change-row">
              <span class="moo-changelog__change-label">Added</span>
              <span>New and refined examples for the Wave 4 component set, including tables, toggle groups, menus, overlays, and form controls.</span>
            </div>
            <div class="moo-changelog__change-row">
              <span class="moo-changelog__change-label">Updated</span>
              <span>RTL examples now use a shared tabbed preview pattern across component pages.</span>
            </div>
          </div>
        </article>

        <article class="moo-changelog__release" aria-labelledby="catalog-polish">
          <div class="moo-changelog__release-heading">
            <span class="badge text-bg-dark">v0.1.1</span>
            <span class="text-body-secondary">Public package refresh</span>
          </div>
          <h2 id="catalog-polish">Catalog Polish</h2>
          <p>Refined the public catalog, homepage, and package metadata for the npm release.</p>

          <div class="moo-changelog__changes">
            <div class="moo-changelog__change-row">
              <span class="moo-changelog__change-label">Updated</span>
              <span>Homepage, documentation pages, and npm package metadata.</span>
            </div>
          </div>
        </article>

        <article class="moo-changelog__release" aria-labelledby="initial-release">
          <div class="moo-changelog__release-heading">
            <span class="badge text-bg-dark">v0.1.0</span>
            <span class="text-body-secondary">Initial public package</span>
          </div>
          <h2 id="initial-release">Initial Release</h2>
          <p>First public release of Moo UI.</p>

          <div class="moo-changelog__changes">
            <div class="moo-changelog__change-row">
              <span class="moo-changelog__change-label">Added</span>
              <span>Initial Release</span>
            </div>
          </div>
        </article>
      </section>

      {{ render_section_page_pagination(current_slug, sections, root_path) }}
    </article>

    {{ render_doc_toc([
      {"id": "documentation-navigation", "label": "Documentation Navigation"},
      {"id": "wave-4-components", "label": "Wave 4 Components"},
      {"id": "catalog-polish", "label": "Catalog Polish"},
      {"id": "initial-release", "label": "Initial Release"}
    ]) }}
  </div>
{% endblock %}
