{% extends "layouts/catalog.html.jinja" %}
{% from "components/typography.html.jinja" import typography %}
{% from "includes/doc-toc.html.jinja" import render_doc_toc %}
{% from "includes/page-header.html.jinja" import render_page_header with context %}
{% from "includes/page-navigation.html.jinja" import render_section_page_actions, render_section_page_pagination %}

{% block title %}License - Moo UI{% endblock %}

{% block content %}
  <div class="moo-doc-layout">
    <article class="moo-doc-page">
      {{ render_page_header(
        "License",
        "Moo UI source is MIT licensed, with separate notices for bundled references, fonts, icons, and visual assets.",
        id="license",
        actions=render_section_page_actions(current_slug, site_pages, root_path)
      ) }}

      <section class="moo-doc-section" aria-labelledby="mit-license">
        {{ typography("MIT License", variant="section-title", id="mit-license") }}
        <p>
          Moo UI source code is licensed under the <a href="https://github.com/wpmoo-org/ui/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">MIT License</a> by WPMoo
          (<code>wpmoo.org</code>). You can use, copy, modify, merge, publish,
          distribute, sublicense, and sell copies of the software as long as the
          copyright notice and permission notice stay with substantial copies of
          the software.
        </p>
        <p>
          The software is provided <q>as is</q>, without warranty of any kind.
          The authors and copyright holders are not liable for claims, damages,
          or other liability arising from use of the software.
        </p>
      </section>

      <section class="moo-doc-section" aria-labelledby="third-party-notices">
        {{ typography("Third-Party Notices", variant="section-title", id="third-party-notices") }}
        <p>
          Moo UI keeps third-party material under its original license and
          attribution. These notices describe what is vendored, referenced, or
          used as visual context.
        </p>

        <div class="d-grid gap-4 mt-4">
          <div>
            <h3 class="h5 mb-2">Bootstrap</h3>
            <p class="mb-0">
              Moo UI vendors the official <code>twbs/bootstrap</code> v5.3.3 SCSS
              source and bundled JavaScript. Bootstrap is licensed under the MIT
              License; the bundled license is stored at
              <code>vendor/bootstrap/LICENSE</code>. Bootstrap documentation is used
              as the behavior, semantics, and accessibility reference for this
              product.
            </p>
          </div>

          <div>
            <h3 class="h5 mb-2">shadcn/ui</h3>
            <p class="mb-0">
              shadcn/ui documentation is used as visual-intent and catalog coverage
              reference. No shadcn/ui implementation source, React code, Tailwind
              code, Radix code, or example prose is bundled or copied. Moo UI
              documentation, example copy, component templates, styles, and inline
              SVG icons are original product work.
            </p>
          </div>

          <div>
            <h3 class="h5 mb-2">Lucide</h3>
            <p class="mb-0">
              Moo UI vendors a build-time icon metadata subset from Iconify's Lucide
              icon set at <code>src/icons/lucide-icons.json</code> and renders
              selected icons into the generated catalog. Lucide is licensed under
              the ISC License.
            </p>
          </div>

          <div>
            <h3 class="h5 mb-2">Geist</h3>
            <p class="mb-0">
              Moo UI vendors <code>Geist-Variable.woff2</code> for catalog chrome
              typography only. Geist is licensed under the SIL Open Font License
              1.1; the bundled license is stored at <code>vendor/geist/LICENSE</code>.
            </p>
          </div>
        </div>
      </section>

      <section class="moo-doc-section" aria-labelledby="visual-assets">
        {{ typography("Visual Assets", variant="section-title", id="visual-assets") }}
        <p>
          WPMoo-generated visual assets, including image assets under
          <code>static/images/</code>, are original WPMoo work and are not
          licensed under MIT unless explicitly stated. See
          <a href="https://github.com/wpmoo-org/ui/blob/main/ASSET_LICENSE.md" target="_blank" rel="noopener noreferrer"><code>ASSET_LICENSE.md</code></a> for the asset license contract.
        </p>
      </section>

      {{ render_section_page_pagination(current_slug, site_pages, root_path) }}
    </article>

    {{ render_doc_toc([
      {"id": "mit-license", "label": "MIT License"},
      {"id": "third-party-notices", "label": "Third-Party Notices"},
      {"id": "visual-assets", "label": "Visual Assets"}
    ]) }}
  </div>
{% endblock %}
