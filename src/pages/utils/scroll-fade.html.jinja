{% extends "layouts/catalog.html.jinja" %}
{% from "includes/page-header.html.jinja" import render_page_header with context %}
{% from "includes/example.html.jinja" import render_example %}

{% block title %}Scroll Fade — Moo UI{% endblock %}

{% block content %}
  {{ render_page_header(
    "Scroll Fade",
    "Hint at content beyond a scroll boundary without adding visible chrome."
  ) }}

  <div class="moo-component-examples">
    {% set vertical_scroll %}
      <div class="scroll-fade no-scrollbar overflow-y-auto border rounded-4 p-3 w-100" style="height: 14rem; max-width: 20rem;">
        <div class="vstack gap-3">
          <p class="mb-0 pb-3 border-bottom">Review the latest workspace activity.</p>
          <p class="mb-0 pb-3 border-bottom">Compare the proposed navigation changes.</p>
          <p class="mb-0 pb-3 border-bottom">Confirm the accessible names.</p>
          <p class="mb-0 pb-3 border-bottom">Check the compact density.</p>
          <p class="mb-0 pb-3 border-bottom">Test the dark theme.</p>
          <p class="mb-0 pb-3 border-bottom">Verify the right-to-left layout.</p>
          <p class="mb-0">Publish the approved update.</p>
        </div>
      </div>
    {% endset %}
    {{ render_example(
      "vertical-scroll",
      "Vertical scrolling",
      "Combine <code>scroll-fade</code> with <code>overflow-y-auto</code> to show a mask only while more content remains above or below.",
      vertical_scroll
    ) }}

    {% set no_overflow %}
      <div class="scroll-fade no-scrollbar overflow-y-auto border rounded-4 p-3 w-100" style="height: 14rem; max-width: 20rem;">
        <div class="vstack gap-3">
          <p class="mb-0">Short content keeps both edges clear.</p>
          <p class="mb-0">No extra state or script is required.</p>
        </div>
      </div>
    {% endset %}
    {{ render_example(
      "no-overflow",
      "No overflow",
      "When the content fits, the utility stays quiet: no mask appears and no extra script is needed.",
      no_overflow
    ) }}

    {% set horizontal_scroll %}
      <div class="scroll-fade-x no-scrollbar d-flex gap-2 overflow-x-auto py-2 w-100" style="max-width: 24rem;">
        <span class="flex-shrink-0 border rounded-pill px-3 py-2">Overview</span>
        <span class="flex-shrink-0 border rounded-pill px-3 py-2">Activity</span>
        <span class="flex-shrink-0 border rounded-pill px-3 py-2">Collaborators</span>
        <span class="flex-shrink-0 border rounded-pill px-3 py-2">Permissions</span>
        <span class="flex-shrink-0 border rounded-pill px-3 py-2">Automations</span>
        <span class="flex-shrink-0 border rounded-pill px-3 py-2">Integrations</span>
      </div>
    {% endset %}
    {{ render_example(
      "horizontal-scroll",
      "Horizontal scrolling",
      "Use <code>scroll-fade-x</code> for horizontally overflowing rows; its inline-axis behavior also works in RTL layouts.",
      horizontal_scroll
    ) }}

    {% set edge_fades %}
      <div class="row g-3 w-100" style="max-width: 40rem;">
        {% for edge, label in [("t", "Top"), ("b", "Bottom")] %}
          <div class="col-12 col-sm-6">
            <p class="small text-body-secondary mb-2">{{ label }}</p>
            <div class="scroll-fade-{{ edge }} no-scrollbar overflow-y-auto border rounded-3 p-3" style="height: 8rem;">
              <div class="vstack gap-3">
                <span>Planning</span><span>Design</span><span>Review</span><span>Release</span><span>Archive</span>
              </div>
            </div>
          </div>
        {% endfor %}
        {% for edge, label in [("l", "Left"), ("r", "Right"), ("s", "Inline start"), ("e", "Inline end")] %}
          <div class="col-12 col-sm-6">
            <p class="small text-body-secondary mb-2">{{ label }}</p>
            <div class="scroll-fade-{{ edge }} no-scrollbar d-flex gap-3 overflow-x-auto border rounded-3 p-3">
              <span class="flex-shrink-0">Planning</span><span class="flex-shrink-0">Design</span><span class="flex-shrink-0">Review</span><span class="flex-shrink-0">Release</span><span class="flex-shrink-0">Archive</span>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endset %}
    {{ render_example(
      "edge-fades",
      "Single edges",
      "Choose physical edges such as <code>scroll-fade-t</code> or logical edges such as <code>scroll-fade-s</code> when only one boundary needs a cue.",
      edge_fades
    ) }}

    {% set fade_size %}
      <div class="d-grid gap-3 w-100" style="max-width: 24rem;">
        <div class="scroll-fade-x no-scrollbar d-flex gap-3 overflow-x-auto border rounded-3 p-3" style="--scroll-fade-size: 1rem;">
          <span class="flex-shrink-0">Compact</span><span class="flex-shrink-0">fade</span><span class="flex-shrink-0">keeps</span><span class="flex-shrink-0">content</span><span class="flex-shrink-0">nearby</span>
        </div>
        <div class="scroll-fade-x no-scrollbar d-flex gap-3 overflow-x-auto border rounded-3 p-3" style="--scroll-fade-size: 4rem;">
          <span class="flex-shrink-0">Roomy</span><span class="flex-shrink-0">fade</span><span class="flex-shrink-0">creates</span><span class="flex-shrink-0">a</span><span class="flex-shrink-0">longer</span><span class="flex-shrink-0">transition</span>
        </div>
      </div>
    {% endset %}
    {{ render_example(
      "fade-size",
      "Fade size",
      "Override <code>--scroll-fade-size</code> when a surface needs a shorter or longer transition without changing the utility itself.",
      fade_size
    ) }}

    {% set disabled_fade %}
      <div class="scroll-fade-x scroll-fade-none no-scrollbar d-flex gap-3 overflow-x-auto border rounded-3 p-3 w-100" style="max-width: 24rem;">
        <span class="flex-shrink-0">Temporarily</span><span class="flex-shrink-0">disable</span><span class="flex-shrink-0">the</span><span class="flex-shrink-0">mask</span><span class="flex-shrink-0">without</span><span class="flex-shrink-0">changing</span><span class="flex-shrink-0">overflow</span>
      </div>
    {% endset %}
    {{ render_example(
      "disabled-fade",
      "Disable the fade",
      "Add <code>scroll-fade-none</code> to remove only the mask; scrolling and the hidden-scrollbar behavior remain intact.",
      disabled_fade
    ) }}
  </div>

{% endblock %}
