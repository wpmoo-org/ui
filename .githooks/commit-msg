#!/usr/bin/env bash
set -euo pipefail

root_dir="$(git rev-parse --show-toplevel)"
"$root_dir/scripts/check-public-git-labels.sh" commit-msg "$1"

branch_name="$(git -C "$root_dir" branch --show-current || true)"
if [[ -n "$branch_name" ]]; then
  "$root_dir/scripts/check-public-git-labels.sh" ref-name "$branch_name"
fi
