#!/usr/bin/env bash
set -euo pipefail

root_dir="$(git rev-parse --show-toplevel)"
workspace_root="$(cd "$root_dir/../../.." && pwd)"
guard="$workspace_root/scripts/ui/git-label-guard.sh"

if [[ ! -x "$guard" ]]; then
  exit 0
fi

"$guard" commit-msg "$1"

branch_name="$(git -C "$root_dir" branch --show-current || true)"
if [[ -n "$branch_name" ]]; then
  "$guard" ref-name "$branch_name"
fi
